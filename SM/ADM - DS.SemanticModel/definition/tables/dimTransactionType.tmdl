	partition dimTransactionType = m
		mode: import
		queryGroup: Dim
		source =
				let
				    Source = Sql.Database(#"SQL Address", "MT", [Query="Select PO_TypeID AS 'ID'#(lf),PO_TypeDescription AS 'Desc'#(lf),CASE#(lf)#(tab)WHEN PO_Family = '2'#(lf)#(tab)#(tab)THEN 'Basis'#(lf)#(tab)WHEN PO_Family = '1'#(lf)#(tab)#(tab)THEN 'Flat'#(lf)#(tab)WHEN PO_Family = '0'#(lf)#(tab)#(tab)THEN 'Template'#(lf)#(tab)ELSE NULL#(lf)END AS 'Family'#(lf),CASE#(lf)#(tab)WHEN PO_TypeDescription LIKE '%PREMIUM%' AND PO_TypeDescription NOT LIKE '%PREMIUM Changed%'#(lf)#(tab)#(tab)THEN 'PREMIUM'#(lf)#(tab)WHEN PO_TypeDescription LIKE '%CIF%' or PO_TypeDescription LIKE '%C+F%'#(lf)#(tab)#(tab)THEN 'CIF'#(lf)#(tab)WHEN PO_TypeDescription LIKE '%FOB%' or PO_TypeDescription LIKE '%FOT%'#(lf)#(tab)#(tab)THEN 'FOT'#(lf)#(tab)ELSE NULL#(lf)END AS 'Group'#(lf)from PurchaseOrderTypes"])
				in
				    Source

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navigation

