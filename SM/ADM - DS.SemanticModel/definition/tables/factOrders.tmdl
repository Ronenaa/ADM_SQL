	measure 'לקוחות חדשים' = ```
			
			
			SUMX(
			    VALUES(dimDates[MonthInCalendarName]),
			CALCULATE(COUNTROWS (
			
			    FILTER (
			        ADDCOLUMNS (
			            //CROSSJOIN(VALUES(factSales[AccountKey]),VALUES(factSales[AgentKey])),
			            VALUES ('factOrders'[AccountKey]), 
			            "PreviousSales", 
			                CALCULATE (
			                  
			                    COUNTROWS ( 'factOrders'), //Original Calc
			                    ALL(dimCustomers),
			                    FILTER (
			                        ALL ( dimDates ),
			                        dimDates[Date] < min(dimDates[Date])
			                    )
			                )
			                ,"ThisSales"
			              ,[Total Sales]
			        ),
			      
			          [PreviousSales]=0
			          && [ThisSales]>0
			         
			    )
			)))
			```
