	measure 'Lazy Customer - Supply Date Last Year' =
			
			VAR MonthParameter = SELECTEDVALUE(LazyCustomerSupplyLastYearMonths[LazyCustomerSupplyLastYearMonths])
			VAR _year = Year(CALCULATE(MAX(dimDates[Date]),ALL(dimDates),dimDates[IsHistory]=1))
			VAR _Ly = _year - 1
			VAR _LastMonth = EOMONTH(CALCULATE(MAX(dimDates[Date]),dimDates[IsHistory]=1),-2)
			VAR _OpenOrders = CALCULATE([Total Quantity Supply Date],Filter(ALL(dimDates),dimDates[Date]>_LastMonth))
			VAR _QtyCheck = IF(ISBLANK(CALCULATE([Total Quantity Supply Date],FILTER(ALL(dimDates),YEAR(dimDates[Date])=_Ly))),0,1)
			VAR _LYCheckTable = CALCULATETABLE(SUMMARIZE(factOrders,dimCustomers[שם לקוח אב],dimDates[MonthInCalendarName],"QtyCheck",_QtyCheck),FILTER(dimDates,YEAR(dimDates[Date])=_Ly))
			VAR _LYSumTable=SELECTCOLUMNS(
			                FILTER(
			                    SUMMARIZE(_LYCheckTable,dimCustomers[שם לקוח אב],"Sum",SUMX(_LYCheckTable,[QtyCheck]))
			                    ,[Sum]>=MonthParameter)
			                ,dimCustomers[שם לקוח אב])
			VAR __CurrentSumTable=SELECTCOLUMNS(
			                                    FILTER(
			                                        SUMMARIZE(factOrders,dimCustomers[שם לקוח אב],"Sum",_OpenOrders)
			                                    ,_OpenOrders = BLANK())
			                                ,dimCustomers[שם לקוח אב])
			
			VAR _Count = COUNTROWS(INTERSECT(_LYSumTable,__CurrentSumTable))
			
			RETURN
			_Count
		formatString: 0
		lineageTag: 961c26b8-791f-4052-8c4b-f50391c8541a

		changedProperty = IsHidden

	measure 'Lazy Customer Check' =
			
			[Lazy Customer - Supply Date] + [Lazy Customer - Execution]
		formatString: 0
