	measure 'Quantity Sales USD NIS Switch CurrentYear' =
			
			VAR _year = YEAR(CALCULATE(MAX(dimDates[Date]),dimDates[IsHistory]=1))
			
			RETURN
			 SWITCH(MAX(OrderVSExecutionVSSupply[ID]),
			    1,SWITCH(MAX(VAT_MeasureSelctionTable[ID ANALYSIS]),
			        1, CALCULATE([Total Sales NIS],Filter(dimDates,YEAR(dimDates[Date])=_year)),
			        2, CALCULATE([Total Sales USD],Filter(dimDates,YEAR(dimDates[Date])=_year)),
			        3, CALCULATE([Total Quantity],Filter(dimDates,YEAR(dimDates[Date])=_year)))
			    ,2,SWITCH(MAX(VAT_MeasureSelctionTable[ID ANALYSIS]),
			        1, CALCULATE([Total Sales NIS Supply Date],Filter(dimDates,YEAR(dimDates[Date])=_year)),
			        2, CALCULATE([Total Sales USD Supply Date],Filter(dimDates,YEAR(dimDates[Date])=_year)),
			        3, CALCULATE([Total Quantity Supply Date],Filter(dimDates,YEAR(dimDates[Date])=_year)))
			    ,3,SWITCH(MAX(VAT_MeasureSelctionTable[ID ANALYSIS]),
			        1, CALCULATE([Total Sales NIS (Sales)],Filter(dimDates,YEAR(dimDates[Date])=_year)),
			        2, CALCULATE([Total Sales USD (Sales)],Filter(dimDates,YEAR(dimDates[Date])=_year)),
			        3, CALCULATE([Total Quantity (Sales)],Filter(dimDates,YEAR(dimDates[Date])=_year)))
			 )
		lineageTag: fa2230bc-2246-49de-a53b-285bd006f532

