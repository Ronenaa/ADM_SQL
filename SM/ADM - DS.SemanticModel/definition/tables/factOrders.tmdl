	measure 'InactiveCustomer – Yellow Flag' =
			
			VAR F_Supply_YTD =
			    [InactiveCustomer - Orders Supply Date Flag YTD vs LY YTD]
			
			VAR F_180_Qty =
			    CALCULATE(
			        [InactiveCustomer - Switch Flag 180 days vs 180 days],
			        'OrderSupplyExecution Parameter'[OrderSupplyExecution Parameter Order] = 1
			    )
			
			VAR F_180_Del =
			    CALCULATE(
			        [InactiveCustomer - Switch Flag 180 days vs 180 days],
			        'OrderSupplyExecution Parameter'[OrderSupplyExecution Parameter Order] = 3
			    )
			
			VAR F_90_Qty =
			    CALCULATE(
			        [InactiveCustomer - Switch Flag 90 days vs 90 days],
			        'OrderSupplyExecution Parameter'[OrderSupplyExecution Parameter Order] = 1
			    )
			
			VAR F_90_Del =
			    CALCULATE(
			        [InactiveCustomer - Switch Flag 90 days vs 90 days],
			        'OrderSupplyExecution Parameter'[OrderSupplyExecution Parameter Order] = 3
			    )
			
			// check if any of the four secondary flags = 1
			VAR OtherFlagsCount =
			    IF( F_180_Qty = 1, 1, 0 )
			  + IF( F_180_Del = 1, 1, 0 )
			  + IF( F_90_Qty  = 1, 1, 0 )
			  + IF( F_90_Del  = 1, 1, 0 )
			  + IF( F_Supply_YTD = 1, 1, 0 )
			
			RETURN
			    IF(
			        OtherFlagsCount=0,
			        --ISBLANK(F_Supply_YTD),
			        BLANK(),                       // no YTD data → blank
			        IF(
			            //F_Supply_YTD = 1 && OtherFlagsCount >=1, // YTD = 1 AND at least one other = 1
			            OtherFlagsCount >=2,
			            1,
			            0
			        )
			    )
		formatString: 0
		lineageTag: 55c05b9b-9286-4b4c-80e2-56af5802f997

		changedProperty = IsHidden

