			    ISBLANK([Sales - Risk Plan Basis]) && ISBLANK([Purchase - Risk Plan Basis]),
			        BLANK(),
			        [Avg Sales Balance Price Basis Flat Value By Supply Date] --[Avg Sales Price Basis Flat Value By Supply Date]
			    )
			,0)
