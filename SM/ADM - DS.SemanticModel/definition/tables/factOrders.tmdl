	measure 'Avg Price Date Switch' = ```
			
			Var _today = CALCULATE(MAX(dimDates[Date]),dimDates[IsHistory]=1)
			Var _thisMonth = EOMONTH(_today,0)
			VAR _ThisWeek = CALCULATE(MAX(dimDates[WeekEnding]),dimDates[IsHistory]=1)
			Var _Daily = EOMONTH(_today,-2)
			VAR _Weekly = EOMONTH(_today,-7)
			VAR _Monthly = EOMONTH(_today,-9)
			VAR _WeeklyFull = CALCULATE(MAX(dimDates[WeekStart]),FILTER(dimDates,dimDates[Date]=_Weekly))
			RETURN
			
			SWITCH(SELECTEDVALUE('Time Selection'[Time Selection Order]),
			0,SWITCH(SELECTEDVALUE(OrderVSExecutionVSSupply[ID]),
			    1,CALCULATE([Avg Unit Price],FILTER(Sub_dimDates,Sub_dimDates[Date]<=_today &&Sub_dimDates[Date]>_Daily)),
			     2,CALCULATE([Avg Unit Price By Supply Date],USERELATIONSHIP(Sub_dimDates[Date],factOrders[תאריך אספקה]),FILTER(Sub_dimDates,Sub_dimDates[Date]<=_today &&Sub_dimDates[Date]>_Daily))
			    ),
			1,SWITCH(SELECTEDVALUE(OrderVSExecutionVSSupply[ID]),
			    1,CALCULATE([Avg Unit Price],FILTER(Sub_dimDates,Sub_dimDates[Date]<=_today &&Sub_dimDates[Date]>=_WeeklyFull)),
			     2,CALCULATE([Avg Unit Price By Supply Date],USERELATIONSHIP(Sub_dimDates[Date],factOrders[תאריך אספקה]),FILTER(Sub_dimDates,Sub_dimDates[Date]<=_today &&Sub_dimDates[Date]>=_WeeklyFull))
			    ),
			2,SWITCH(SELECTEDVALUE(OrderVSExecutionVSSupply[ID]),
			    1,CALCULATE([Avg Unit Price],FILTER(Sub_dimDates,Sub_dimDates[Date]<=_today &&Sub_dimDates[Date]>_Monthly)),
			    2,CALCULATE([Avg Unit Price By Supply Date],USERELATIONSHIP(Sub_dimDates[Date],factOrders[תאריך אספקה]),FILTER(Sub_dimDates,Sub_dimDates[Date]<=_today &&Sub_dimDates[Date]>_Monthly))
			    )
			)
			
			```
		formatString: \$#,0;(\$#,0);\$#,0
		lineageTag: f7857521-36ba-4ab8-8f1f-a92fd1a235d6

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Quantity Date Switch' = ```
			
			Var _today = CALCULATE(MAX(dimDates[Date]),dimDates[IsHistory]=1)
			Var _thisMonth = EOMONTH(_today,0)
			VAR _ThisWeek = CALCULATE(MAX(dimDates[WeekEnding]),dimDates[IsHistory]=1)
			Var _Daily = EOMONTH(_today,-2)
			VAR _Weekly = EOMONTH(_today,-7)
			VAR _Monthly = EOMONTH(_today,-9)
			VAR _WeeklyFull = CALCULATE(MAX(dimDates[WeekStart]),FILTER(dimDates,dimDates[Date]=_Weekly))
			RETURN
			
			SWITCH(SELECTEDVALUE('Time Selection'[Time Selection Order]),
			0,IF(MAX(Sub_dimDates[Date])<=_today && MIN(Sub_dimDates[Date])>_Daily,
			    SWITCH(SELECTEDVALUE(OrderVSExecutionVSSupply[ID]),
			        1,CALCULATE([Total Quantity]+0,FILTER(Sub_dimDates,Sub_dimDates[Date]<=_today &&Sub_dimDates[Date]>_Daily)),
			        2,CALCULATE([Total Quantity Supply Date]+0,USERELATIONSHIP(Sub_dimDates[Date],factOrders[תאריך אספקה]),FILTER(Sub_dimDates,Sub_dimDates[Date]<=_today &&Sub_dimDates[Date]>_Daily)),BLANK()
			        )
			    ),
			1,IF(MAX(Sub_dimDates[Date])<=_thisMonth && MIN(Sub_dimDates[Date])>_WeeklyFull,
			    SWITCH(SELECTEDVALUE(OrderVSExecutionVSSupply[ID]),
			        1,CALCULATE([Total Quantity]+0,FILTER(Sub_dimDates,Sub_dimDates[Date]<=_today &&Sub_dimDates[Date]>_WeeklyFull)),
			        2,CALCULATE([Total Quantity Supply Date]+0,USERELATIONSHIP(Sub_dimDates[Date],factOrders[תאריך אספקה]),FILTER(Sub_dimDates,Sub_dimDates[Date]<=_today &&Sub_dimDates[Date]>_WeeklyFull)),BLANK()
			        )
			    ),
			2,IF(MAX(Sub_dimDates[Date])<=_thisMonth && MIN(Sub_dimDates[Date])>_Monthly,
			    SWITCH(SELECTEDVALUE(OrderVSExecutionVSSupply[ID]),
			        1,CALCULATE([Total Quantity]+0,FILTER(Sub_dimDates,Sub_dimDates[Date]<=_today &&Sub_dimDates[Date]>_Monthly)),
			        2,CALCULATE([Total Quantity Supply Date]+0,USERELATIONSHIP(Sub_dimDates[Date],factOrders[תאריך אספקה]),FILTER(Sub_dimDates,Sub_dimDates[Date]<=_today &&Sub_dimDates[Date]>_Monthly)),BLANK()
			        )
			    )
			)
			
			```
