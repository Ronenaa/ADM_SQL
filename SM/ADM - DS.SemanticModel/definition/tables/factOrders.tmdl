ELSE NULL#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)END#(lf)#(tab)#(tab)#(tab)WHEN t.PO_Family = 1#(lf)#(tab)#(tab)#(tab)#(tab)Then POB.Balance#(lf)#(tab)#(tab)#(tab)ELSE  POB.Balance#(lf)#(tab)#(tab)END AS FlatQTY#(lf)#(tab)#(tab)--,bc.TotalContracts as ContractSigned#(lf)#(tab)#(tab),POL_StockExchangeDate#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(lf)#(tab)#(tab),sf.PF_GeneralFactor#(lf)#(tab)#(tab),POL_PremiumPrice#(lf)#(tab)#(tab),POL_StockMarketPrice#(lf)#(tab)#(tab),smp.SMP_Symbol#(lf)#(tab)#(tab),CAST (smpe.SMPE_TempPrice as float) as SMPE_TempPrice#(lf)#(tab)#(tab),ACT.TAOR_AOPTSIH as OrderType#(lf)#(tab)#(tab),POL.POL_StockMarketTempPriceForNoneClosed as MarketTempPrice#(lf)#(tab)#(tab),POL_FinalPriceForClosedContract#(tab)#(tab)#(tab)as FinalPriceClosedContract#(lf)#(lf)#(tab)#(tab),OP.CFFlat#(lf)#(tab)#(tab),OP.CFFLAT_CC#(lf)#(tab)#(tab),OP.CFFLAT_NCC#(lf)#(tab)#(tab),OP.FotPrice#(lf)#(tab)#(tab),OP.FOT_CC#(lf)#(tab)#(tab),OP.FOT_NCC#(lf)#(tab)#(tab),OP.OriginalQty#(lf)#(tab)#(tab),OP.DollarRate#(lf)#(tab)#(tab),POL.POL_StockMarketTempPriceForNoneClosed#(lf)#(tab)#(tab),GETDATE() AS RowInsertDatetime#(lf)FROM [HZMNOT] HZ#(lf)LEFT JOIN (#(lf)           SELECT *, #(lf)                    CASE#(lf)                    #(tab)WHEN sher = 0#(lf)                    #(tab)THEN FIRST_VALUE(sher) OVER (PARTITION BY value_partition ORDER BY Tarikh) #(lf)                    #(tab)ELSE sher#(lf)                    END AS new_sher#(lf)            FROM (#(lf)                     SELECT *#(lf)#(tab)#(tab)#(tab)#(tab)#(tab) ,SUM(CASE WHEN sher=0 THEN 0 ELSE 1 END) OVER (ORDER BY tarikh ) AS value_partition#(lf)                     FROM SHERI_MTBE) m#(lf)           #(lf)           ) SM #(lf)ON SM.TARIKH=HZ.T_HZMNH#(lf)Left Join OrderPrices OP#(lf)#(tab)ON op.OrderID = Hz.MSPR_HZMNH#(lf)LEFT JOIN PurchaseOrderTypes t#(lf)#(tab)ON t.PO_TypeID = OP.ActionType#(lf)Left Join BasisContract bc#(lf)#(tab)ON op.OrderID = bc.ID#(lf)----#(lf)left join SalesOrder2Purchase sol#(lf)#(tab)on HZ.MSPR_HZMNH = sol.POSO_SOID#(lf)left join PurchaseOrderLines POL#(lf)#(tab)on sol.POSO_POID = pol.POL_OrderID and sol.POSO_POLID = pol.POL_LineID#(lf)left join ProductStockMarketFactors sf#(lf)#(tab)on pol.POL_ProductID = sf.PF_ProductID and POL.POL_FactorCode = sf.PF_FactorID #(lf)left join StockMarketProduct smp#(lf)#(tab)on POL.POL_ProductID = smp.SMP_ProductID AND MONTH(POL.POL_StockExchangeDate) = smp.SMP_MonthID#(lf)left join SMPE as smpe --(select * from SMPE where  rownum = 1) smpe#(lf)#(tab)on POL.POL_ProductID = smpe.SMPE_ProductID AND YEAR(POL.POL_StockExchangeDate) = smpe.SMPE_Year AND MONTH(POL.POL_StockExchangeDate) = smpe.SMPE_Month#(lf)Left Join viewPurchaseOrderBalance POB#(lf)#(tab)ON POL.POL_OrderID = POB.POID AND POL.POL_LineID = POB.POLineID#(lf)LEFT JOIN TBLT_PEOLOT_HZMNH_T_MSHLOCH ACT#(lf)#(tab)ON HZ.actionType = ACT.MS_AOPTSIH#(lf)#(lf)WHERE Cast(SUBSTRING(T_HZMNH,1,4) as int) >=2018 and Cast(SUBSTRING(T_HZMNH,1,4) as int) <= Year(Getdate())#(lf)AND HZ.OrderStatus<>3#(lf)AND HZ.ActionType IN (1,11,12,14)--NOT IN (2,6,7,10/*,11*/)#(lf)#(lf)--AND HZ.MSPR_HZMNH IN ('139761')--,'136892','136030','136532','137242', '135805')--'135671'-- '136227' --'133900'#(lf)--AND SUBSTRING(HZ.T_ASPQH,1,4) = 2025 AND SUBSTRING(HZ.T_ASPQH,5,2) = 01#(lf))#(lf)#(lf)SELECT#(tab)o.*#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(lf)#(tab)#(tab),CASE #(lf)#(tab)#(tab)#(tab)WHEN o.PremiumFlag = 1 THEN o.FlatQTY * FinalPriceClosedContract#(lf)#(tab)#(tab)#(tab)ELSE LineTotalBalanceUSD#(lf)#(tab)#(tab) END#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS LineTotalFlatBalanceUSD#(lf)#(tab)#(tab),CASE #(lf)#(tab)#(tab)#(tab)WHEN o.PremiumFlag = 1 THEN o.FlatQTY * FinalPriceClosedContract#(lf)#(tab)#(tab)#(tab)ELSE LineTotalNetUSD#(lf)#(tab)#(tab) END#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS LineTotalFlatUSD#(lf)#(tab)#(tab),CASE #(lf)#(tab)#(tab)#(tab)WHEN o.PremiumFlag = 1 THEN o.BasisQTY * MarketTempPrice#(lf)#(tab)#(tab)#(tab)ELSE 0#(lf)#(tab)#(tab) END#(lf)#(tab)#(tab) +#(lf)#(tab)#(tab)CASE #(lf)#(tab)#(tab)#(tab)WHEN o.PremiumFlag = 1 THEN o.FlatQTY * FinalPriceClosedContract#(lf)#(tab)#(tab)#(tab)ELSE LineTotalNetUSD#(lf)#(tab)#(tab) END#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS LineTotalFlatValueUSD#(lf)#(lf)    ,CASE #(lf)        WHEN o.PremiumFlag = 1 THEN o.CFFLAT_CC #(lf)        ELSE o.CFFlat #(lf)    END AS UnitPriceCF,#(lf)    #(lf)    -- Calculate LineTotalCF_USD using PremiumFlag and FlatQTY (or OriginalQty)#(lf)    CASE #(lf)        WHEN o.PremiumFlag = 1 THEN o.CFFLAT_CC * o.FlatQTY #(lf)        ELSE o.CFFlat * o.OriginalQty #(lf)    END AS LineTotalCF_USD,#(lf)    #(lf)    -- Calculate LineTotalCF_NIS (apply DollarRate to the above)#(lf)    CASE #(lf)        WHEN o.PremiumFlag = 1 THEN o.CFFLAT_CC * o.FlatQTY * o.DollarRate #(lf)        ELSE o.CFFlat * o.DollarRate * o.OriginalQty #(lf)    END AS LineTotalCF_NIS,#(lf)    #(lf)    -- Calculate UnitPriceFOT based on the PremiumFlag#(lf)    CASE #(lf)        WHEN o.PremiumFlag = 1 THEN o.FOT_CC #(lf)        ELSE o.FotPrice #(lf)    END AS UnitPriceFOT,#(lf)    #(lf)    -- Calculate LineTotalFOT_USD using PremiumFlag and FlatQTY (or OriginalQty)#(lf)    CASE #(lf)        WHEN o.PremiumFlag = 1 THEN o.FOT_CC * o.FlatQTY #(lf)        ELSE o.FotPrice * o.OriginalQty #(lf)    END AS LineTotalFOT_USD,#(lf)    #(lf)    -- Calculate LineTotalFOT_NIS (apply DollarRate to the above)#(lf)    CASE #(lf)        WHEN o.PremiumFlag = 1 THEN o.FOT_CC * o.FlatQTY * o.DollarRate #(lf)        ELSE o.FotPrice * o.DollarRate * o.OriginalQty #(lf)    END AS LineTotalFOT_NIS,#(lf)    #(lf)    -- Use BasisQTY to compute the flat value balance in USD#(lf)    CASE#(lf)#(tab)#(tab)WHEN o.PremiumFlag = 1 THEN (o.POL_StockMarketTempPriceForNoneClosed * o.BasisQTY)+(o.FlatQTY * FinalPriceClosedContract) #(lf)#(tab)#(tab)ELSE LineTotalBalanceUSD#(lf)#(tab)#(tab)END AS LineTotalFlatValueBalanceUSD,#(lf)    #(lf)    -- Calculate MarketTempPriceCFF_USD and its related total using BasisQTY#(lf)    CASE #(lf)        WHEN o.PremiumFlag = 1 THEN o.CFFLAT_NCC #(lf)        ELSE NULL #(lf)    END AS MarketTempPriceCFF_USD,#(lf)    #(lf)    CASE #(lf)        WHEN o.PremiumFlag = 1 THEN (o.CFFLAT_NCC * o.BasisQTY) + (o.FlatQTY * o.CFFLAT_NCC)#(lf)        ELSE QuantityLeft*o.CFFlat #(lf)    END AS LineTotalFlatValueBalanceCFFUSD,#(lf)#(tab)CASE #(lf)        WHEN o.PremiumFlag = 1 THEN (o.FlatQTY * o.CFFLAT_NCC)#(lf)        ELSE QuantityLeft*o.CFFlat #(lf)    END AS LineTotalFlatBalanceCFFUSD,#(lf)    #(lf)    -- Calculate MarketTempPriceFOT_USD and its related total using BasisQTY#(lf)    CASE #(lf)        WHEN o.PremiumFlag = 1 THEN o.FOT_NCC #(lf)        ELSE NULL #(lf)    END AS MarketTempPriceFOT_USD,#(lf)    #(lf)    CASE #(lf)        WHEN o.PremiumFlag = 1 THEN  (o.FOT_NCC * o.BasisQTY) + (o.FlatQTY * o.FOT_NCC)--(o.FOT_NCC * o.BasisQTY)--#(lf)        ELSE QuantityLeft*o.FotPrice #(lf)    END AS LineTotalFlatValueBalanceFOTUSD,#(lf)    CASE #(lf)        WHEN o.PremiumFlag = 1 THEN (o.FOT_NCC * o.FlatQTY)#(lf)        ELSE QuantityLeft*o.FotPrice #(lf)    END AS LineTotalFlatBalanceFOTUSD,#(lf)#(lf)    CASE #(lf)        WHEN o.PremiumFlag = 1 #(lf)             THEN (o.CFFLAT_NCC * o.BasisQTY) + (o.CFFLAT_CC * o.FlatQTY)#(lf)        ELSE (o.CFFlat * o.OriginalQty)#(lf)    END AS LineTotalFlatValueCFFUSD,#(lf)    #(lf)    -- Combined calculation for FOT pricing#(lf)    CASE #(lf)        WHEN o.PremiumFlag = 1 #(lf)             THEN (o.FOT_NCC * o.BasisQTY) + (o.FOT_CC * o.FlatQTY)#(lf)        ELSE (o.FotPrice * o.OriginalQty)#(lf)    END AS LineTotalFlatValueFOTUSD,#(lf)#(lf)#(tab)CASE#(lf)#(tab)#(tab)WHEN o.[סטטוס] = 1 then 'Open Order'#(lf)#(tab)#(tab)else null#(lf)#(tab)END AS 'Open_Slicer'#(lf)#(lf)/*#(tab)#(tab),CASE#(lf)#(tab)#(tab)#(tab)WHEN o.PremiumFlag = 1 THEN o.LineTotalFlatValueBalanceCFFUSD + LineTotalCF_USD#(lf)#(tab)#(tab)#(tab)ELSE LineTotalCF_USD END#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS LineTotalFlatValueCFFUSD#(lf)#(tab)#(tab),CASE#(lf)#(tab)#(tab)#(tab)WHEN o.PremiumFlag = 1 THEN o.LineTotalFlatValueBalanceFOTUSD + LineTotalCF_USD#(lf)#(tab)#(tab)#(tab)ELSE LineTotalCF_USD END#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS LineTotalFlatValueFOTUSD#(lf)*/#(lf)#(lf)FROM Orders o#(lf)where 1=1#(lf)--and OrderID = 140452#(lf)--and BasisQTY is not null#(lf)--and BasisQTY <>0#(lf)"]),
