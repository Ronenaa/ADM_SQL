	measure 'InactiveCustomer - Switch Flag 90 days vs 90 days ---- %Change' =
			
			VAR ReferenceDate = CALCULATE(MAX(dimDates[Date]),dimDates[IsHistory]=1)
			-- Calculate the total sales over the last 90 days (from the most recent date going back 90 days)
			VAR TotalSalesLast90 =
			    CALCULATE(
			        [InactiveCustomer Measure Switch],--[Total Quantity],
			        DATESINPERIOD(dimDates[Date], ReferenceDate, -90, DAY)
			    )
			-- Calculate the total sales for the 90 days preceding the last 90 days (from ReferenceDate-90 to ReferenceDate-180)
			VAR TotalSalesPrev90 =
			    CALCULATE(
			        [InactiveCustomer Measure Switch],
			        DATESINPERIOD(dimDates[Date], ReferenceDate - 90, -90, DAY)
			    )
			RETURN
			    --IF(TotalSalesLast90 = 0 && TotalSalesPrev90 > 0, 1, 0)
			    DIVIDE(TotalSalesLast90-TotalSalesPrev90,TotalSalesPrev90)
			    --TotalSalesLast90-TotalSalesPrev90
			    --TotalSalesLast90
			    --TotalSalesPrev90
		formatString: 0%;-0%;0%
		lineageTag: 3a9386cb-9a35-49ff-a4aa-025a1d0fa6d4

		changedProperty = IsHidden

	measure 'InactiveCustomer - Orders Supply Date Flag YTD vs LY YTD ---- %change' =
			
			VAR TotalSalesThisYear = [Quantity Supply Date DynamicTable]
			VAR TotalSalesParallelPeriod = [Quantity Supply DynamicTable LY YTD]
			
			RETURN
			    --IF(TotalSalesThisYear = 0 && TotalSalesParallelPeriod > 0, 1, 0)
			    DIVIDE(TotalSalesThisYear-TotalSalesParallelPeriod,TotalSalesParallelPeriod)
			    --TotalSalesThisYear-TotalSalesParallelPeriod
			    --TotalSalesLast90
			    --TotalSalesPrev90
