	measure 'InactiveCustomer - Switch Flag 180 days vs 180 days --- %change' =
			
			VAR ReferenceDate = CALCULATE(MAX(dimDates[Date]),dimDates[IsHistory]=1)
			
			VAR TotalSalesLastPeriod =
			    CALCULATE(
			        [InactiveCustomer Measure Switch],
			        DATESINPERIOD(dimDates[Date], ReferenceDate, -180, DAY)
			    )
			
			VAR TotalSalesPrevParallelPreiod =
			    CALCULATE(
			        [InactiveCustomer Measure Switch],
			        DATESINPERIOD(dimDates[Date], ReferenceDate - 180, -180, DAY)
			    )
			RETURN
			    --IF(TotalSalesLastPeriod  = 0 && TotalSalesPrevParallelPreiod > 0, 1, 0)
			    DIVIDE(TotalSalesLastPeriod-TotalSalesPrevParallelPreiod,TotalSalesPrevParallelPreiod)
			    --TotalSalesLastPeriod-TotalSalesPrevParallelPreiod
			    --TotalSalesLastPeriod
			    --TotalSalesPrevParallelPreiod
