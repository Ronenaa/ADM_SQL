			Var _qty = CALCULATE([Quantity Dynamic Table Switch],FILTER(ALL(Sub_dimDates),Sub_dimDates[Date]<=_date && Sub_dimDates[Date]>=_date3months),REMOVEFILTERS(DimDates))
			
