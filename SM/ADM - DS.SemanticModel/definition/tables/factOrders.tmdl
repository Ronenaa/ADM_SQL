	measure 'Remain Price - Risk Plan' =
			
			VAR LastUpdated=CALCULATE(MAX(factInventory[Date]),ALL(factInventory))
			var StockCostCurrentMonth = CALCULATE(CALCULATE([Inventory Value Switch],factInventory[Date]=LastUpdated),ALL(dimDates))
			var StockQtyCurrentMonth = CALCULATE(CALCULATE([Inventory Balance - Quantity],factInventory[Date]=LastUpdated),ALL(dimDates))
			VAR _MaxDate = MAX(dimDates[Date])
			var _Quantity = CALCULATE(
			    --CALCULATE(SUM(factPurchaseOrder[Quantity]),factPurchaseOrder[IsOpen]="1",USERELATIONSHIP(dimDates[Date],factPurchaseOrder[Supply Date]))
			    CALCULATE(SUM(factPurchaseOrder[Balance]),factPurchaseOrder[IsOpen]="1",USERELATIONSHIP(dimDates[Date],factPurchaseOrder[Supply Date]))
			    ,FILTER(ALL(dimDates),dimDates[Date]<=_MaxDate),USERELATIONSHIP(dimDates[Date],factPurchaseOrder[Supply Date]))
			VAR _Positive = DIVIDE( StockCostCurrentMonth+[All Open Purchase Cost By Supply Date - Risk Plan],StockQtyCurrentMonth+_Quantity,BLANK())
			
			return
			IF([Remain - Risk Plan] >=0 ,_Positive,[AVG Sales Balance Price Flat+FlatValue]--[AVG Sales Price Flat+FlatValue By Supply Date]--[AVG Price Supply Date Switch] --[Avg Unit Price By Supply Date]--
			)
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: Risk Plan
		lineageTag: 03afc911-41b8-496b-8876-5796f4575afa

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

