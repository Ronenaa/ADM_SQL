	measure 'Quantity Orders DynamicTable 2Y' =
			
			VAR _YEAR = CALCULATE(YEAR(MAX(dimDates[date])),dimDates[IsHistory]=1)-2
			RETURN
			CALCULATE([Total Quantity],Sub_DimDates[Year]=_YEAR,DATEADD(dimDates[Date],-2,YEAR),DATEADD(Sub_DimDates[Date],-2,YEAR))
			/*
			VAR _YEAR = CALCULATE(YEAR(MAX(dimDates[LastYear])),dimDates[IsHistory]=1)-1
			VAR _Month = Month(MAX(Sub_DimDates[Date]))
			
			RETURN
