	measure 'InactiveCustomer - Orders Supply Date Flag YTD vs LY YTD' =
			
			VAR LastPeriod = [Quantity Supply Date DynamicTable]
			VAR PrevPeriod = [Quantity Supply DynamicTable LY YTD]
			// % decrease from prev to last
			VAR DecreasePct =
			    DIVIDE( PrevPeriod - LastPeriod, PrevPeriod )
			
			// detect the “no data” scenario
			VAR HasData =
			    NOT( ISBLANK( LastPeriod ) || ISBLANK( PrevPeriod ) )
			
			RETURN
			    IF(
			        NOT HasData,
			        BLANK(),                     // no data → blank
			        IF(
			            PrevPeriod > 0
			            && DecreasePct > 0.30,   // drop > 30%
			            1,
			            0
			        )
			    )
			    --IF(TotalSalesThisYear = 0 && TotalSalesParallelPeriod > 0, 1, 0)
			    --DIVIDE(TotalSalesLast90-TotalSalesPrev90,TotalSalesPrev90)
			    --TotalSalesLast90-TotalSalesPrev90
			    --TotalSalesLast90
			    --TotalSalesPrev90
		formatString: 0
		lineageTag: 914f2fdc-3777-4bc2-990e-35e9be4e67d2

		changedProperty = IsHidden

