			CONCATENATE(SELECTEDVALUE('OrderSupplyExecution Parameter'[Value4])," YTD")
		lineageTag: 2c621a9e-d97d-4282-b44f-2f2e3ad1fa19

	measure 'Switch Titles 180' =
			
			CONCATENATE(SELECTEDVALUE('OrderSupplyExecution Parameter'[Value4])," 180")
		lineageTag: 3525da0b-43b1-4474-bb7f-b7a3a0b0e993

	measure 'Switch Titles 90' =
			
			CONCATENATE(SELECTEDVALUE('OrderSupplyExecution Parameter'[Value4])," 90")
		lineageTag: bb03962e-1b14-4f46-b52b-895914fcb1a9

	measure 'Quantity Months Table Switch (Sales Analyzer)' = ```
			
			VAR _MinDate= MIN(Sub_DimDates[Date])
			VAR _CheckBlank = CALCULATE([Total Quantity Supply TO DATE],ALL(dimItemsSimple),Filter(ALL(Sub_DimDates),Sub_DimDates[Date]>=_MinDate))
			// VAR _todate = CALCULATE(MAX(dimDates[Date]),FILTER(ALL(dimDates),dimDates[IsHistory]=1))
			VAR _Maxdate = CALCULATE(MAX(dimDates[Date]),dimDates[IsHistory]=1)
			VAR _SubMaxdate = MAX(Sub_DimDates[Date])
			VAR _date = IF(_Maxdate<=_SubMaxdate,_Maxdate,_SubMaxdate)
			VAR _Orders = CALCULATE([Quantity Orders DynamicTable],FILTER(dimDates,dimDates[Date]<=_date))
			
			
			Var _Supply =
			CALCULATE(CALCULATE([Total Quantity]
			                  ,FILTER(dimDates,dimDates[Date]<=_date)
			                  ,USERELATIONSHIP(Sub_DimDates[Date],factOrders[תאריך אספקה])
			                  )
			        ,dimDates[IsHistory]=1)
			VAR _Execute = CALCULATE([Quantity Execution DynamicTable],FILTER(dimDates,dimDates[Date]<=_date)) --[Quantity Execution DynamicTable]
			VAR _Measure = 
			SWITCH(MIN('OrderSupplyExecution Parameter'[OrderSupplyExecution Parameter Order]),
			1,IF(ISBLANK(_Orders),"-",_Orders),
			2,IF(ISBLANK(_Supply),"-",_Supply),
			3,IF(ISBLANK(_Execute),"-",_Execute),
			IF(ISBLANK(_Orders),"-",_Orders)
			)
			
			
			Return
			IF(ISBLANK(_CheckBlank),BLANK(),_Measure)
			```
		displayFolder: Dynamic Table
		lineageTag: d5bd4196-9978-4154-b57d-021af4562f6f

		formatStringDefinition = "#,##0;-#,##0;-"

	measure 'Sort Measure' =
			VAR sortfield = SELECTEDVALUE ( SortOptions[Sort By], "Open Orders" )
			RETURN
			SWITCH (
			    TRUE (),
			
			    sortfield = "Open Orders",
			    RANKX ( ALL ( dimCustomers[שם לקוח אב] ), [Quantity Dynamic Table Switch Open Orders], , DESC, DENSE ),
			
			    sortfield = "Size",
			    RANKX (
			        ALL ( dimCustomers[שם לקוח אב] ),
			        CALCULATE ( [Qty Num], dimDates[ShowLast2Years] = 1 ),
			        , DESC, DENSE
			    ),
			
			    sortfield = "Order Date",
			    RANKX ( ALL ( dimCustomers[שם לקוח אב] ), [Last Order Date], , DESC, DENSE )
			)
		formatString: 0
		lineageTag: 749622c4-af13-4d4f-8a9a-6748f14a376f

	measure 'Last Order Date' = ```
			
			CALCULATE(
			    MAX(factOrders[Date]),
			    ALLEXCEPT(dimCustomers, dimCustomers[שם לקוח אב])
			)
			
			```
		formatString: General Date
		lineageTag: b42ed131-5d65-4ca0-bf1a-c7103c1a61e3

	measure 'Total Months' =
			
			VAR StartD = DATE ( 2025, 1, 1 )
			VAR EndD = EOMONTH ( TODAY (), 0 )
			RETURN
			    CALCULATE (
			        DISTINCTCOUNT ( 'Sub_DimDates'[YearMonthNumber] ),
			        'Sub_DimDates'[Date] >= StartD,
			        'Sub_DimDates'[Date] <= EndD,
			        REMOVEFILTERS ( 'Sub_DimDates' )
			    )
		formatString: 0
		displayFolder: Sales Qty Target
		lineageTag: 12bcaf32-e2e9-42bc-af04-993a63b8754c

	measure 'Months With Purchases' =
			
			VAR StartD = DATE ( 2025, 1, 1 )
			VAR EndD = EOMONTH ( TODAY (), 0 )
			RETURN
			    CALCULATE (
			        COUNTROWS (
			            FILTER (
			                ADDCOLUMNS (
			                    VALUES ( 'Sub_DimDates'[MonthInCalendarShortName] ),
			                    "@q", CALCULATE ( [Qty Num] )
			                ),
			                [@q] > 0
			            )
			        ),
			        'Sub_DimDates'[Date] >= StartD,
			        'Sub_DimDates'[Date] <= EndD,
			        REMOVEFILTERS ( 'Sub_DimDates' )
			    )
		formatString: 0
		displayFolder: Sales Qty Target
		lineageTag: 048827ef-2329-45e6-9b09-420efd784495

	measure 'TopN Avg' =
			
			VAR N = [Top Months Value]
			VAR StartD = DATE ( 2025, 1, 1 )
			VAR EndD = EOMONTH ( TODAY (), 0 )
			VAR MonthlyQty =
			    CALCULATETABLE (
			        ADDCOLUMNS (
			            VALUES ( 'Sub_DimDates'[MonthInCalendarShortName] ),
			            "@q", CALCULATE ( [Qty Num] )
			        ),
			        'Sub_DimDates'[Date] >= StartD,
			        'Sub_DimDates'[Date] <= EndD,
			        REMOVEFILTERS ( 'Sub_DimDates' )
			    )
			VAR TopMonths =
			    TOPN ( N, MonthlyQty, [@q], DESC, 'Sub_DimDates'[MonthInCalendarShortName], ASC )
			RETURN
			    DIVIDE ( SUMX ( TopMonths, [@q] ), N )
		displayFolder: Sales Qty Target
		lineageTag: 85c6d78b-3d12-4085-9166-7f09b5059d69

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Next Month Qty' =
			
			VAR NextStart = EOMONTH ( TODAY (), 0 ) + 1
			VAR NextEnd = EOMONTH ( TODAY (), 1 )
			RETURN
			    CALCULATE (
			        [Qty Num],
			        'Sub_DimDates'[Date] >= NextStart,
			        'Sub_DimDates'[Date] <= NextEnd,
			        REMOVEFILTERS ( 'Sub_DimDates' )
			    )
		displayFolder: Sales Qty Target
		lineageTag: 9018d972-4cb4-4a91-a71e-17fff549b565

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Norm Avg' =
			
			DIVIDE ( [TopN Avg] * [Months With Purchases], [Total Months] )
		displayFolder: Sales Qty Target
		lineageTag: ab2a3e2e-f0ab-4d7b-bf65-209fe45a6b52

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Gap Next Month vs Norm' = ```
			[Norm Avg] - COALESCE ( [Next Month Qty], 0 ) 
			```
		displayFolder: Sales Qty Target
		lineageTag: dd754fcf-e6e4-4283-80a7-672eafa8e3eb

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Gap Next Month - No Booking' =
			
			VAR nq = [Next Month Qty]
			RETURN
			    IF ( ISBLANK ( nq ) || nq = 0,  [Norm Avg] - 0 , "-" )
		displayFolder: Sales Qty Target
		lineageTag: 0c7a8f89-e98b-4d1d-9e82-04dc83ca10c1

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Qty Num' =
			
			// VAR raw = [Quantity Months Table Switch (Sales Analyzer)]
			// RETURN
			//     IF ( ISBLANK ( raw ), 0, IFERROR ( raw + 0, 0 ) )
			VAR _Orders = [Quantity Orders DynamicTable]
			VAR _Supply =
			    CALCULATE (
			        [Total Quantity],
			        USERELATIONSHIP ( Sub_DimDates[Date], factOrders[תאריך אספקה] )
			    )
			VAR _Execute = [Quantity Execution DynamicTable]
			VAR _Sel = MIN ( 'OrderSupplyExecution Parameter'[OrderSupplyExecution Parameter Order] )
			VAR _Val =
			    SWITCH ( _Sel,
			        1, _Orders,
			        2, _Supply,
			        3, _Execute,
			        _Orders
			    )
			RETURN
			    IF ( ISBLANK ( _Val ), 0, _Val )
		displayFolder: Sales Qty Target
		lineageTag: 47cf039b-27c6-4756-a440-5549492d5949

		annotation PBI_FormatHint = {"isGeneralNumber":true}

