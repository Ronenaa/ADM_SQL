	measure 'Remain Price - Risk Plan Flat' =
			
			VAR LastUpdated=CALCULATE(MAX(factInventory[Date]),ALL(factInventory))
			var StockCostCurrentMonth = CALCULATE(CALCULATE([Inventory Value Switch],factInventory[Date]=LastUpdated),ALL(dimDates))
			var StockQtyCurrentMonth = CALCULATE(CALCULATE([Inventory Balance - Quantity],factInventory[Date]=LastUpdated),ALL(dimDates))
			VAR _MaxDate = MAX(dimDates[Date])
			var _Quantity = CALCULATE(
			    CALCULATE(SUM(factPurchaseOrder[FlatQTY]),factPurchaseOrder[IsOpen]="1",USERELATIONSHIP(dimDates[Date],factPurchaseOrder[Supply Date]))
			    ,FILTER(ALL(dimDates),dimDates[Date]<=_MaxDate),USERELATIONSHIP(dimDates[Date],factPurchaseOrder[Supply Date]))
			VAR _Positive = DIVIDE( StockCostCurrentMonth+[All Open Purchase Cost By Supply Date - Risk Plan Flat],StockQtyCurrentMonth+_Quantity,BLANK())
			
			return
			IF([Remain - Risk Plan Flat] >=0 ,_Positive,[AVG Sales Price Flat - FirstMonth]
			)
		displayFolder: Risk Plan
		lineageTag: f76ec66d-eb85-460a-95a0-6408c41d7a9f

		changedProperty = IsHidden

