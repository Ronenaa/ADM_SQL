	measure 'Avg Price Date Switch FOT' = ```
			
			Var _today = CALCULATE(MAX(dimDates[Date]),dimDates[IsHistory]=1)
			Var _thisMonth = EOMONTH(_today,0)
			VAR _ThisWeek = CALCULATE(MAX(dimDates[WeekEnding]),dimDates[IsHistory]=1)
			Var _Daily = EOMONTH(_today,-2)
			VAR _Weekly = EOMONTH(_today,-7)
			VAR _Monthly = EOMONTH(_today,-9)
			VAR _WeeklyFull = CALCULATE(MAX(dimDates[WeekStart]),FILTER(dimDates,dimDates[Date]=_Weekly))
			RETURN
			
			SWITCH(SELECTEDVALUE('Time Selection'[Time Selection Order]),
			0,SWITCH(SELECTEDVALUE(OrderVSExecutionVSSupply[ID]),
			    1,CALCULATE([Avg FOT Price],FILTER(Sub_dimDates,Sub_dimDates[Date]<=_today &&Sub_dimDates[Date]>_Daily)),
			     2,CALCULATE([Avg FOT Price By Supply Date],USERELATIONSHIP(Sub_dimDates[Date],factOrders[תאריך אספקה]),FILTER(Sub_dimDates,Sub_dimDates[Date]<=_today &&Sub_dimDates[Date]>_Daily))
			    ),
			1,SWITCH(SELECTEDVALUE(OrderVSExecutionVSSupply[ID]),
			    1,CALCULATE([Avg FOT Price],FILTER(Sub_dimDates,Sub_dimDates[Date]<=_today &&Sub_dimDates[Date]>=_WeeklyFull)),
			     2,CALCULATE([Avg FOT Price By Supply Date],USERELATIONSHIP(Sub_dimDates[Date],factOrders[תאריך אספקה]),FILTER(Sub_dimDates,Sub_dimDates[Date]<=_today &&Sub_dimDates[Date]>=_WeeklyFull))
			    ),
			2,SWITCH(SELECTEDVALUE(OrderVSExecutionVSSupply[ID]),
			    1,CALCULATE([Avg FOT Price],FILTER(Sub_dimDates,Sub_dimDates[Date]<=_today &&Sub_dimDates[Date]>_Monthly)),
			    2,CALCULATE([Avg FOT Price By Supply Date],USERELATIONSHIP(Sub_dimDates[Date],factOrders[תאריך אספקה]),FILTER(Sub_dimDates,Sub_dimDates[Date]<=_today &&Sub_dimDates[Date]>_Monthly))
			    )
			)
			
