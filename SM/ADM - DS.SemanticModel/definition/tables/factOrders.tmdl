	measure 'Lazy Customer - Supply Date Last X Month' =
			
			VAR _MonthXParameter = SELECTEDVALUE(LazyCustomerXMonths[LazyCustomerXMonths])
			VAR _MonthYParameter = SELECTEDVALUE(LazyCustomerYMonths[LazyCustomerYMonths])
			VAR _Date = CALCULATE(MAX(dimDates[Date]),ALL(dimDates),dimDates[IsHistory]=1)
			VAR _Ly = DATE(Year(_Date),MONTH(_Date)-_MonthYParameter,DAY(_Date))
			VAR _LastMonth = DATE(Year(_Date),MONTH(_Date),DAY(_Date)-60)
			VAR _OpenOrders = CALCULATE([Total Quantity Supply Date],Filter(ALL(dimDates),dimDates[Date]>_LastMonth))
			VAR _QtyCheck = IF(ISBLANK(CALCULATE([Total Quantity Supply Date],FILTER(ALL(dimDates),dimDates[Date]>_Ly &&dimDates[Date]<=_LastMonth))),0,1)
			VAR _LYCheckTable = CALCULATETABLE(SUMMARIZE(factOrders,dimCustomers[שם לקוח אב],dimDates[MonthInCalendarName],"QtyCheck",_QtyCheck),FILTER(dimDates,dimDates[Date]>_Ly &&dimDates[Date]<=_LastMonth))
			VAR _LYSumTable=SELECTCOLUMNS(
			                FILTER(
			                    SUMMARIZE(_LYCheckTable,dimCustomers[שם לקוח אב],"Sum",SUMX(_LYCheckTable,[QtyCheck]))
			                    ,[Sum]>=_MonthXParameter)
			                ,dimCustomers[שם לקוח אב])
			VAR __CurrentSumTable=SELECTCOLUMNS(
			                                    FILTER(
			                                        SUMMARIZE(factOrders,dimCustomers[שם לקוח אב],"Sum",_OpenOrders)
			                                    ,_OpenOrders = BLANK())
			                                ,dimCustomers[שם לקוח אב])
			
			VAR _Count = COUNTROWS(INTERSECT(_LYSumTable,__CurrentSumTable))
			
			RETURN
			_Count
		formatString: 0
		lineageTag: b2ce2916-755e-43b9-ae64-6f8f2009a230

		changedProperty = IsHidden

	measure 'Total Quantity Supply TO DATE' =
			
