	measure 'Stock calculated' = ```
			
			VAR LastUpdated=CALCULATE(MAX(factInventory[Date]),ALL(factInventory))
			var StockCurrentMonth = CALCULATE(CALCULATE(SUM(factInventory[Quantity]),factInventory[Date]=LastUpdated),ALL(dimDates))
			var AllOpenPrevMonth = CALCULATE([All Open Orders By Supply Date - Risk Plan],DATEADD(dimDates[Date],-1,MONTH))
			VAR AllOpenPurchasePrevMonth = CALCULATE([All Open Purchase By Supply Date - Risk Plan],DATEADD(dimDates[Date],-1,MONTH))
			
			return 
			StockCurrentMonth+AllOpenPurchasePrevMonth-AllOpenPrevMonth
