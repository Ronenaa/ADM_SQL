	measure 'Lazy Customer - Supply Date' =
			
			[Lazy Customer - Supply Date Last X Month] + [Lazy Customer - Supply Date Last Year]
		formatString: 0
		lineageTag: 0e5a12e8-efea-4023-829a-6df83596995c

		changedProperty = IsHidden

	measure 'Lazy Customer - Execution Last X Month' =
			
			VAR _MonthXParameter = SELECTEDVALUE(LazyCustomerExecutionXMonths[LazyCustomerExecutionXMonths])
			VAR _MonthYParameter = SELECTEDVALUE(LazyCustomerExecutionYMonths[LazyCustomerExecutionYMonths])
			VAR _Date = CALCULATE(MAX(dimDates[Date]),ALL(dimDates),dimDates[IsHistory]=1)
			VAR _Ly = DATE(Year(_Date),MONTH(_Date)-_MonthYParameter,DAY(_Date))
			VAR _LastMonth = DATE(Year(_Date),MONTH(_Date),DAY(_Date)-60)
			VAR _OpenOrdersExecution = CALCULATE([Total Quantity (Sales)],Filter(ALL(dimDates),dimDates[Date]>_LastMonth))
			VAR _QtyExecution = CALCULATE([Total Quantity (Sales)],FILTER(ALL(dimDates),dimDates[Date]>_Ly &&dimDates[Date]<=_LastMonth))
			VAR _OpenOrders = CALCULATE([Total Quantity],Filter(ALL(dimDates),dimDates[Date]>_LastMonth))
			VAR _QtyOrders = CALCULATE([Total Quantity],FILTER(ALL(dimDates),dimDates[Date]>_Ly &&dimDates[Date]<=_LastMonth))
			VAR _QtyCheck = IF(ISBLANK(_QtyExecution) && ISBLANK(_QtyOrders),0,1)
			VAR _LYCheckTable = CALCULATETABLE(SUMMARIZE(CROSSJOIN(dimCustomers,dimDates),dimCustomers[שם לקוח אב],dimDates[MonthInCalendarName],"QtyCheck",_QtyCheck),FILTER(dimDates,dimDates[Date]>_Ly &&dimDates[Date]<=_LastMonth))
			VAR _LYSumTable=SELECTCOLUMNS(
			                FILTER(
			                    SUMMARIZE(_LYCheckTable,dimCustomers[שם לקוח אב],"Sum",SUMX(_LYCheckTable,[QtyCheck]))
			                    ,[Sum]>=_MonthXParameter)
			                ,dimCustomers[שם לקוח אב])
			VAR __CurrentSumTable=SELECTCOLUMNS(
			                                    FILTER(
			                                        SUMMARIZE(dimCustomers,dimCustomers[שם לקוח אב],"SumOpenOrder",_OpenOrders+_OpenOrdersExecution)
			                                    ,[SumOpenOrder] = BLANK())
			                                ,dimCustomers[שם לקוח אב])
			
			VAR _Count = COUNTROWS(INTERSECT(_LYSumTable,__CurrentSumTable))
			
			RETURN
			_Count
		formatString: 0
		lineageTag: fbe9e845-fe42-4197-a11a-aa782b62fd8b

		changedProperty = IsHidden

	measure 'Lazy Customer - Execution' =
			
			[Lazy Customer - Execution Last X Month]
