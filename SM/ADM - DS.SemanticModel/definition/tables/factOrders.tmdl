	measure 'Good Customer - Supply Date - 6 Out 12' = ```
			
			VAR _Date = CALCULATE(MAX(dimDates[Date]),ALL(dimDates),dimDates[IsHistory]=1)
			VAR _EOdate = EOMONTH(_Date,0)
			VAR _L12M = CALCULATE(
			            CALCULATE(MAX(dimDates[FirstDayOfMonth])  
			                        ,DATEADD(dimDates[Date],-12,MONTH)
			                     )
			                    ,dimDates[IsHistory]=1
			                    )
			--EDATE(_EOdate, -6)
			VAR _Months =
			    CALCULATETABLE(
			        VALUES(dimDates[FirstDayOfMonth]),
			        dimDates[FirstDayOfMonth] >= _L12M,
			        dimDates[FirstDayOfMonth] <= _EOdate,
			        dimDates[IsHistory] = 1
			    )
			VAR _ActiveMonthCount =
			    SUMX(
			        _Months,
			        // For each month from the _Months table, use the column name [FirstDayOfMonth] as the current month.
			        VAR CurrentMonth = [FirstDayOfMonth]
			        VAR _StartOfMonth = CurrentMonth
			        VAR _EndOfMonth = EOMONTH(CurrentMonth, 0)
			        VAR Qty =
			            CALCULATE(
			                [Total Quantity Supply Date_v1],
			                ALL(dimDates),
			                dimDates[Date] >= _StartOfMonth,
			                dimDates[Date] <= _EndOfMonth
			            )
			        RETURN IF(NOT(ISBLANK(Qty)) && Qty <> 0, 1, 0)
			    )
			RETURN
			        IF(_ActiveMonthCount >=6, 1, 0)
			```
		formatString: 0
		lineageTag: d20b4b1d-4e51-4676-8b69-b34ab430c1d3

		changedProperty = IsHidden

	measure 'Good Customer - Avg Quantity Last 12 Months' =
			
			VAR _Date =
			    CALCULATE(
			        MAX(dimDates[Date]),
			        ALL(dimDates),
			        dimDates[IsHistory] = 1
			    )
			VAR SumQty12 =
			    CALCULATE(
			        [Total Quantity Supply Date_v1],
			        -- Use DATESINPERIOD to restrict to the last 12 months,
			        -- anchored by the current max date in your context.
			        DATESINPERIOD(
			            dimDates[Date],
			            _Date,
			            -12,
			            MONTH
			        )
			    )
			VAR ActiveMonthCount12 =
			    CALCULATE(
			        DISTINCTCOUNT(dimDates[FirstDayOfMonth]),
			        -- Same 12-month window
			        DATESINPERIOD(
			            dimDates[Date],
			            _Date,
			            -12,
			            MONTH
			        ),
			        -- Keep only months where quantity is > 0
			        -- (or you can use [Total Quantity Supply Date_v1] <> BLANK)
			        KEEPFILTERS(
			            FILTER(
			                ALL(dimDates),
			                [Total Quantity Supply Date_v1] > 0
			            )
			        )
			    )
			RETURN
			    DIVIDE(SumQty12, ActiveMonthCount12)
		formatString: #,0
		lineageTag: 5ddaf5ce-0f01-4ad5-a743-10ad73cf898a

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'Good Customer - Supply Date' =
			
			Var _4out9 = [Good Customer - Supply Date - 6 Out 12]
			Var _3Out6 = [Good Customer - Supply Date - 3 Out 6]
			Var _date = CALCULATE(MAX(dimDates[Date]),dimDates[IsHistory]=1)
			Var _OpenOrder = [Open Orders Quantity By Supply Date]
			Var _MonthlyAVG = [Good Customer - Avg Quantity Last 12 Months]
			
			RETURN
			SWITCH(TRUE(),
			ISBLANK(_OpenOrder),
			    _3Out6+_4out9,
			_OpenOrder<=_MonthlyAVG*1.5,
			        _3Out6 + _4out9,
			BLANK()
			)
		formatString: 0
		lineageTag: 0cdeeb6d-88a1-4f8b-9fe7-d6a2f78a7e09

		changedProperty = IsHidden

	measure 'Good Customer - 3Months Forecast' =
			
			VAR _Date =
			    CALCULATE(
			        MAX(dimDates[Date]),
			        ALL(dimDates),
			        dimDates[IsHistory] = 1
			    )
			VAR _CurrMonth =
			    DATE( YEAR(_Date), MONTH(_Date), 1 )
			
			// Your 12‑month average, cleared of Sub_dimDates filters
			VAR _Avg12 =
			    CALCULATE(
			        [Good Customer - Avg Quantity Last 12 Months],
			        ALL(Sub_dimDates)
			    )
			
			// The month of the current cell in the matrix
			VAR _CellMonth =
			    MAX( Sub_dimDates[FirstDayOfMonth] )
			
			// Quantity in that cell’s month
			VAR _CellQty =
			    CALCULATE(
			        [Total Quantity Supply Date_v1],
			        ALL(dimDates),
			        dimDates[Date] >= _CellMonth,
			        dimDates[Date] <= EOMONTH(_CellMonth, 0)
			    )
			
			// Offset in months between the real current month and the cell’s month
			VAR _Offset =
			    DATEDIFF( _CurrMonth, _CellMonth, MONTH )
			
			RETURN
			SWITCH(
			    TRUE(),
			    // Three months before current: actual quantity (even if zero)
			    _Offset = -3,  _CellQty,
			    _Offset = -2,  _CellQty,
			    _Offset = -1,  _CellQty,
			
			    // Current month: actual if >0, otherwise average
			    _Offset = 0 && _CellQty > 0,  _CellQty,
			    _Offset = 0,                   _Avg12,
			
			    // Next month or the month after: average
			    _Offset = 1 || _Offset = 2,   _Avg12,
			
			    // All other months: blank
			    BLANK()
			)
		formatString: 0
		lineageTag: 504bc8a4-a72e-4a8b-a57e-6e6effb51e0d

		changedProperty = IsHidden

	measure 'Good Customer - Quantity Supply Table' =
			
			VAR _Date =
			    CALCULATE(
			        MAX(dimDates[Date]),
			        ALL(dimDates),
			        dimDates[IsHistory] = 1
			    )
			VAR _CurrMonth =
			    DATE( YEAR(_Date), MONTH(_Date), 1 )
			
			// Your 12‑month average, cleared of Sub_dimDates filters
			VAR _Avg12 =
			    CALCULATE(
			        [Good Customer - Avg Quantity Last 12 Months],
			        ALL(Sub_dimDates)
			    )
			
			// The month of the current cell in the matrix
			VAR _CellMonth =
			    MAX( Sub_dimDates[FirstDayOfMonth] )
			
			// Quantity in that cell’s month
			VAR _CellQty =
			    CALCULATE(
			        [Total Quantity Supply Date_v1],
			        ALL(dimDates),
			        ALL(Sub_DimDates),
			        dimDates[Date] >= _CellMonth,
			        dimDates[Date] <= EOMONTH(_CellMonth, 0)
			    )
			
			// Offset in months between the real current month and the cell’s month
			VAR _Offset =
			    DATEDIFF( _CurrMonth, _CellMonth, MONTH )
			
			RETURN
			IF(
			    // Check if we are in the context of a specific month; if so, run our SWITCH logic
			    ISINSCOPE(Sub_DimDates[MonthInCalendarName]),
			    SWITCH(
			        TRUE(),
			        _Offset = -2, _CellQty,
			        _Offset = -1, _CellQty,
			        _Offset =  0, _CellQty,
			        _Offset =  1, _CellQty,
			        _Offset =  2, _CellQty,
			        BLANK()  // For any other cases, return BLANK
			    ),
			    // Otherwise (total column), return the average for the past 12 months
			    _Avg12
			)
		lineageTag: e2ce185b-325d-4f73-84bd-238d079b1388

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Recomended Supply Date' =
			
			VAR _maxDate = MAX(factOrders[תאריך אספקה])
			VAR _RecomendedMonth = DATE(YEAR(_maxDate),MONTH(_maxDate)+1,1)
			VAR _currentMonth = DATE(YEAR(TODAY()), MONTH(TODAY()), 1)
			VAR _dateToShow = IF(_maxDate < _currentMonth, _currentMonth, _RecomendedMonth)
			RETURN
			    FORMAT(_dateToShow, "MMM yy")
		lineageTag: 79ab5330-ca0b-4e92-a796-0c7f4642b857

