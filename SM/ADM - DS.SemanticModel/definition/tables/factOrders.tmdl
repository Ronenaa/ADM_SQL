	partition factOrders = m
		mode: import
		queryGroup: 'fact Tables'
		source =
				let
				    Source = Sql.Database(#"SQL Address", "MT", [Query="------ active in prod 21-1-25#(lf)-------------- מחירון יומי להשוואה-----------------#(lf)With LastCreation as (#(lf)Select OrderId,MAX(CreateDate) AS LastCreation#(lf)From tblOrderPriceS#(lf)Group By OrderID#(lf))#(lf)#(lf),LastVersion as (#(lf)Select o.OrderId,Max(DayVersion) as LastVersion#(lf)From tblOrderPriceS o#(lf)Inner Join LastCreation LC#(lf)#(tab)ON o.OrderID=LC.OrderID AND o.CreateDate=LC.LastCreation#(lf)Group By o.OrderID#(lf))#(lf)#(lf),OrderPrices as (#(lf)Select O.*#(lf)from tblOrderPriceS o#(lf)Inner Join LastCreation LC#(lf)#(tab)ON o.OrderID=LC.OrderID And o.CreateDate=LC.LastCreation#(lf)Inner Join LastVersion LV#(lf)#(tab)ON o.OrderID=LV.OrderID AND o.DayVersion = LV.LastVersion#(lf)Where 1=1#(lf)),#(lf)#(lf)BasisContract as (#(lf)Select a.POSO_SOID as ID,#(lf)ISNULL(SUM(b.TotalSuccessfullyClosed),0) as TotalContracts#(lf)FRom [dbo].[SaleOrder2PurchaseOrderLines] a#(lf)LEFT JOIN [dbo].[viewStockExchangeOrders] b#(lf)#(tab)ON a.POSO_POID = b.SEO_PurchaseOrderID AND a.POSO_POLID = b.SEO_PurchaseOrderLine#(lf)Where 1=1#(lf)and POSO_isActive = 1#(lf)and LEFT(POSO_POID,1) = 9#(lf)Group BY a.POSO_SOID#(lf))#(lf)#(lf),SMPE_1 as (#(lf)select * #(lf),ROW_NUMBER() OVER (PARTITION BY SMPE_ProductID,SMPE_Year,SMPE_Month ORDER BY SMPE_CreateDate DESC,SMPE_DueDate DESC) as rownum#(lf)from [dbo].[StockMarketProductEOM]#(lf))#(lf)#(lf),SMPE as (#(lf)select * from SMPE_1 where  rownum = 1#(lf))#(lf)#(lf),SalesOrder2Purchase as (#(lf)select * from [dbo].[SaleOrder2PurchaseOrderLines]#(lf)where POSO_IsActive = '1'#(lf)--and POSO_SOID = 128444 --131989#(lf)and POSO_HasRolloverBeenMade = 0#(lf)and LEFT(POSO_POID,2) = 90   ---- Temp Order Only#(lf))#(lf)#(lf)#(lf)#(lf)--------------------הזמנות------------------#(lf),Orders as (#(lf)SELECT #(lf)#(lf)'1' as 'EntityID'#(lf)        ,CAST(HZ.MSPR_HZMNH AS VARCHAR) AS 'OrderID'#(lf)#(tab)#(tab),1 AS 'OrderLineNumber'#(lf)#(tab)#(tab),'Orders' AS 'DocName'#(lf)#(tab)#(tab),CAST(CONVERT(INT, CONVERT(VARCHAR,HZ.QOD_MQBL))as varchar) AS 'AccountKey' -- customer from invoices in case you need just invoices #(lf)#(tab)#(tab),SUBSTRING(HZ.T_ASPQH,1,4) + '-' + SUBSTRING(HZ.T_ASPQH,5,2) + '-' + SUBSTRING(HZ.T_ASPQH,7,2) as 'תאריך אספקה'#(lf)        ,SUBSTRING(HZ.T_HZMNH,1,4) + '-' + SUBSTRING(HZ.T_HZMNH,5,2) + '-' + SUBSTRING(HZ.T_HZMNH,7,2) as 'Date'#(lf)#(tab)#(tab),null AS 'Time'#(lf)#(tab)#(tab),cast(CONVERT(INT, CONVERT(VARCHAR,HZ.AISH_MCIROT)) as varchar) AS 'AgentKey' #(lf)#(tab)#(tab),cast(CONVERT(INT, CONVERT(VARCHAR,HZ.MOTSR_MOZMN)) as varchar)+ '-' + cast(CONVERT(INT, CONVERT(VARCHAR,HZ.MOTSR_MOZMN)) as varchar) AS 'ItemKey'#(lf)#(tab)#(tab)--,CAST('1' as varchar) + CAST(CONVERT(INT, CONVERT(VARCHAR, i.BRANCH)) as varchar) AS 'BranchKey'#(lf)#(tab)#(tab),null AS 'EmployeeKey'#(lf)#(tab)#(tab),null AS 'חבר מועדון'#(lf)#(tab)#(tab)--,(1 - (1 - ii.[T$PERCENT] / 100) * (1 - i.[T$PERCENT] / 100)) AS 'DiscountPercent' -- the DiscountPercent for the invoice and invoice line#(lf)#(tab)#(tab),null AS 'DiscountPercent'#(lf)#(tab)#(tab) --,(1 - (1 - ii.[T$PERCENT] / 100) * (1 - i.[T$PERCENT] / 100)) * ii.TQUANT / 1000 * ROUND(ii.PRICE, 2) * ii.IEXCHANGE AS 'LineTotalDiscount' -- the discount from gross price to the net#(lf)#(tab)#(tab),NULL AS 'LineTotalDiscount'#(lf)#(tab)#(tab)--,ROUND(ii.PRICE, 2) * ii.IEXCHANGE AS 'UnitGrossPrice'#(lf)#(tab)#(tab),NULL AS 'UnitGrossPrice'#(lf)#(tab)#(tab)--,ROUND(ii.PRICE * (1 - ii.[T$PERCENT] / 100) * (1 - i.[T$PERCENT] / 100), 2) * ii.IEXCHANGE AS 'UnitNetPrice'#(lf)#(tab)#(tab),CASE#(lf)#(tab)         WHEN HZ.MTBE = '$' THEN MCHIR_ICH#(lf)#(tab)#(tab)   --THEN CAST(HZ.MCHIR_ICH AS decimal (12,4))#(lf)#(tab)         ELSE CAST(HZ.MCHIR_ICH *(1/SM.NEW_SHER)  AS decimal (12,4))#(lf)         END AS 'UnitNetPriceUSD'#(lf)#(tab)#(tab),HZ.CMOT_MOZMNT AS 'Quantity'#(lf)#(tab)#(tab),HZ.CMOT_SHSOPQH AS 'QuantitySupply'#(lf)#(tab)#(tab),HZ.CMOT_MOZMNT - HZ.CMOT_SHSOPQH AS 'QuantityLeft'#(lf)#(tab)#(tab)--The cost can be tor.cost * Quant or just tor.cost#(lf)#(tab)#(tab)--Option 1#(lf)#(tab)#(tab)/*,CASE WHEN tor.COSTFLAG NOT IN ('C', '\0') #(lf)#(tab)#(tab)      THEN tor.COST * (CASE WHEN (tor.QUANT) < 0.0 THEN - 1 ELSE 1 END)#(lf)#(tab)#(tab)      ELSE p.COST * ((ii.QUANT / 1000) / p.COSTQUANT) * (CASE WHEN i.DEBIT = 'C' THEN - 1 ELSE 1 END) * (CASE WHEN ii.CREDITFLAG = 'Y' THEN 0 ELSE 1 END)#(lf)#(tab)#(tab)END AS 'LineTotalCost' --------Cost without Quant#(lf)#(tab)#(tab)*/#(lf)#(tab)#(tab),NULL AS 'LineTotalCost'#(lf)#(tab)#(tab)/*,(CASE WHEN ii.CURRENCY <> '-1'#(lf)#(tab)#(tab)#(tab)THEN round(ii.IVCOST, 2) * ii.IEXCHANGE#(lf)#(tab)#(tab)#(tab)ELSE round(ii.IVCOST, 2) END) * (CASE WHEN (i.DEBIT = 'C') #(tab)THEN - 1 ELSE 1 END) AS 'LineTotalNet'*/#(lf)#(tab)#(tab),CASE#(lf)#(tab)         WHEN HZ.MTBE = '$'#(lf)#(tab)#(tab)     THEN CAST((HZ.MCHIR_ICH)*CMOT_MOZMNT AS decimal (12,4))#(lf)#(tab)         ELSE CAST(HZ.MCHIR_ICH*HZ.CMOT_MOZMNT*(1/SM.NEW_SHER) AS decimal (12,4))#(lf)         END AS 'LineTotalNetUSD'#(lf)#(tab)#(tab),CASE#(lf)#(tab)         WHEN HZ.MTBE = '$'#(lf)#(tab)#(tab)     THEN CAST((HZ.MCHIR_ICH)*(HZ.CMOT_MOZMNT - HZ.CMOT_SHSOPQH) AS decimal (12,4))#(lf)#(tab)         ELSE CAST(HZ.MCHIR_ICH*(HZ.CMOT_MOZMNT - HZ.CMOT_SHSOPQH)*(1/SM.NEW_SHER) AS decimal (12,4))#(lf)         END AS 'LineTotalBalanceUSD'#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(lf)#(tab)#(tab)--, (round(ii.IVCOST, 2)/ii.IEXCHANGE) *fnc.EXCHANGE2   *(CASE WHEN (i.DEBIT = 'C') THEN - 1 ELSE 1 END) AS 'LineTotalNet_USD'#(lf)#(tab)#(tab),CASE#(lf)#(tab)         WHEN HZ.MTBE = '$'#(lf)#(tab)#(tab)     THEN CAST(HZ.MCHIR_ICH*SM.NEW_SHER AS decimal (12,4))#(lf)#(tab)         ELSE CAST(HZ.MCHIR_ICH AS decimal (12,4))#(lf)         END AS 'UnitNetPriceNIS'#(lf)#(tab)    ,CASE#(lf)#(tab)         WHEN HZ.MTBE = '$'#(lf)#(tab)#(tab)     THEN CAST((HZ.MCHIR_ICH*SM.NEW_SHER)*CMOT_MOZMNT AS decimal (12,4))#(lf)#(tab)         ELSE CAST(HZ.MCHIR_ICH*HZ.CMOT_MOZMNT AS decimal (12,4))#(lf)         END AS 'LineTotalNetNIS'#(lf)#(lf)/*#(tab)#(tab) ,CASE#(lf)#(tab)#(tab)#(tab)WHEN ps.OrderID IS NOT NULL THEN OP.CFFLAT_CC#(lf)#(tab)#(tab)#(tab)ELSE OP.CFFlat END#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab) AS 'UnitPriceCF'#(lf)#(tab)#(tab) ,CASE#(lf)#(tab)#(tab)#(tab)WHEN ps.OrderID IS NOT NULL THEN OP.CFFLAT_CC*ps.FlatQTY#(lf)#(tab)#(tab)#(tab)ELSE Op.CFFlat*OP.OriginalQty END#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab) AS 'LineTotalCF_USD'#(lf)#(tab)#(tab) ,CASE#(lf)#(tab)#(tab)#(tab)WHEN ps.OrderID IS NOT NULL THEN OP.CFFLAT_CC*ps.FlatQTY*OP.DollarRate#(lf)#(tab)#(tab)#(tab)ELSE OP.CFFlat*OP.DollarRate*OP.OriginalQty END#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab) AS 'LineTotalCF_NIS'#(lf)#(tab)#(tab) ,CASE#(lf)#(tab)#(tab)#(tab)WHEN ps.OrderID IS NOT NULL THEN OP.FOT_CC#(lf)#(tab)#(tab)#(tab)ELSE OP.FotPrice END#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab) AS 'UnitPriceFOT'#(lf)#(tab)#(tab) ,CASE#(lf)#(tab)#(tab)#(tab)WHEN ps.OrderID IS NOT NULL THEN OP.FOT_CC*ps.FlatQTY#(lf)#(tab)#(tab)#(tab)ELSE Op.FotPrice*OP.OriginalQty END#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab) AS 'LineTotalFOT_USD'#(lf)#(tab)#(tab) ,CASE#(lf)#(tab)#(tab)#(tab)WHEN ps.OrderID IS NOT NULL THEN OP.FOT_CC*ps.FlatQTY*OP.DollarRate#(lf)#(tab)#(tab)#(tab)ELSE OP.FotPrice*OP.DollarRate*OP.OriginalQty END#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab) AS 'LineTotalFOT_NIS'#(lf)#(tab)#(tab) --,OP.CFPremium AS 'UnitPricePremium'#(lf)#(tab)#(tab) --,Op.CFPremium*OP.OriginalQty AS 'LineTotalPremium_USD'#(lf)#(tab)#(tab) --,OP.CFPremium*OP.DollarRate*OP.OriginalQty AS 'LineTotalPremium_NIS'#(lf)#(tab)#(tab) ,POL.POL_StockMarketTempPriceForNoneClosed*ps.BasisQTY#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab) AS 'LineTotalFlatValueBalanceUSD'#(lf)#(tab)#(tab) ,CASE#(lf)#(tab)#(tab)#(tab)WHEN ps.OrderID IS NOT NULL THEN OP.CFFLAT_NCC#(lf)#(tab)#(tab)#(tab)ELSE NULL#(tab)END#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab) AS 'MarketTempPriceCFF_USD'#(lf)#(tab)#(tab) ,CASE#(lf)#(tab)#(tab)#(tab)WHEN ps.OrderID IS NOT NULL THEN OP.CFFLAT_NCC*ps.BasisQTY#(lf)#(tab)#(tab)#(tab)ELSE NULL END#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab) AS 'LineTotalFlatValueBalanceCFFUSD'#(lf)#(tab)#(tab) ,CASE#(lf)#(tab)#(tab)#(tab)WHEN ps.OrderID IS NOT NULL THEN OP.FOT_NCC#(lf)#(tab)#(tab)#(tab)ELSE NULL#(tab)END#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab) AS 'MarketTempPriceFOT_USD'#(lf)#(tab)#(tab) ,CASE#(lf)#(tab)#(tab)#(tab)WHEN ps.OrderID IS NOT NULL THEN OP.FOT_NCC*ps.BasisQTY#(lf)#(tab)#(tab)#(tab)ELSE NULL END#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab) AS 'LineTotalFlatValueBalanceFOTUSD'#(lf)*/#(lf)#(tab)#(tab) ,Case#(lf)#(tab)#(tab)#(tab)WHEN OP.CFPremium >0#(lf)#(tab)#(tab)#(tab)#(tab)THEN 1#(lf)#(tab)#(tab)#(tab)ELSE 0#(lf)#(tab)#(tab)END AS 'PremiumFlag'#(lf)#(tab)#(tab),CONVERT(INT, CONVERT(VARCHAR,SUBSTRING(HZ.T_ASPQH,1,4) + SUBSTRING(HZ.T_ASPQH,5,2))) AS YearMonth#(lf)#(tab)#(tab)----#(lf)#(tab)#(tab),HZ.OrderStatus AS 'סטטוס'#(lf)#(tab)#(tab),NULL AS 'ChargeFlag'  #(lf)#(tab)#(tab),NULL AS 'סטטוס ליקוט כותרת'#(lf)#(tab)    ,NULL AS 'סטטוס ליקוט שורה'#(lf)#(tab)#(tab),NULL AS 'דגל סטורנו'#(lf)#(tab)#(tab)#(lf)#(tab)#(tab),CASE#(lf)#(tab)#(tab)#(tab)WHEN DATEDIFF(dd,#(lf)#(tab)#(tab)#(tab)CAST(SUBSTRING(HZ.T_HZMNH,1,4) + '-' + SUBSTRING(HZ.T_HZMNH,5,2) + '-' + SUBSTRING(HZ.T_HZMNH,7,2) as Date)#(lf)#(tab)#(tab)#(tab),CAST(SUBSTRING(HZ.T_ASPQH,1,4) + '-' + SUBSTRING(HZ.T_ASPQH,5,2) + '-' + SUBSTRING(HZ.T_ASPQH,7,2) AS Date)) > 60#(lf)#(tab)#(tab)#(tab)#(tab)THEN 1#(lf)#(tab)#(tab)#(tab)ELSE 2#(lf)#(tab)#(tab)END as 'Spot