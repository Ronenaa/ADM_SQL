	measure 'Good Customer - Supply Date - 4 Out 9' =
			
			VAR _MonthXParameter = 4
			VAR _MonthYParameter = 9
			VAR _Date = CALCULATE(MAX(dimDates[Date]),ALL(dimDates),dimDates[IsHistory]=1)
			VAR _EOdate = EOMONTH(_Date,0)
			VAR _Ly = DATE(Year(_Date),MONTH(_Date)-9,DAY(_Date))
			VAR _OpenOrders = CALCULATE([Total Quantity Supply Date],Filter(ALL(dimDates),dimDates[Date]>_Date))
			VAR _QtyCheck = IF(ISBLANK(CALCULATE([Total Quantity Supply Date],FILTER(ALL(dimDates),dimDates[Date]>_Ly &&dimDates[Date]<=_EOdate))),0,1)
			VAR _LYCheckTable = CALCULATETABLE(SUMMARIZE(factOrders,dimCustomers[שם לקוח אב],dimDates[MonthInCalendarName],"QtyCheck",_QtyCheck),FILTER(dimDates,dimDates[Date]>_Ly &&dimDates[Date]<=_EOdate))
			VAR _LYSumTable=FILTER(
			                    SUMMARIZE(_LYCheckTable,dimCustomers[שם לקוח אב],"Sum",SUMX(_LYCheckTable,[QtyCheck]))
			                    ,[Sum]>=4)
			
			VAR _Count = COUNTROWS(_LYSumTable)
			
			RETURN
			_Count
		formatString: 0
		lineageTag: ad61f0ad-b2a2-4a62-b1e1-02a32f908925

		changedProperty = IsHidden

	measure 'Good Customer - Supply Date - 3 Out 6' = ```
			
			VAR _Date = CALCULATE(MAX(dimDates[Date]),ALL(dimDates),dimDates[IsHistory]=1)
			VAR _EOdate = EOMONTH(_Date,0)
			VAR _L6M = CALCULATE(
			            CALCULATE(MAX(dimDates[FirstDayOfMonth])  
			                        ,DATEADD(dimDates[Date],-6,MONTH)
			                     )
			                    ,dimDates[IsHistory]=1
			                    )
			--EDATE(_EOdate, -6)
			VAR _Months =
			    CALCULATETABLE(
			        VALUES(dimDates[FirstDayOfMonth]),
			        dimDates[FirstDayOfMonth] >= _L6M,
			        dimDates[FirstDayOfMonth] <= _EOdate,
			        dimDates[IsHistory] = 1
			    )
			VAR _ActiveMonthCount =
			    SUMX(
			        _Months,
			        // For each month from the _Months table, use the column name [FirstDayOfMonth] as the current month.
			        VAR CurrentMonth = [FirstDayOfMonth]
			        VAR _StartOfMonth = CurrentMonth
			        VAR _EndOfMonth = EOMONTH(CurrentMonth, 0)
			        VAR Qty =
			            CALCULATE(
			                [Total Quantity Supply Date_v1],
			                ALL(dimDates),
			                dimDates[Date] >= _StartOfMonth,
			                dimDates[Date] <= _EndOfMonth
			            )
			        RETURN IF(NOT(ISBLANK(Qty)) && Qty <> 0, 1, 0)
			    )
			RETURN
			        IF(_ActiveMonthCount >=3, 1, 0)
			
			/*VAR _L6M = CALCULATE(
			            CALCULATE(MAX(dimDates[FirstDayOfMonth])  
			                        ,DATEADD(dimDates[Date],-6,MONTH)
			                     )
			                    ,dimDates[IsHistory]=1
			                    )
			    --DATE(Year(_Date),MONTH(_Date)-6,DAY(_Date))
			VAR _QtyCheck = IF(ISBLANK(
			                        CALCULATE([Total Quantity Supply Date_v1],FILTER(ALL(dimDates),dimDates[Date]>=_L6M &&dimDates[Date]<=_EOdate))
			                        ),0,1)
			
			RETURN
			_QtyCheck */
			
			/* original measure
			VAR _MonthXParameter = 3
			VAR _MonthYParameter = 6
			VAR _Date = CALCULATE(MAX(dimDates[Date]),ALL(dimDates),dimDates[IsHistory]=1)
			VAR _EOdate = EOMONTH(_Date,0)
			VAR _Ly = DATE(Year(_Date),MONTH(_Date)-6,DAY(_Date))
			VAR _OpenOrders = CALCULATE([Total Quantity Supply Date],Filter(ALL(dimDates),dimDates[Date]>=_Date))
			VAR _QtyCheck = IF(ISBLANK(CALCULATE([Total Quantity Supply Date],FILTER(ALL(dimDates),dimDates[Date]>_Ly &&dimDates[Date]<=_EOdate))),0,1)
			VAR _LYCheckTable = CALCULATETABLE(SUMMARIZE(factOrders,dimCustomers[שם לקוח אב],dimDates[MonthInCalendarName],"QtyCheck",_QtyCheck),FILTER(dimDates,dimDates[Date]>_Ly &&dimDates[Date]<=_EOdate))
			VAR _LYSumTable=FILTER(
			                    SUMMARIZE(_LYCheckTable,dimCustomers[שם לקוח אב],"Sum",SUMX(_LYCheckTable,[QtyCheck]))
			                    ,[Sum]>=3)
			
			VAR _Count = COUNTROWS(_LYSumTable)
			
			RETURN
			_Count*/
			```
		formatString: 0
		lineageTag: 9124a75a-e861-45a9-9cd4-d4d0069b5d49

		changedProperty = IsHidden

	measure 'Good Customer - Supply Date_backup' =
			
			Var _4out9 = [Good Customer - Supply Date - 4 Out 9]
			Var _3Out6 = [Good Customer - Supply Date - 3 Out 6]
			Var _date = CALCULATE(MAX(dimDates[Date]),dimDates[IsHistory]=1)
			Var _OpenOrder = [Open Orders Quantity By Supply Date]
			Var _totalOrderThisYear = CALCULATE([Total Quantity Supply Date],Filter(dimDates,Year(dimDates[Date])=YEAR(_date)))
			Var _totalTransactionThisYear = CALCULATE([Transactions Quantity],USERELATIONSHIP(dimDates[Date],factOrders[תאריך אספקה]),USERELATIONSHIP(Sub_DimDates[Date],factOrders[תאריך אספקה]),Filter(dimDates,Year(dimDates[Date])=YEAR(_date)))
			Var _MonthlyAVG = DIVIDE(_totalOrderThisYear,_totalTransactionThisYear,BLANK())
			
			RETURN
			SWITCH(TRUE(),
			ISBLANK(_OpenOrder),
			    _3Out6+_4out9,
			_OpenOrder<=_MonthlyAVG*1.2,
			        _3Out6 + _4out9,
			BLANK()
			)
		formatString: 0
		lineageTag: ef2ddb2b-3d3f-4d9b-b730-e7412afb575b

		changedProperty = IsHidden

