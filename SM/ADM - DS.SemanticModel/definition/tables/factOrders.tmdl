	measure 'Remain Price - Risk Plan Basis' =
			
			--VAR LastUpdated=CALCULATE(MAX(factInventory[Date]),ALL(factInventory))
			--var StockCostCurrentMonth = CALCULATE(CALCULATE([Inventory Value Switch],factInventory[Date]=LastUpdated),ALL(dimDates))
			--var StockQtyCurrentMonth = CALCULATE(CALCULATE([Inventory Balance - Quantity],factInventory[Date]=LastUpdated),ALL(dimDates))
			VAR _MaxDate = MAX(dimDates[Date])
			var _Quantity = --[All Open Purchase Basis By Supply Date - Risk Plan] - [All Open Orders Basis By Supply Date - Risk Plan]
			CALCULATE(
			    CALCULATE(SUM(factPurchaseOrder[BasisQTY]),factPurchaseOrder[IsOpen]="1",USERELATIONSHIP(dimDates[Date],factPurchaseOrder[Supply Date]))
			    ,FILTER(ALL(dimDates),dimDates[Date]<=_MaxDate),USERELATIONSHIP(dimDates[Date],factPurchaseOrder[Supply Date]))
			VAR _Positive = DIVIDE( [All Open Purchase Cost By Supply Date - Risk Plan Flat Value],_Quantity,BLANK())
			
			return
			IF([Remain - Risk Plan Basis] >=0 ,_Positive,[AVG Price - Risk Plan Basis Flat Value]--[Avg Sales Price Basis Flat Value By Supply Date]
			)
