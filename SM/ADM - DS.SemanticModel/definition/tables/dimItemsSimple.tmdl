ON ALL#(lf)#(lf)#(tab)SELECT  #(lf)#(tab)'1' as 'EntityID'#(lf)#(tab)    ,'0S' AS 'MainItemKey'#(lf)#(tab)#(tab),'כללי' AS 'MainItemName'#(lf)        ,'0-' +CAST(SIM.QOD_SHROT AS VARCHAR)+ 'S'  AS 'ItemKey'#(lf)#(tab)#(tab),SIM.SHM_SHROT  AS 'שם מוצר'#(lf)#(tab)#(tab),SIM.QOD_SHROT AS 'מקט'#(lf)#(tab)#(tab),CAST(SIM.QOD_SHROT AS VARCHAR) +' | ' + SIM.SHM_SHROT AS 'מזהה מוצר'#(lf)#(tab)#(tab),NULL AS 'מוצר על'#(lf)#(tab)    ,'כללי' AS 'שם מוצר על'#(lf)#(tab)#(tab),NULL AS 'יחידת מידה'#(lf)#(tab)#(tab),NULL AS 'מחיר מכירה'#(lf)#(tab)#(tab),'כללי' AS 'סיווג מוצר'#(lf)#(tab)#(tab),'כללי' AS 'קטגוריה'#(lf)#(tab)#(tab),NULL AS 'סטטוס'#(lf)#(tab)#(tab),'כללי' AS 'קבוצת פריט'#(lf)#(tab)#(tab),'' as Product#(lf)#(tab)#(tab),PNL as PNL#(lf)#(tab)#(tab),'' as 'Article'#(lf)#(tab)#(tab) ,'Other' AS 'Article_Description'#(lf)#(tab)#(tab),GETDATE() AS RowInsertDatetime#(lf)#(tab)#(tab),100000000 AS ProductArticleOrder#(lf)#(tab)#(tab),100000000 AS ProductGroupOrder#(lf)FROM HOTSAOT_SHROTIM_New SIM#(lf)  LEFT JOIN (SELECT *#(lf)#(tab)#(tab)#(tab)FROM [dbo].[TRGOM_ANGLIT]#(lf)#(tab)#(tab)#(tab)WHERE SOG_PRIT_SOCN_BNQ_TM_SH_CHBRH = N'פ') T#(lf)#(tab)#(tab)#(tab)ON SIM.QOD_SHROT = T.QOD#(lf)  LEFT JOIN (SELECT distinct [TARO_ANGLIT_2_ART],[ART_DESC]#(lf)#(tab)#(tab)#(tab)FROM [dbo].[TRGOM_ANGLIT]#(lf)#(tab)#(tab)#(tab)WHERE SOG_PRIT_SOCN_BNQ_TM_SH_CHBRH = N'פ' and ART_DESC<>'' and TARO_ANGLIT_3_PNL_HCNSH = 8052) A#(lf)#(tab)#(tab)#(tab)ON A.TARO_ANGLIT_2_ART = T.TARO_ANGLIT_2_ART#(lf))#(lf)#(tab)SELECT STG2_1.*#(lf)#(tab)#(tab)  ,CASE#(lf)#(tab)#(tab)#(tab)WHEN STG2_1.Product is NULL OR STG2_1.Product = ''#(lf)#(tab)#(tab)#(tab)#(tab)THEN 0  #(lf)#(tab)#(tab)#(tab)ELSE Dense_Rank () Over (Order by ProductArticleOrder,Product)  #(lf)#(tab)#(tab)END AS ProductOrder#(lf)#(tab)      ,INV.Balance AS 'Balance'#(lf)#(tab)#(tab)  ,Inv.StockValue#(lf)#(lf)#(tab)#(tab) #(lf)#(tab)FROM STG2_1#(lf)#(tab)#(lf)#(tab)#(lf)#(tab)----2.1#(lf)#(tab)----INVENTORY----#(lf)LEFT JOIN (#(lf)#(tab)#(tab)SEL