	measure MonthforstockselectedPeriod = DISTINCTCOUNT(dimDates[Date])/30
		lineageTag: dafdfb2d-2a7b-40e0-ad5e-51e3c2d1fdb1

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'InventoryBalance - Today' = CALCULATE([Inventory Balance - Quantity],ALL(dimDates))
		lineageTag: bc53fc98-efc2-45ec-ba37-b63102fa50d6

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Inventory Days' =
			
			VAR _Date = CALCULATE(MAX(dimDates[Date]),dimDates[IsHistory]=1)
			VAR _90Days = DATE(YEAR(_Date),MONTH(_Date),DAY(_Date)-90)
			VAR _Inventory = CALCULATE(SUM(factInventory[Quantity]),FILTER(All(dimDates),dimDates[Date]>=_90Days && dimDates[Date]<=_Date))
			VAR _Sales = CALCULATE([Total Quantity OUT],FILTER(All(dimDates),dimDates[Date]>=_90Days && dimDates[Date]<=_Date))
			VAR _Sales_noExchange = CALCULATE([Total Quantity OUT],factInventoryActivity[DocType]<>4,FILTER(All(dimDates),dimDates[Date]>=_90Days && dimDates[Date]<=_Date))
			
			RETURN
			SWITCH(TRUE(),
			HASONEVALUE(dimWarehouses[WarehsKey]),
			DIVIDE(_Inventory,_Sales),
			DIVIDE(_Inventory,_Sales_noExchange)
			)
		lineageTag: 7fc74a2f-48d2-4e76-b533-c5220e38c331

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Inventory Balance - Avg Value' =
			
			var LastUpdated=CALCULATE(MAX(factInventory[Date]),ALL(factInventory))
			return CALCULATE(DIVIDE([Inventory Balance - Value],[Inventory Balance - Quantity],BLANK()),factInventory[Date]=LastUpdated)
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: e28d5217-da1e-459d-bbf4-3c6f1af4ef99

		changedProperty = IsHidden

	measure 'Inventory Balance - Quantity Other' =
			
			VAR _tbl = SELECTCOLUMNS(dimSuppliersCompare,"Supplier",dimSuppliersCompare[Supplier Name],"TotalQty",CALCULATE([Inventory Balance - Quantity]-[Total Allocation Messages QTY],All(dimItemsSimple),REMOVEFILTERS(dimSuppliers)))
			VAR _Above350 = FILTER(SUMMARIZE(_tbl,[Supplier],[TotalQty],"Qty",[Inventory Balance - Quantity]-[Total Allocation Messages QTY]),[TotalQty]>=350)
			VAR _Under350 = FILTER(SUMMARIZE(_tbl,[Supplier],[TotalQty],"Qty",CALCULATE([Inventory Balance - Quantity]-[Total Allocation Messages QTY],REMOVEFILTERS(dimSuppliers))),[TotalQty]<350)
			VAR _UnderOTHER = FILTER(SELECTCOLUMNS(_Under350,"Supplier",[Supplier],"Quantity",CALCULATE(SUMX(_Under350,[Qty]),ALL(dimSuppliersCompare))),[Supplier]="OTHER")
			
			Return
			SWITCH(TRUE(),
			        HASONEVALUE(dimSuppliers[Supplier Name]),
			        SWITCH(MAX(dimSuppliers[Supplier Name]),
			        "Other",SUMX(_UnderOTHER,[Quantity]),
			        SUMX(_Above350,[Qty])
			        ),
			[Inventory Balance - Quantity]-[Total Allocation Messages QTY])
		formatString: " #,#.##;(#,#.##)"
		lineageTag: f395f4e9-5799-4669-9593-35024760fa20

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Inventory Balance - Quantity -' = ```
			
			IF(ISBLANK([Inventory Balance - Quantity]-[Total Allocation Messages QTY]),
			    IF(ISBLANK(CALCULATE([Inventory Balance - Quantity]-[Total Allocation Messages QTY],ALL(dimItemsSimple)))
			        ,Blank(),"-")
			   ,[Inventory Balance - Quantity]-[Total Allocation Messages QTY]
			   )
			   
			```
		formatString: " #,#.##;(#,#.##)"
		lineageTag: 90f3d8f0-c2f0-4d9c-824a-58ccce228ae6

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Inventory Balance - Quantity Other -' = ```
			
			IF(ISBLANK([Inventory Balance - Quantity Other]),
			    IF(ISBLANK(CALCULATE([Inventory Balance - Quantity Other],ALL(dimItemsSimple)))
			        ,Blank(),"-")
			   ,[Inventory Balance - Quantity Other]
