	measure MAXInventoryMonth =
			
			VAR _Tbl = SUMMARIZE(dimDates,dimDates[MonthInCalendarName],"MAXInOut",MAX([Total Quantity IN],[Total Quantity OUT]),"Inventory",[Inventory Balance - Quantity - Monthly])
			
			RETURN
			MAXX(_Tbl,MAX([MAXInOut],[Inventory]))*1.1
		lineageTag: 8b43dcab-d931-4ca1-a7d6-df1904b306fd

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Inventory Balance - Value Other' = ```
			
			VAR _tbl = SELECTCOLUMNS(dimSuppliersCompare,"Supplier",dimSuppliersCompare[Supplier Name],"TotalQty",CALCULATE([Inventory Balance - Quantity],All(dimItemsSimple),REMOVEFILTERS(dimSuppliers)))
			VAR _Above350 = FILTER(SUMMARIZE(_tbl,[Supplier],[TotalQty],"Value", factInventory[Inventory Balance - Value FOT]),[TotalQty]>=350)
			VAR _Under350 = FILTER(SUMMARIZE(_tbl,[Supplier],[TotalQty],"Value", CALCULATE(factInventory[Inventory Balance - Value FOT],REMOVEFILTERS(dimSuppliers))),[TotalQty]<350)
			VAR _UnderOTHER = FILTER(SELECTCOLUMNS(_Under350,"Supplier",[Supplier],"Value",CALCULATE(SUMX(_Under350,[Value]),ALL(dimSuppliersCompare))),[Supplier]="OTHER")
			
			Return
			
			SWITCH(TRUE(),
			HASONEVALUE(dimSuppliers[Supplier Name]),
			    SWITCH(MAX(dimSuppliers[Supplier Name]),
			        "אחר",
			            CALCULATE(SUMX(_UnderOTHER,[Value]),ALL(dimSuppliers)),
			        SUMX(_Above350,[Value])
			    ),
			[Inventory Balance - Value FOT])
			
			```
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: 14f8f22f-c917-419a-a14c-dedcdd7d4fd6

		changedProperty = IsHidden

	measure 'Inventory Balance - Avg Value Other' = ```
			
			
			VAR _tbl = SELECTCOLUMNS(dimSuppliersCompare,"Supplier",dimSuppliersCompare[Supplier Name],"TotalQty",CALCULATE([Inventory Balance - Quantity],All(dimItemsSimple),REMOVEFILTERS(dimSuppliers)))
			VAR _Above350 = FILTER(SUMMARIZE(_tbl,[Supplier],[TotalQty],"Qty",[Inventory Balance - Quantity],"Value", factInventory[Inventory Balance - Value FOT]),[TotalQty]>=350)
			VAR _Under350 = FILTER(SUMMARIZE(_tbl,[Supplier],[TotalQty],"Qty",CALCULATE([Inventory Balance - Quantity],REMOVEFILTERS(dimSuppliers)),"Value", CALCULATE(factInventory[Inventory Balance - Value FOT],REMOVEFILTERS(dimSuppliers))),[TotalQty]<350)
			VAR _UnderOTHER = FILTER(SELECTCOLUMNS(_Under350,"Supplier",[Supplier],"Quantity",CALCULATE(SUMX(_Under350,[Qty]),ALL(dimSuppliersCompare)),"Value",CALCULATE(SUMX(_Under350,[Value]),ALL(dimSuppliersCompare))),[Supplier]="OTHER")
			
			Return
			
			SWITCH(TRUE(),
			HASONEVALUE(dimSuppliers[Supplier Name]),
			    SWITCH(MAX(dimSuppliers[Supplier Name]),
			        "OTHER",
			            DIVIDE(CALCULATE(SUMX(_UnderOTHER,[Value]),ALL(dimSuppliers)),CALCULATE(SUMX(_UnderOTHER,[Quantity]),ALL(dimSuppliers))),
			        DIVIDE(SUMX(_Above350,[Value]),SUMX(_Above350,[QTY]))
			    ),
			[Inventory Balance - Avg Value FOT])
			
			```
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: b2226d8f-be69-407e-a57d-2546354e96ed

		changedProperty = IsHidden

