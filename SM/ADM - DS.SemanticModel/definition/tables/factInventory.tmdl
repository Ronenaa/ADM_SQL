	measure 'ימי מלאי - כולל הזמנות ורכש' = [Inventory Days - Including Purchase and Orders]
		formatString: #,0
		displayFolder: מדדי אחוז
		lineageTag: ff4cf1ba-77b8-4aad-83be-20c207b4d0d7

		changedProperty = IsHidden

	measure 'המלצת רכש' = ```
			SUMX(VALUES(dimItems[ItemKey]), CALCULATE(IF([כמות נדרשת לעמידה בחודשי מלאי] >
			[כמות מלאי כולל רכש והזמנות לקוח] , [כמות נדרשת לעמידה בחודשי מלאי] -[כמות מלאי כולל רכש והזמנות לקוח] ,0)))
			
			/* if calculating the recom according to parameters
			
			
			*/
			
			/* if calculatin the recom according to future date 
			
			IF( [Inventory Days - Including Purchase and Orders] > ([PurchaseMonthsParameter Value] *30 *[Daily Inventory Chosen Analysis]) 
			,0,
			([PurchaseMonthsParameter Value] *30 *[Daily Inventory Chosen Analysis]) - [Inventory Days - Including Purchase and Orders])
			*/
			
			
			///V1 IF([Purchase Recomendation - Days]>0,[Avg Lead Time]*[ממוצע יומי לתקופה שנבחרה],
			//(ABS([Purchase Recomendation - Days]+[Avg Lead Time])*[ממוצע יומי לתקופה שנבחרה]))
			```
		formatString: #,0
		displayFolder: מדדי אחוז
		lineageTag: 89feac09-abdc-48cf-a35b-fb6115b48fc3

		changedProperty = IsHidden

	measure 'Inventory Balance - Quantity' = ```
			
			VAR _LastUpdated=CALCULATE(MAX(factInventory[Date]),ALL(factInventory))
			
			RETURN 
			CALCULATE(SUM(factInventory[Quantity]),factInventory[Date]=_LastUpdated)
			```
		formatString: " #,#.##;(#,#.##)"
		lineageTag: d1a59b4c-3451-43eb-8a92-17c1ea9e8671

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Inventory Balance - Value' =
			
			var LastUpdated=CALCULATE(MAX(factInventory[Date]),ALL(factInventory))
			return CALCULATE(SUM(factInventory[StockValue]),factInventory[Date]=LastUpdated)
