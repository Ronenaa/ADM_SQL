	measure 'Inventory Balance - Quantity - Monthly' = ```
			
			VAR _LastUpdated=CALCULATE(MAX(factInventory[Date]))
			
			RETURN 
			CALCULATE(SUM(factInventory[Quantity]),factInventory[Date]=_LastUpdated)
