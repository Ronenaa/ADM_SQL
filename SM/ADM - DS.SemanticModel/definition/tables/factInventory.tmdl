C.FotFlat) OVER (PARTITION BY TM.ItemKey order by PC.DueDate)* SUM(TM.Quantity) ELSE PC.FotFlat* SUM(TM.Quantity) END AS 'SVal'#(lf)#(tab)#(tab),PC.WeightedExpenses#(lf)#(tab)#(tab),GETDATE() AS RowInsertDatetime#(lf)#(tab)#(tab),MV.MAXVERSION as 'Version'#(lf)#(tab)#(tab),ROW_NUMBER() OVER (partition by PC.DueDate,TM.ItemKey ORDER BY PC.DueDate,MV.MAXVERSION desc) AS 'MaxVersion' --row num 1 will be the latest#(lf)#(lf)FROM STG_2 TM#(lf)LEFT JOIN (SELECT DueDate,ProductCode,MAX([Version]) as MAXVERSION#(lf)#(tab)#(tab)#(tab)FROM tblProductsCost#(lf)#(tab)#(tab)#(tab)Group By DueDate,ProductCode) MV#(lf)#(tab)#(tab)ON MV.DueDate=TM.Date#(lf)#(tab)#(tab)AND MV.ProductCode = TM.ItemKey#(lf)LEFT JOIN tblProductsCost PC#(lf)#(tab)ON PC.Version =MV.MAXVERSION#(lf)#(tab)AND PC.DueDate = MV.DueDate#(lf)#(tab)AND PC.ProductCode = MV.ProductCode#(lf)WHERE 1=1#(lf)GROUP BY TM.ItemKey,PC.DueDate,PC.AvgPrice,PC.CFFlat,PC.FotFlat,PC.WeightedExpenses,MV.MAXVERSION#(lf))#(lf)#(lf)#(lf)SELECT#(lf)'1' as 'EntityID'#(lf)--,'1' + Inv.ItemKey as 'ItemKey'#(lf)--,CONCAT('1', Inv.ItemKey) as 'ItemKey'#(lf),cast(Inv.ItemKey as varchar) +'-'+ cast(Inv.ItemKey as varchar) as 'ItemKey'#(lf),Inv.Date AS 'Date'#(lf),NULL as 'Type'#(lf),NULL as 'Status'#(lf)--,'1' + Inv.[WarehsKey] as 'WarehsKey'#(lf)--,CONCAT('1' , Inv.[WarehsKey]) as 'WarehsKey'#(lf),cast( Inv.SupplierKey as varchar) as 'SupplierKey'#(lf),cast( Inv.[WarehsKey] as varchar) as 'WarehsKey'#(lf)--,'1' + Inv.[BranchKey] as 'BranchKey'#(lf)--,Concat('1', Inv.[BranchKey]) as 'BranchKey'#(lf),cast(Inv.[BranchKey] as varchar) as 'BranchKey'#(lf),Inv.[CostperUnit]#(lf),UnitPrice#(lf),FOTprice#(lf),CFPrice#(lf),SUM(Quantity) as 'Quantity'#(lf),SUM([StockValue]) as 'StockValue'#(lf),SUM([FOTStockValue]) as 'FOTStockValue'#(lf),SUM([CFStockValue]) as 'CFStockValue'#(lf),WeightedExpenses#(lf),Inv.[RowInsertDatetime]#(lf)FROM (SELECT * #(lf)#(tab)#(tab)FROM STG_1#(lf)#(tab)UNION ALL#(lf)#(tab)SELECT *#(lf)#(tab)#(tab)FROM STG_3#(lf)#(tab)#(tab))Inv#(lf)WHERE MaxVersion=1#(lf)GROUP BY #(lf)Inv.ItemKey#(lf),Inv.Date#(lf),Inv.TYPE#(lf),Inv.Status#(lf),Inv.WarehsKey#(lf),SupplierKey#(lf),Inv.BranchKey#(lf),Inv.CostperUnit#(lf),Inv.RowInsertDatetime#(lf),WeightedExpenses#(lf),UnitPrice#(lf),FOTprice#(lf),CFPrice#(lf)Order By SupplierKey,ItemKey,Date"]),
