table RiskPlanMeasures
	lineageTag: 6403fa79-1d08-4c14-a332-27c6e52e2ad7

	measure SwitchMeasures = ```
			
			Switch(MIN(RiskPlanMeasures[RiskPlanMeasures Order]),
			    0,[Balance - Risk Plan], 
			    1,[AVG Price - Risk Plan No Total], 
			    2,[Market Price - Risk Plan No Total],
			    3,[Price Diff - Risk Plan No Total], 
			    4,[Total Risk Plan])
			```
		formatString: #,0
		lineageTag: 71a16e47-e920-4307-9e26-6adcefdedc0f

		annotation PBI_FormatHint = {"isDecimal":true}

