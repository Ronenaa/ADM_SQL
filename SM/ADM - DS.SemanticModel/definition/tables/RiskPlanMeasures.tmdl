	partition RiskPlanMeasures = calculated
		mode: import
		source =
				{
				    ("Balance", NAMEOF('factOrders'[Balance - Risk Plan]), 0,"Balance"),
				    ("Cost Price", NAMEOF('factOrders'[AVG Price - Risk Plan No Total]), 1,"Cost Price"),
				    ("Market Price", NAMEOF('factDailyPrices'[Market Price - Risk Plan No Total]), 2,"Market Price"),
				    ("Profit/Loss", NAMEOF('factOrders'[Price Diff - Risk Plan No Total]), 3,"Profit/Loss"),
				    ("Risk Plan", NAMEOF('factOrders'[Total Risk Plan]), 4,"Risk Plan")
				}

