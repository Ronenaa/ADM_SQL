table factGain
	lineageTag: 90dcc501-1254-44cb-8db6-0688157a3940

	measure 'Purchase Qty' = ```
			
			CALCULATE (
			    SUM ( factGain[PurchaseQuantity] ),
			    FILTER (
			        factGain,
			        factGain[purchase_docname] = "Warehouse"
			            || factGain[Qty_flag] = "1"
			    )
			)
			
			```
		formatString: #,0.00
		displayFolder: Base Measures
		lineageTag: 25bb7897-58e9-468c-9259-738749bdc57c

	measure 'CIF Purchase' =
			
			CALCULATE(
			   sum(factGain[CIF_Purchase]),
			    factGain[Qty_flag] = "1"
			)
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		displayFolder: Base Measures
		lineageTag: 8dd57b6b-31ec-4602-98cb-57d7b95294df

	measure 'DischargeCost new' =
			
			CALCULATE(
			    sum(factGain[DischargeCost]),
			    factGain[Qty_flag] = "1"
			)
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		displayFolder: Base Measures
		lineageTag: 6ecdc05e-dc00-47c2-9cc8-9c7433acee5f

	measure 'FOTPurchase new' = ```
			
			var price_wh = CALCULATE(AVERAGE(factGain[FOT_Purchase]), factGain[Purchase_DocName] = "Warehouse")
			var price_other = CALCULATE(SUM(factGain[FOT_Purchase]),factGain[Qty_flag] = "1")
			RETURN
			switch(
			    SELECTEDVALUE(factGain[Purchase_DocName]),
			    "Warehouse",price_wh,
			    price_other
			)
			    
			```
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		displayFolder: Base Measures
		lineageTag: 7b1d801b-f78a-44f1-bbe0-2322d87ed54f

	measure 'Total Gain (DeliveryDate)' =
			
			CALCULATE(
			    [Total Gain (Base)],
			    USERELATIONSHIP(factGain[DeliveryDate],dimDates[Date])
			)
		lineageTag: 6bc0775a-6bc5-418f-a24a-953e13b55d46

		formatStringDefinition =
				var V = [Total Gain (DeliveryDate)]
				
				return
				switch( TRUE(),
				    ABS(V) >= 1000000, "$#,0,,.0#M",
				    ABS(V) >= 1000, "$#,0,.0#K",
				    "$#,0"
				)

	measure 'Sales Qty (Exceution)' =
			
			CALCULATE(
			[Sales Qty],
			FILTER(factGain,factGain[QuantityCategory] = "Sales")
			)
		lineageTag: 61088c21-4dd5-4c3f-a3fc-4c58ceffca2e

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Gain per Ton new' =
			DIVIDE(
			    [Total Gain (Base)],
			    [Sales Qty]
			)
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		lineageTag: 931ef64a-7e46-4f36-9f78-6760bade4717

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Sales Qty' = sum(factGain[Quantity])
		displayFolder: Base Measures
		lineageTag: 937f8184-c149-4b26-83fc-9a0ed9146091

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'AVG unit price sales non dates' =
			
			CALCULATE(
			    AVERAGE(factGain[UnitNetPriceUSD]),
			    factGain[LineType] = "Item",
			    REMOVEFILTERS(dimDates)
			)
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		displayFolder: Ship_Details
		lineageTag: 07cf476e-c0b9-4f56-be45-784fe38aa08e

	measure 'FOT Qty (Sales)' =
			
			CALCULATE(
			SUM(factGain[Quantity]),
			FILTER(factGain,factGain[Price Term] = "FOT")
			)
		displayFolder: Base Measures
		lineageTag: 06a08414-8b1f-42f5-83ac-d1549c4645f2

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'CIF Qty (Sales)' =
			
			CALCULATE(
			SUM(factGain[Quantity]),
			FILTER(factGain,factGain[Price Term] = "CIF")
			)
		displayFolder: Base Measures
		lineageTag: f4005234-cd42-4b74-99da-084845a7c6ec

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Gain (Base)' =
			
			SUM(factGain[TotalGain])
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		displayFolder: Base Measures
		lineageTag: 1760992a-d8e3-420c-a6bf-08dab57da5a5

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Total Quantity Adjustment (Gain)' =
			
			CALCULATE(SUM(factGain[Quantity]), factGain[AdjustmentFlag] = "1")
		lineageTag: ba6301db-f40b-4c50-85b7-35c088cd7bbf

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Shortage Qty Adjustment' =
			
			CALCULATE(
			    [Total Quantity Adjustment (Gain)],
			    factGain[QuantityCategory] = "Shortage"
			)
		lineageTag: 4aca9c5d-a8df-4794-b8cb-11e07183bed2

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Storage Qty Adjustment' =
			
			CALCULATE(
			    [Total Quantity Adjustment (Gain)],
			    factGain[QuantityCategory] = "Storage",
			    REMOVEFILTERS(dimDates)
			)
		displayFolder: Ship_Details
		lineageTag: a265baa7-1ba2-4129-8a10-319bc0e4f94f

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Adjustment Shortage % (gain)' =
			
			IF( [Shortage Qty Adjustment] && [Purchase Qty],
			DIVIDE(
			[Shortage Qty Adjustment],
			[Purchase Qty],0)
			)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 5021ff8e-9e76-4307-9884-a063adb15913

	measure 'Exchange Qty Adjustment' =
			
			CALCULATE(
			    [Total Quantity Adjustment (Gain)],
			    factGain[QuantityCategory] = "Swap",
			    REMOVEFILTERS(dimDates)
			)
		lineageTag: 5c61816a-c133-4a96-8334-a89c2431553a

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'PO Number new' =
			
			CALCULATE(
			    SELECTEDVALUE(dimSubPurchaseOrderNumber[PurchaseOrderID]),
			    FILTER(
			        ALL(factGain),
			        factGain[PurchaseOrderID] in VALUES(factGain[PurchaseOrderID])
			    )
			)
		lineageTag: d44ee5e1-2782-49a3-97ba-038b89e9805b

	measure 'Product new' = ```
			
			CALCULATE(
			    SELECTEDVALUE(dimItems[Article_Description]),
			    FILTER(
			        ALL(factGain),
			        factGain[PurchaseOrderID] in VALUES(factGain[PurchaseOrderID]) &&
			        factGain[ItemKey] <> "96-96" &&
			        factGain[Quantity] > 0 
			    )
			)
			```
		lineageTag: 1017c8fa-80b1-4264-8762-da109c276c26

	measure 'Delivery Date (Gain)' =
			
			var delivery_month_count = DISTINCTCOUNT(factGain[Year-Month])
			 RETURN
			 IF(
			    delivery_month_count > 1, "Multiple",
			    CALCULATE(
			    SELECTEDVALUE(dimDates[MonthInCalendarShortName]),
			    FILTER(
			        ALL(factGain),
			        factGain[PurchaseOrderID] in VALUES( factGain[PurchaseOrderID])
			    )
			    )
			 )
		lineageTag: edb174d8-0e7b-4239-94fa-bd26cc362413

	measure 'Supplier Name gain' = ```
			
			IF (
			    ISBLANK ( SELECTEDVALUE (factGain[PurchaseOrderID])),
			    BLANK(),
			    CALCULATE(
			        SELECTEDVALUE(dimSuppliers[Supplier Name]),
			        FILTER( ALL( factGain),
			        factGain[PurchaseOrderID] in VALUES(factGain[PurchaseOrderID]) &&
			        factGain[Qty_flag] ="1" 
			        --&& factGain[Purchase_DocName] = "Order Expenses"
			    )
			))
			```
		lineageTag: 07c26ad7-7697-41c5-a4fb-22edbd5ec241

	measure 'AVG unit price weighted' =
			
			CALCULATE(
			    [AVG unit price sales],
			    REMOVEFILTERS(dimCustomers)
			)
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		lineageTag: 96290117-8de6-4487-a004-03a98fd22d15

	measure 'AVG Price diff' = ```
			
			 IF( 
			    ISBLANK([AVG unit price sales]),
			    BLANK(),
			    [AVG unit price sales] - [AVG unit price weighted]
			 )
			```
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		lineageTag: 198ec594-7abd-49ce-a737-11dc2e6f5603

	measure 'Sales Qty non date' =
			
			CALCULATE(
			    [Sales Qty (Exceution)],
			    REMOVEFILTERS(dimDates)
			)
		displayFolder: Ship_Details
		lineageTag: 14fbd6e4-463b-4cb6-a66e-1a09ec14cca0

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Purchase Qty non dates' =
			
			CALCULATE(
