		sourceColumn: Total_WH_cost

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	partition factGain = m
		mode: import
		queryGroup: 'fact Tables'
		source =
				let
				    Source = Sql.Database(#"SQL Address", "MT", [Query="with CurrencyConvertion as (#(lf)SELECT *, #(lf)         CASE#(lf)         #(tab)WHEN sher = 0#(lf)         #(tab)THEN FIRST_VALUE(sher) OVER (PARTITION BY value_partition ORDER BY Tarikh) #(lf)         #(tab)ELSE sher#(lf)         END AS new_sher#(lf)         ,CASE#(lf)         #(tab)WHEN SHER_EURO = 0#(lf)         #(tab)THEN FIRST_VALUE(SHER_EURO) OVER (PARTITION BY value_partitionEuro ORDER BY Tarikh) #(lf)         #(tab)ELSE  SHER_EURO#(lf)         END AS new_sherEuro#(lf) FROM (#(lf)          SELECT *#(lf) ,SUM(CASE WHEN sher=0 THEN 0 ELSE 1 END) OVER (ORDER BY tarikh ) AS value_partition#(lf) ,SUM(CASE WHEN SHER_EURO=0 THEN 0 ELSE 1 END) OVER (ORDER BY tarikh ) AS value_partitionEuro#(lf)          FROM SHERI_MTBE#(lf) ) m#(lf))#(lf)#(lf)--------------------------------------------------------------- the below part should be a view is the database ----------------------------------------------------#(lf),totals_raw AS (#(lf)    -- Step 1: per-row calculations#(lf)    SELECT#(lf)        CONCAT(#(lf)            CAST(CONVERT(BIGINT, POL.POL_OrderID) AS VARCHAR(20)),#(lf)            CAST(POL.POL_LineID AS VARCHAR(10))#(lf)        ) AS PurchaseOrderID,#(lf)        #(lf)        CONVERT(VARCHAR, HS.QOD_MOTSR) + '-' + CONVERT(VARCHAR, HS.QOD_MOTSR) AS ItemKey,#(lf)#(lf)        -- PNL classification#(lf)        CASE#(lf)            WHEN HST.QOD_SHROT IN (5, 19, 30, 4)#(lf)              OR HST.QOD_SHROT IS NULL#(lf)                THEN 999#(lf)            ELSE HST.QOD_SHROT#(lf)        END AS PNLKey,#(lf)#(lf)        -- Order quantity (only main item rows)#(lf)        CASE#(lf)            WHEN HS.QOD_SHROT = 0 THEN HS.CMOT#(lf)            ELSE 0#(lf)        END AS OrderQuantity,#(lf)#(lf)        -- Line total in USD (exactly כמו הקטע ששלחת)#(lf)        CASE#(lf)            WHEN HS.MTBE = '$' THEN HS.MCHIR_ICH * HS.CMOT#(lf)            WHEN HS.MTBE = 'Eur' THEN HS.MCHIR_ICH * HS.CMOT * (SM.NEW_SHEREURO / NULLIF(SM.NEW_SHER, 0))#(lf)            ELSE HS.MCHIR_ICH * HS.CMOT * (#(lf)                    1 / CASE WHEN HC.SHER_MTBE = 0 THEN 1 ELSE HC.SHER_MTBE END#(lf)                 )#(lf)        END AS LineTotalNetUSD#(lf)    FROM HOTSAOT_COTROT HC#(lf)    LEFT JOIN HOTSAOT_SHOROT HS#(lf)        ON HC.NOMRTOR = HS.NOMRTOR#(lf)    LEFT JOIN PurchaseOrderLines POL#(lf)        ON CONCAT(#(lf)               CAST(CONVERT(BIGINT, POL.POL_OrderID) AS VARCHAR(20)),#(lf)               CAST(POL.POL_LineID AS VARCHAR(10))#(lf)           ) = CAST(HS.MS_MSMKH_QSHOR AS VARCHAR(30))#(lf)    LEFT JOIN HOTSAOT_SHROTIM_New HST#(lf)        ON HS.QOD_SHROT = HST.QOD_SHROT#(lf)    LEFT JOIN CurrencyConvertion SM#(lf)        ON SM.TARIKH = HC.T_ERKH#(lf)    WHERE 1 = 1#(lf)      AND CAST(SUBSTRING(HC.T_MSMKH, 1, 4) AS INT) >= 2018#(lf)      AND CAST(SUBSTRING(HC.T_MSMKH, 1, 4) AS INT) <= YEAR(GETDATE())#(lf)      AND HS.QOD_SHROT NOT IN (14)#(lf)),#(lf)#(lf)totals AS (#(lf)    -- Step 2: aggregate like the DAX measure#(lf)    SELECT#(lf)        PurchaseOrderID,#(lf)        ItemKey,#(lf)        999 as PNLKey,#(lf)        SUM(LineTotalNetUSD) AS LineTotalNetUSD,       -- same as [Total Expenses USD]#(lf)        SUM(OrderQuantity)   AS OrderQuantity,     -- same as [Total Order Quantity (Hzmnot)]#(lf)        CAST(ROUND(SUM(LineTotalNetUSD) / NULLIF(SUM(OrderQuantity), 0), 2) AS FLOAT) AS UnitNetPriceUSD  -- Avg Price USD (Expenses)#(lf)    FROM totals_raw#(lf)    GROUP BY#(lf)        PurchaseOrderID,#(lf)        ItemKey#(lf)),#(lf)#(lf)-- exchange_movements: merges former 'main' + 'base' — raw free shipments enriched with purchase cost#(lf)exchange_movements AS (#(lf)    SELECT#(lf)        TM.QOD_SHOLCH  AS DeliveredFrom,#(lf)        W.SHM_GORM     AS DeliveredFromName,#(lf)        ISNULL(b.MS_HZMNH, bb.MS_HZMNH) AS PurchaseOrderID,#(lf)        CASE#(lf)            WHEN ISNULL(b.MS_HZMNH, bb.MS_HZMNH) LIKE '2000%' THEN 'P' -- Purchase order#(lf)            ELSE 'E'                                                     -- Expense / other#(lf)        END AS Order_Type,#(lf)        CONVERT(VARCHAR, TM.QOD_MOTSR) + '-' + CONVERT(VARCHAR, TM.QOD_MOTSR) AS ItemKey,#(lf)        SUM(TM.MSHQL_NTO) AS qty_loaned,#(lf)        G.QOD_GORM     AS DeliveredTo,#(lf)        G.SHM_GORM     AS DeliveredToName,#(lf)        SUBSTRING(TARIKH_MSHLOCH, 1, 4) + '-' + SUBSTRING(TARIKH_MSHLOCH, 5, 2) AS [Date],#(lf)        -- price columns from totals (previously joined in the separate 'base' CTE)#(lf)        t.UnitNetPriceUSD,#(lf)        t.LineTotalNetUSD,#(lf)        t.OrderQuantity#(lf)    FROM TEODOT_MSHLOCH TM#(lf)    LEFT JOIN GORMIM G                   ON TM.QOD_MQBL        = G.QOD_GORM#(lf)    LEFT JOIN GORMIM W                   ON TM.QOD_SHOLCH       = W.QOD_GORM#(lf)    LEFT JOIN QISHOR_RCSH_LMCIRH a       ON a.MS_TEODT_MCIRH   = TM.MS_TEODH#(lf)    LEFT JOIN QISHOR_T_MSHLOCH_HZMNOT b  ON a.MS_TEODT_RCSH    = b.MS_T_MSHLOCH#(lf)    LEFT JOIN QISHOR_T_MSHLOCH_HZMNOT bb ON bb.MS_T_MSHLOCH    = TM.MS_TEODH#(lf)    LEFT JOIN (#(lf)        SELECT PurchaseOrderID, ItemKey, UnitNetPriceUSD, LineTotalNetUSD, OrderQuantity#(lf)        FROM totals#(lf)        WHERE PNLKey = 999#(lf)          AND OrderQuantity <> 0#(lf)    ) t ON ISNULL(b.MS_HZMNH, bb.MS_HZMNH) = t.PurchaseOrderID#(lf)    WHERE TM.MCHIR_ICH = 0                         -- Only free/loaned shipments#(lf)      AND G.AOPI_PEILOT NOT IN (N'פחת', N'אחסון') -- Exclude waste/storage#(lf)      AND SUBSTRING(TARIKH_MSHLOCH, 1, 4) + '-' + SUBSTRING(TARIKH_MSHLOCH, 5, 2) >= '2024-01'#(lf)    GROUP BY#(lf)        SUBSTRING(TARIKH_MSHLOCH, 1, 4) + '-' + SUBSTRING(TARIKH_MSHLOCH, 5, 2),#(lf)        TM.QOD_SHOLCH, W.SHM_GORM,#(lf)        b.MS_HZMNH, bb.MS_HZMNH,#(lf)        CONVERT(VARCHAR, TM.QOD_MOTSR) + '-' + CONVERT(VARCHAR, TM.QOD_MOTSR),#(lf)        G.QOD_GORM, G.SHM_GORM,#(lf)        t.UnitNetPriceUSD, t.LineTotalNetUSD, t.OrderQuantity#(lf)),#(lf)#(lf)exchange_p_orders AS (#(lf)    -- P-type movements only: the original purchases that exchanges are matched against#(lf)    SELECT#(lf)        DeliveredFrom,#(lf)        DeliveredFromName,#(lf)        PurchaseOrderID,#(lf)        ItemKey,#(lf)        SUM(qty_loaned)        AS quantity,#(lf)        DeliveredTo,#(lf)        DeliveredToName,#(lf)        [Date]                 AS Purchase_Date,#(lf)        MAX(UnitNetPriceUSD)   AS max_unit_price,#(lf)        MAX(LineTotalNetUSD)   AS max_LineTotalNetUSD,#(lf)        MAX(OrderQuantity)     AS max_OrderQuantity#(lf)    FROM exchange_movements#(lf)    WHERE Order_Type = 'P'#(lf)    GROUP BY#(lf)        DeliveredFrom, DeliveredFromName,#(lf)        PurchaseOrderID, ItemKey,#(lf)        DeliveredTo, DeliveredToName,#(lf)        [Date]#(lf)),#(lf)#(lf)-- exchange_priced: merges former 'final' + 'final2' — ranks and keeps only the best purchase match#(lf)exchange_priced AS (#(lf)    SELECT#(lf)            b.DeliveredFrom,#(lf)            b.DeliveredFromName,#(lf)            b.PurchaseOrderID  AS Exchange_order,#(lf)            b.[Date]           AS Exchange_Order_Date,#(lf)            b.ItemKey,#(lf)            b.qty_loaned       AS Qty_Sold,#(lf)            p.PurchaseOrderID  AS Purchase,#(lf)            p.Purchase_Date,#(lf)            p.max_unit_price   AS UnitNetPriceUSD,#(lf)            p.max_LineTotalNetUSD AS LineTotalNetUSD,#(lf)            p.max_OrderQuantity   AS OrderQuantity,#(lf)            ship_sub.ShipID,   -- ship from the related purchase order#(lf)            ROW_NUMBER() OVER (#(lf)                PARTITION BY b.ItemKey,b.PurchaseOrderID#(lf)                ORDER BY p.Purchase_Date DESC#(lf)            ) AS rn#(lf)        FROM exchange_movements b#(lf)        LEFT JOIN exchange_p_orders p#(lf)            ON  b.DeliveredFrom = p.DeliveredTo#(lf)            AND b.ItemKey       = p.ItemKey#(lf)        -- Look up the ship that delivered the related purchase order.#(lf)        -- p.PurchaseOrderID = CONCAT(POL_OrderID, POL_LineID) — same format as totals_raw.#(lf)        -- Must include POL_LineID in the key, otherwise it never matches.#(lf)        LEFT JOIN (#(lf)            SELECT#(lf)                CONCAT(#(lf)                    CAST(CONVERT(BIGINT, POL.POL_OrderID) AS VARCHAR(20)),#(lf)                    CAST(POL.POL_LineID AS VARCHAR(10))#(lf)                )              AS PurchaseOrderID,#(lf)                MAX(sl.ShipID) AS ShipID#(lf)            FROM PurchaseOrderLines POL#(lf)            JOIN ShipsArrivals sa ON POL.POL_ShipArrivalID = sa.SA_ID#(lf)            JOIN ShipList      sl ON sa.SA_ShipID          = sl.ShipID#(lf)            GROUP BY POL.POL_OrderID, POL.POL_LineID#(lf)        ) ship_sub ON ship_sub.PurchaseOrderID = CAST(p.PurchaseOrderID AS VARCHAR(20))#(lf)        WHERE DATEDIFF(MONTH,#(lf)#(tab)#(tab)#(tab)#(tab)CAST(b.[Date] + '-01' AS DATE),#(lf)#(tab)#(tab)#(tab)#(tab)CAST(p.Purchase_Date + '-01' AS DATE)#(lf)#(tab)#(tab)#(tab)#(tab))    BETWEEN -3 AND 0#(lf))#(lf)#(lf)-----------------------------------------------------------------------------------------------------------------------------------------------#(lf),purchase_orders as (#(lf)#(lf)----Invoice--#(lf)SELECT#(lf)#(tab) CAST(CCS.HZMNT_RCSH AS VARCHAR)#(tab)#(tab)#(tab)AS PurchaseOrderID,#(lf)     'Invoice'#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS DocName,#(lf)     NULL#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS SupplierKey,#(lf)     CAST(SUBSTRING(CCS.T_CHSHBONIT,1,4) + '-' + SUBSTRING(CCS.T_CHSHBONIT,5,2) + '-' + SUBSTRING(CCS.T_CHSHBONIT,7,2) AS DATE) AS [Value Date],#(lf)     CAST(CONVERT(VARCHAR, POL_ProductID) AS VARCHAR) + '-' + CAST(CONVERT(VARCHAR, M.ServiceCode) AS VARCHAR) + 'S' AS ItemKey,#(lf)     CAST(ROUND(CCS.MCHIR_ICH_LLA_ME_M / NULLIF(CASE WHEN SHER_LCHISHOB <> 0 THEN SHER_LCHISHOB ELSE CC2.new_sher END, 0), 2) AS FLOAT) * -1  AS UnitNetPriceUSD,#(lf)     CCS.MSHQL_NTO                   AS Quantity,#(lf)     CASE WHEN CCS.QOD_MOTSR = 0 THEN CCS.MSHQL_NTO ELSE 0 END AS OrderQuantity,#(lf)     HST.QOD_SHROT                           AS PNLKey,#(lf)#(tab) HST.PNL as [PNL Code],#(lf)     CAST(ROUND(CCS.CMOT * (CCS.MCHIR_ICH_LLA_ME_M / NULLIF(CASE WHEN SHER_LCHISHOB <> 0 THEN SHER_LCHISHOB ELSE CC2.new_sher END, 0)), 2) AS FLOAT) * -1 AS LineTotalNetUSD,#(lf)     CONVERT(INT, CONVERT(VARCHAR, SUBSTRING(CCS.T_CHSHBONIT,1,4) + SUBSTRING(CCS.T_CHSHBONIT,5,2))) AS YearMonth,#(lf)#(tab) null as ShipID,#(lf)    'Invoice'                                AS DocType,#(lf)#(tab)CASE WHEN SHER_LCHISHOB <> 0 THEN SHER_LCHISHOB ELSE CC2.new_sher END as [NEW_SHER]#(lf)FROM [dbo].[CHIOBI_CHOTS_COTROT] CC#(lf)LEFT JOIN [dbo].[CHIOBI_CHOTS_SHOROT] CCS#(lf)       ON CC.MS_CHSHBONIT = CCS.MS_CHSHBONIT#(lf)LEFT JOIN CurrencyConvertion CC2#(lf)       ON CCS.[TARIKH_MSHLOCH] = CC2.Tarikh#(lf)LEFT JOIN (select DISTINCT#(lf)#(tab)#(tab)#(tab)POL_SQL_POID, POL_ProductID#(lf)#(tab)#(tab)#(tab)from PurchaseOrderLines POL#(tab)) POL#(lf)#(tab)#(tab)ON CCS.HZMNT_RCSH = POL.POL_SQL_POID#(lf)LEFT JOIN MOTSRIM M#(lf)#(tab)ON CCS.QOD_MOTSR = M.QOD_MOTSR#(lf)LEFT JOIN HOTSAOT_SHROTIM_New HST #(lf)#(tab)ON M.ServiceCode = HST.QOD_SHROT#(lf)#(tab)where CAST(SUBSTRING(CCS.T_CHSHBONIT,1,4) + '-' + SUBSTRING(CCS.T_CHSHBONIT,5,2) + '-' + SUBSTRING(CCS.T_CHSHBONIT,7,2) AS DATE) >= '2024-01-01'#(lf)#(lf)UNION ALL#(lf)#(tab)------Import--------#(lf)SELECT#(lf)#(lf)#(tab)#(tab)CONCAT(#(lf)#(tab)#(tab)#(tab)CAST(CONVERT(BIGINT, POL.POL_OrderID) AS VARCHAR(20)),#(lf)#(tab)#(tab)#(tab)CAST(POL.POL_LineID AS VARCHAR(10))#(lf)#(tab)#(tab) )#(tab)as 'PurchaseOrderID'#(lf)#(tab)#(tab),'Import' AS 'DocName'  -- was: 'Order Expenses'#(lf)#(tab)#(tab),CAST(#(lf)#(tab)#(tab)  MAX(#(lf)#(tab)#(tab)#(tab)CASE WHEN HS.QOD_SHROT = 0#(lf)#(tab)#(tab)#(tab)#(tab) THEN CONVERT(INT, CONVERT(VARCHAR, HC.QOD_SPQ))#(lf)#(tab)#(tab)#(tab)END#(lf)#(tab)#(tab)  ) OVER (PARTITION BY HS.MS_MSMKH_QSHOR)#(lf)#(tab)#(tab)#(tab)AS VARCHAR)#(tab) AS 'SupplierKey'#(lf)#(tab)#(tab),CASE #(lf)#(tab)#(tab)#(tab)WHEN HS.MS_MSMKH_QSHOR = 0 #(lf)#(tab)#(tab)#(tab)  THEN CONVERT(date, HC.T_ERKH, 112)#(lf)#(tab)#(tab)#(tab)ELSE#(lf)#(tab)#(tab)#(tab)  MAX(#(lf)#(tab)#(tab)#(tab)#(tab)CASE WHEN HS.QOD_SHROT = 0 #(lf)#(tab)#(tab)#(tab)#(tab)#(tab) THEN CONVERT(date, HC.T_ERKH, 112) #(lf)#(tab)#(tab)#(tab)#(tab)END#(lf)#(tab)#(tab)#(tab)  ) OVER (#(lf)#(tab)#(tab)#(tab)#(tab)PARTITION BY #(lf)#(tab)#(tab)#(tab)#(tab)  CASE #(lf)#(tab)#(tab)#(tab)#(tab)#(tab)WHEN HS.MS_MSMKH_QSHOR = 0 #(lf)#(tab)#(tab)#(tab)#(tab)#(tab)  THEN HZ.MSPR_HZMNH #(lf)#(tab)#(tab)#(tab)#(tab)#(tab)ELSE HS.MS_MSMKH_QSHOR #(lf)#(tab)#(tab)#(tab)#(tab)  END#(lf)#(tab)#(tab)#(tab)  )#(lf)#(tab)#(tab)  END AS 'Value Date'#(lf)#(tab)#(tab),CASE#(lf)#(tab)#(tab)#(tab)WHEN  HST.QOD_SHROT IS NULL OR HS.QOD_SHROT IN (5, 19, 30, 4) THEN cast(CONVERT(INT, CONVERT(VARCHAR,HS.QOD_MOTSR)) as varchar)+ '-' + cast(CONVERT(INT, CONVERT(VARCHAR,HS.QOD_MOTSR)) as varchar) -- העמסת עליות הובלה והפרש מחיר על המוצר#(lf)#(tab)#(tab)#(tab)ELSE cast(CONVERT(INT, CONVERT(VARCHAR,HS.QOD_MOTSR)) as varchar)+ '-' + cast(CONVERT(INT, CONVERT(VARCHAR,HST.QOD_SHROT)) as varchar)+'S' #(lf)#(tab)#(tab)#(tab)END#(tab)#(tab)AS 'ItemKey'#(lf)#(lf)#(tab)#(tab) ,CASE#(lf)#(tab)#(tab)#(tab)WHEN HST.QOD_SHROT IS NOT NULL THEN#(lf)#(tab)#(tab)#(tab)#(tab)CASE#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)WHEN HS.MTBE = '$' THEN#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)CAST(ROUND(HS.MCHIR_ICH / NULLIF(POL.POL_FinalWeightReceived, 0), 2) AS FLOAT)#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)WHEN HS.MTBE = 'Eur' THEN#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)CAST(ROUND(#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)HS.MCHIR_ICH * (SM.NEW_SHEREURO / NULLIF(SM.NEW_SHER, 0)) / NULLIF(POL.POL_FinalWeightReceived, 0)#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab), 2) AS FLOAT)#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)ELSE#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)CAST(ROUND(#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)HS.MCHIR_ICH * (1 / NULLIF(HC.SHER_MTBE, 0)) / NULLIF(POL.POL_FinalWeightReceived, 0)#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab), 2) AS FLOAT)#(lf)#(tab)#(tab)#(tab)#(tab)END#(lf)#(tab)#(tab)#(tab)ELSE#(lf)#(tab)#(tab)#(tab)#(tab)CASE#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)WHEN HS.MTBE = '$' THEN CAST(ROUND(HS.MCHIR_ICH, 2) AS FLOAT)#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)WHEN HS.MTBE = 'Eur' THEN#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)CAST(ROUND(#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)HS.MCHIR_ICH * (SM.NEW_SHEREURO / NULLIF(SM.NEW_SHER, 0))#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab), 2) AS FLOAT)#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)ELSE#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)CAST(ROUND(#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)HS.MCHIR_ICH * (1 / NULLIF(HC.SHER_MTBE, 0))#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab), 2) AS FLOAT)#(lf)#(tab)#(tab)#(tab)#(tab)END#(lf)#(tab)#(tab)END AS 'UnitNetPriceUSD'#(lf)#(tab)#(tab),HS.CMOT AS 'Quantity'#(lf)#(tab)#(tab),CASE WHEN HS.QOD_SHROT = 0 then HS.CMOT#(lf)#(tab)#(tab)#(tab)#(tab)ELSE 0#(lf)#(tab)#(tab)#(tab)#(tab)END#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS 'OrderQuantity'#(lf)#(tab)#(tab),CASE #(lf)#(tab)#(tab)#(tab)WHEN HST.QOD_SHROT IN (5, 19, 30, 4,18) OR HST.QOD_SHROT IS NULL #(lf)#(tab)#(tab)#(tab)THEN 999#(lf)#(tab)#(tab)#(tab)ELSE HST.QOD_SHROT#(lf)#(tab)#(tab)END#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS 'PNLKey' ----------  העמסת עליות הובלה על המוצר והפרש מחיר#(lf)#(tab)#(tab)#(tab),case when HST.QOD_SHROT IN (5, 19, 30, 4,18) OR HST.QOD_SHROT IS NULL  then 1010 #(lf)#(tab)#(tab)#(tab)else HST.PNL end as [PNL Code]#(lf)#(tab)#(tab)#(tab),CAST(ROUND(CASE#(lf)#(tab)         WHEN HS.MTBE = '$' THEN HS.MCHIR_ICH * HS.CMOT#(lf)#(tab)#(tab)#(tab) WHEN HS.MTBE = 'Eur' THEN HS.MCHIR_ICH * HS.CMOT * (SM.NEW_SHEREURO / NULLIF(SM.NEW_SHER, 0))#(lf)#(tab)         ELSE HS.MCHIR_ICH * HS.CMOT * (1 / CASE WHEN HC.SHER_MTBE = 0 THEN 1 ELSE HC.SHER_MTBE END)#(lf)         END, 2) AS FLOAT) AS 'LineTotalNetUSD'#(lf)#(tab)#(tab),CONVERT(INT, CONVERT(VARCHAR,SUBSTRING(HS.T_ERKH,1,4) + SUBSTRING(HS.T_ERKH,5,2))) AS YearMonth#(lf)#(tab)#(tab),sl.ShipID#(lf)#(tab)#(tab),CASE #(lf)#(tab)#(tab)    WHEN HS.QOD_SHROT IN (5, 19, 30, 20, 4) THEN N'סחורה'#(lf)#(tab)#(tab)    ELSE HC.SOG_MSMKH#(lf)#(tab)#(tab)END#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)as DocType#(lf)#(tab)#(tab),SM.NEW_SHER#(lf)FROM HOTSAOT_COTROT HC#(lf)LEFT JOIN HOTSAOT_SHOROT HS ON HC.NOMRTOR = HS.NOMRTOR#(lf)LEFT JOIN PurchaseOrderLines POL ON CONCAT(#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)CAST(CONVERT(BIGINT, POL.POL_OrderID) AS VARCHAR(20)),#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)CAST(POL.POL_LineID AS VARCHAR(10))#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab))#(tab)#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)= CAST(HS.MS_MSMKH_QSHOR AS VARCHAR(30))#(lf)LEFT JOIN HZMNOT HZ ON (HS.MS_MSMKH_QSHOR = HZ.MSPR_HZMNH)#(lf)LEFT JOIN HOTSAOT_SHROTIM_New HST ON HS.QOD_SHROT = HST.QOD_SHROT#(lf)LEFT JOIN ShipsArrivals sa ON POL.POL_ShipArrivalID = sa.SA_ID#(lf)LEFT JOIN ShipList sl ON sa.SA_ShipID = sl.ShipID#(lf)LEFT JOIN PurchaseOrder PO ON POL.POL_OrderID = PO.PO_OrderID#(lf)LEFT JOIN CurrencyConvertion SM  ON SM.TARIKH=HC.T_ERKH#(lf)#(lf)WHERE 1=1#(lf)and Cast(SUBSTRING(HC.T_MSMKH,1,4) as int) >=2018 and Cast(SUBSTRING(HC.T_MSMKH,1,4) as int) <= YEAR(GETDATE())#(lf)and HS.QOD_SHROT NOT IN (14)#(lf)and CONCAT(CAST(CONVERT(BIGINT, POL.POL_OrderID) AS VARCHAR(20)),CAST(POL.POL_LineID AS VARCHAR(10))) <> ' '#(lf)and  cast( HC.T_ERKH as date) >= '2024-01-01'#(lf)#(lf)UNION ALL#(lf)#(lf)-----Exchange----#(lf)SELECT#(lf)    CAST(HZ.MSPR_HZMNH AS VARCHAR)                                      AS PurchaseOrderID,#(lf)    'Swap'                                                          AS DocName,  -- was: 'Orders'#(lf)    t.DeliveredFrom#(tab)                                            AS SupplierKey,#(lf)    CAST(SUBSTRING(HZ.T_ASPQH,1,4) + '-' + SUBSTRING(HZ.T_ASPQH,5,2) + '-' + SUBSTRING(HZ.T_ASPQH,7,2)#(lf)         AS DATE)                                                       AS [Value Date],#(lf)    CAST(CONVERT(INT, CONVERT(VARCHAR,HZ.MOTSR_MOZMN)) AS VARCHAR) + '-' +#(lf)    CAST(CONVERT(INT, CONVERT(VARCHAR,HZ.MOTSR_MOZMN)) AS VARCHAR)      AS ItemKey,#(lf)    t.UnitNetPriceUSD                                                   AS UnitNetPriceUSD,#(lf)    HZ.CMOT_MOZMNT                                                      AS Quantity,#(lf)    t.OrderQuantity                                                     AS OrderQuantity,#(lf)    999                                                                 AS PNLKey,#(lf)#(tab)1010  as [PNL Code],#(lf)    t.LineTotalNetUSD                                                  AS LineTotalNetUSD,#(lf)    CONVERT(INT, CONVERT(VARCHAR, SUBSTRING(HZ.T_ASPQH,1,4) + SUBSTRING(HZ.T_ASPQH,5,2))) AS YearMonth,#(lf)    t.ShipID                                                            AS ShipID,  -- ship from the related purchase order#(lf)    'Order'                                                             AS DocType,#(lf)    SM.NEW_SHER#(lf)FROM HZMNOT HZ#(lf)LEFT JOIN CurrencyConvertion SM#(lf)    ON SM.TARIKH = HZ.T_HZMNH#(lf)LEFT JOIN exchange_priced t#(lf)    ON t.Exchange_order = HZ.MSPR_HZMNH#(lf)   AND t.ItemKey =#(lf)        CAST(CONVERT(INT, CONVERT(VARCHAR,HZ.MOTSR_MOZMN)) AS VARCHAR) + '-' +#(lf)        CAST(CONVERT(INT, CONVERT(VARCHAR,HZ.MOTSR_MOZMN)) AS VARCHAR)#(lf)   AND t.rn = 1#(lf)WHERE CAST(SUBSTRING(HZ.T_HZMNH,1,4) AS INT) BETWEEN 2018 AND YEAR(GETDATE())#(lf)  AND HZ.OrderStatus <> 3#(lf)  AND HZ.ActionType IN (6,7)#(lf)  AND YEAR(CAST(SUBSTRING(HZ.T_ASPQH,1,4) + '-' + SUBSTRING(HZ.T_ASPQH,5,2) + '-' + SUBSTRING(HZ.T_ASPQH,7,2) AS DATE))  >= 2024#(lf)  )#(lf)#(lf),inv AS (#(lf)    -- One row per (ItemKey, calendar-month): last day's price in that month.#(lf)    -- Price is set by item+date, not by warehouse — any warehouse shares the same item price.#(lf)    SELECT ItemKey, [Date], WH_Price#(lf)    FROM (#(lf)        SELECT#(lf)            CONVERT(VARCHAR, src.ItemKey) + '-' + CONVERT(VARCHAR, src.ItemKey) AS ItemKey,#(lf)            src.[Date],#(lf)            CAST(ROUND(src.LastFOTPrice,     2) AS FLOAT) AS LastFOTPrice,#(lf)            CAST(ROUND(src.WeightedExpenses, 2) AS FLOAT) AS WeightedExpenses,#(lf)            CAST(ROUND(COALESCE(NULLIF(src.WeightedExpenses, 0), src.LastFOTPrice), 2) AS FLOAT) AS WH_Price,#(lf)            ROW_NUMBER() OVER (#(lf)                PARTITION BY src.ItemKey, YEAR(src.[Date]), MONTH(src.[Date])#(lf)                ORDER BY src.[Date] DESC#(lf)            ) AS month_rn#(lf)        FROM (#(lf)            -- Regular warehouses#(lf)            SELECT#(lf)                inv.ProductID      AS ItemKey,#(lf)                inv.DueDate        AS [Date],#(lf)                pcost.FotFlat      AS LastFOTPrice,#(lf)                pcost.WeightedExpenses,#(lf)                inv.Version,#(lf)                ROW_NUMBER() OVER (PARTITION BY inv.DueDate, inv.SupplierID, inv.ProductID#(lf)                                   ORDER BY inv.Version DESC) AS MaxVersion#(lf)            FROM tblInventory inv#(lf)            LEFT JOIN tblProductsCost pcost#(lf)                ON  inv.DueDate   = pcost.DueDate#(lf)                AND inv.ProductID = pcost.ProductCode#(lf)                AND inv.Version   = pcost.Version#(lf)            WHERE inv.SupplierID IN (1411, 1367, 1366, 1289, 1101, 943)#(lf)              AND inv.DueDate >= '2024-01-01'#(lf)#(lf)            UNION ALL#(lf)#(lf)            -- Warehouse 1144: items from BT movements, prices from tblProductsCost#(lf)            SELECT#(lf)                tm.ItemKey,#(lf)                pc.DueDate         AS [Date],#(lf)                pc.FotFlat         AS LastFOTPrice,#(lf)                pc.WeightedExpenses,#(lf)                mv.MAXVERSION      AS Version,#(lf)                ROW_NUMBER() OVER (PARTITION BY pc.DueDate, tm.ItemKey#(lf)                                   ORDER BY mv.MAXVERSION DESC) AS MaxVersion#(lf)            FROM (#(lf)                SELECT DISTINCT QOD_PRIT AS ItemKey,#(lf)                       CAST(SUBSTRING(T_TNOEH,1,4)+'-'+SUBSTRING(T_TNOEH,5,2)+'-'+SUBSTRING(T_TNOEH,7,2) AS DATE) AS [Date]#(lf)                FROM BT.dbo.TNOEOT_MLAI_CLLI#(lf)                WHERE QOD_GORM <> 1#(lf)                  AND CAST(SUBSTRING(T_TNOEH,1,4) AS INT) BETWEEN 2024 AND YEAR(GETDATE())#(lf)                  AND (SOG_TNOEH_CN_ITS_SP_HE LIKE N'%כ%' OR SOG_TNOEH_CN_ITS_SP_HE LIKE N'%י%')#(lf)            ) tm#(lf)            LEFT JOIN (SELECT DueDate, ProductCode, MAX(Version) AS MAXVERSION#(lf)                       FROM tblProductsCost#(lf)                       GROUP BY DueDate, ProductCode) mv#(lf)                ON  mv.DueDate     = tm.[Date]#(lf)                AND mv.ProductCode = tm.ItemKey#(lf)            LEFT JOIN tblProductsCost pc#(lf)                ON  pc.Version     = mv.MAXVERSION#(lf)                AND pc.DueDate     = mv.DueDate#(lf)                AND pc.ProductCode = mv.ProductCode#(lf)            GROUP BY tm.ItemKey, pc.DueDate, pc.FotFlat, pc.WeightedExpenses, mv.MAXVERSION#(lf)        ) src#(lf)        WHERE src.MaxVersion = 1#(lf)    ) daily#(lf)    WHERE daily.month_rn = 1#(lf))#(lf)#(lf)-- Resolves the primary DocName per PurchaseOrderID before aggregation.#(lf)-- A PO can have rows of multiple types (e.g. Import + Invoice).#(lf)-- Priority: Import > Exchange > Invoice.#(lf),po_doctype AS (#(lf)    SELECT DISTINCT#(lf)        PurchaseOrderID,#(lf)        CASE#(lf)            WHEN EXISTS (#(lf)                SELECT 1 FROM purchase_orders pe2#(lf)                WHERE pe2.PurchaseOrderID = pe.PurchaseOrderID#(lf)                  AND pe2.DocName = 'Import'#(lf)            ) THEN 'Import'#(lf)            WHEN EXISTS (#(lf)                SELECT 1 FROM purchase_orders pe2#(lf)                WHERE pe2.PurchaseOrderID = pe.PurchaseOrderID#(lf)                  AND pe2.DocName = 'Swap'#(lf)            ) THEN 'Swap'#(lf)            ELSE 'Invoice'#(lf)        END AS DocName#(lf)    FROM purchase_orders pe#(lf))#(lf)#(lf),P_costs as (#(lf)    select#(lf)#(tab)pe.PurchaseOrderID,#(lf)#(tab)dt.DocName,#(lf)#(tab)min([Value Date]) as ValueDate,#(lf)#(tab)max(case when [PNLKey] = 999 then SupplierKey else null end) as SupplierKey,#(lf)#(tab)max(ShipID) as boat,#(lf)#(tab)SUM(CASE WHEN [PNL Code] = 2270 THEN LineTotalNetUSD ELSE 0 END) as DischargeCosts,#(lf)#(tab)CAST(ROUND(SUM(CASE WHEN [PNL Code] = 1201 THEN LineTotalNetUSD ELSE 0 END) / NULLIF(SUM(orderquantity), 0), 2) AS FLOAT) as [demurrage / Despatch],#(lf)#(tab)CAST(ROUND(SUM(CASE WHEN [PNL Code] = 1111 THEN LineTotalNetUSD ELSE 0 END) / NULLIF(SUM(orderquantity), 0), 2) AS FLOAT) as [Shortage],#(lf)#(tab)CAST(ROUND(SUM(CASE WHEN [PNL Code] not in (1010,2270,1201,1111) THEN LineTotalNetUSD ELSE 0 END) / NULLIF(SUM(orderquantity), 0), 2) AS FLOAT) as [Other_Expenses],#(lf)#(tab)sum (orderquantity) as orderquantity,#(lf)#(tab)sum(LineTotalNetUSD) as LineTotalNetUSD,#(lf)#(tab)CAST(ROUND(#(lf)#(tab)#(tab)SUM(CASE WHEN PNLKey = 999 THEN LineTotalNetUSD ELSE 0 END)#(lf)#(tab)#(tab)/ NULLIF(SUM(CASE WHEN PNLKey = 999 THEN OrderQuantity ELSE 0 END), 0)#(lf)#(tab), 2) AS FLOAT) AS Cif_price,#(lf)#(tab)MAX(pe.NEW_SHER) AS NEW_SHER#(lf)  from purchase_orders pe#(lf)  LEFT JOIN po_doctype dt ON dt.PurchaseOrderID = pe.PurchaseOrderID#(lf)  group by pe.PurchaseOrderID, dt.DocName#(lf)  )#(lf),sales as (#(lf)  SELECT #(lf)#(tab)'Invoice' AS 'DocName'#(lf)#(tab)#(tab),Case#(lf)#(tab)#(tab)#(tab)WHEN CS.QOD_MOTSR = TM.QOD_MOTSR#(lf)#(tab)#(tab)#(tab)#(tab)THEN 'Item'#(lf)#(tab)#(tab)#(tab)ELSE 'Additional Expense'#(lf)#(tab)#(tab)END AS 'LineType'#(lf)#(tab)#(tab),CONVERT(VARCHAR,CS.QOD_LQOCH) 'AccountKey' -- customer from invoices in case you need just invoices #(lf)#(tab)#(tab),SUBSTRING(CS.T_CHSHBONIT,1,4) + '-' + SUBSTRING(CS.T_CHSHBONIT,5,2) + '-' + SUBSTRING(CS.T_CHSHBONIT,7,2) AS 'Date' -- Invoice date  #(lf)#(tab)#(tab),CAST(CONVERT(INT, CONVERT(VARCHAR,AM