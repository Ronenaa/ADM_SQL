		lineageTag: 571343e0-3db3-4542-93ed-773d30086b6d

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Shortage qty non dates' = ```
			
			 CALCULATE(
			    [Total Quantity Adjustment (Gain)],
			    factGain[QuantityCategory] = "Shortage",
			    REMOVEFILTERS(dimDates)
			)
			```
		displayFolder: Ship_Details
		lineageTag: d4ed0949-b776-4d0f-84a0-fb06facf9428

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'AVG unit price sales' = ```
			
			CALCULATE(
			    DIVIDE(
			        [Total Net USD],
			        [Sales Qty (Exceution)] 
			    ),
			    factGain[LineType] = "Item" && 
			    factGain[QuantityCategory] = "Sales"
			)
			
			```
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		lineageTag: 4f2a4f40-7cf2-4988-bb65-33fc3cce48ae

	measure 'Gain per Ton non dates' =
			
			CALCULATE(
			    [Gain per Ton new],
