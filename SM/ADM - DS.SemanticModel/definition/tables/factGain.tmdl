b)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS [Price Term],#(lf)#(tab)s.Quantity#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS [Quantity],#(lf)#(tab)s.Quantity#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS PurchaseQuantity,#(lf)    s.LineTotalNet_USD#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS [LineTotalNet_USD],#(lf)    CASE WHEN s.Quantity > 0#(lf)         THEN CAST(ROUND((s.LineTotalNet_USD - s.AdditionalLineCost) / NULLIF(s.Quantity, 0), 2) AS FLOAT)#(lf)         ELSE NULL END                                                                                                      AS Item_Price,#(lf)    CASE WHEN s.AdditionalQuantity > 0#(lf)         THEN CAST(ROUND(s.AdditionalLineCost / NULLIF(s.AdditionalQuantity, 0), 2) AS FLOAT)#(lf)         ELSE NULL END                                                                                                      AS Storage_Price,#(lf)    CASE WHEN s.AdjustmentFlag <> 1#(lf)         THEN CAST(ROUND(#(lf)             (s.LineTotalNet_USD - s.AdditionalLineCost) / NULLIF(s.Quantity, 0) +#(lf)             ISNULL(s.AdditionalLineCost / NULLIF(s.AdditionalQuantity, 0), 0),#(lf)             2) AS FLOAT)#(lf)         ELSE NULL END                                                                                                      AS Total_Price,#(lf)    s.UnitNetPriceUSD#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS [UnitNetPriceUSD],#(lf)    NULL#(tab)#(tab)#(tab)#(tab)#(tab)#(ta