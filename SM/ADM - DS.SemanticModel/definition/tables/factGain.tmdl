#(tab)#(tab)#(tab)#(tab)#(tab)AS DeliveryDate,#(lf)#(tab)case when s.SalesType is null then s.QuantityCategory#(lf)#(tab)#(tab) else s.SalesType end#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS [Price Term],#(lf)#(tab)s.Quantity#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS Quantity,#(lf)#(tab)case when s.rn = 1#(lf)#(tab)then PC.orderquantity else 0 end#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS PurchaseQuantity,#(lf)#(tab)s.LineTotalNet_USD#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS LineTotalNet_USD,#(lf)#(tab)NULL#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS Item_Price,#(lf)#(tab)NULL#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS Storage_Price,#(lf)#(tab)CASE WHEN s.AdjustmentFlag <> 1#(lf)#(tab)#(tab) THEN CAST(ROUND(s.LineTotalNet_USD / NULLIF(s.Quantity, 0), 2) AS FLOAT)#(lf)#(tab)#(tab) ELSE NULL END#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS Total_Price,#(lf)#(tab)s.UnitNetPriceUSD#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS UnitNetPriceUSD,#(lf)#(tab)case when s.rn = 1#(lf)#(tab)then PC.Cif_price else 0 end#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS CIF_Purchase,#(lf)#(tab)case when s.rn = 1#(lf)#(tab)then PC.[demurrage / Despatch] else 0 end#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS [demurrage / Despatch],#(lf)#(tab)CASE WHEN s.rn = 1 THEN PC.[Other_Expenses]     ELSE 0 END#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS [Other_Expenses],#(lf)#(tab)CASE WHEN s.rn = 1 THEN PC.Shortage            ELSE 0 END#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS Shortage,#(lf)#(tab)CASE WHEN s.rn = 1 THEN#(lf)#(tab)#(tab)CAST(ROUND(PC.DischargeCosts /#(lf)#(tab)#(tab)#(tab)NULLIF(PC.orderquantity, 0), 2) AS FLOAT)#(lf)#(tab)ELSE 0 END#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS DischargeCost,#(lf)#(tab)CASE WHEN s.rn = 1 THEN#(lf)#(tab)#(tab)CAST(ROUND(PC.Cif_price + PC.[demurrage / Despatch] + (PC.DischargeCosts /#(lf)#(tab)#(tab)#(tab)NULLIF(PC.orderquantity, 0)), 2) AS FLOAT)#(lf)#(tab)ELSE 0 END#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS FOT_Purchase,#(lf)#(tab)null#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS Total_WH_cost,#(lf)#(tab)CAST(ROUND(CASE#(lf)#(tab)#(tab)WHEN s.SalesType = 'CIF'                   AND s.LineType = 'Item'#(lf)#(tab)#(tab)#(tab)THEN (s.LineTotalNet_USD / NULLIF(s.Quantity, 0)) - PC.Cif_price#(lf)#(tab)#(tab)WHEN s.SalesType IN ('FOT', 'FOT Premium') AND s.LineType = 'Item'#(lf)#(tab)#(tab)#(tab)THEN (s.LineTotalNet_USD / NULLIF(s.Quantity, 0)) - (PC.Cif_price + PC.[demurrage / Despatch] + (PC.DischargeCosts /#(lf)#(tab)#(tab)#(tab)#(tab) NULLIF(PC.orderquantity, 0)))#(lf)#(tab)#(tab)ELSE 0#(lf)#(tab)END, 2) AS FLOAT)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS Gain,#(lf)#(tab)CAST(ROUND(CASE#(lf)#(tab)#(tab)WHEN s.SalesType = 'CIF'                   AND s.LineType = 'Item'#(lf)#(tab)#(tab)#(tab)THEN ((s.LineTotalNet_USD / NULLIF(s.Quantity, 0)) - PC.Cif_price) * s.Quantity#(lf)#(tab)#(tab)WHEN s.SalesType IN ('FOT', 'FOT Premium') AND s.LineType = 'Item'#(lf)#(tab)#(tab)#(tab)THEN ((s.LineTotalNet_USD / NULLIF(s.Quantity, 0)) - (PC.Cif_price + PC.[demurrage / Despatch] + (PC.DischargeCosts /#(lf)#(tab)#(tab)#(tab)#(tab) NULLIF(PC.orderquantity, 0)))) * s.Quantity#(lf)#(tab)#(tab)ELSE 0#(lf)#(tab)END, 2) AS FLOAT)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS TotalGain,#(lf)#(tab)NULL#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS AdditionalLineCost#(lf)FROM (#(lf)    SELECT s.*,#(lf)           bl.PurchaseOrderID,#(lf)           ROW_NUMBER() OVER (PARTITION BY bl.PurchaseOrderID ORDER BY s.DeliveryNote ASC) AS rn#(lf)    FROM sales s#(lf)    INNER JOIN base_link bl ON bl.DeliveryNote = s.DeliveryNote#(lf)) s#(lf)LEFT JOIN  P_costs PC   ON PC.PurchaseOrderID = CAST(s.PurchaseOrderID AS VARCHAR(30))#(lf)WHERE PC.ValueDate IS NOT NULL#(lf)#(lf)UNION ALL#(lf)#(lf)-- ============================================================#(lf)-- Branch 2: Warehouse orders — cost from inv (LastCFPrice)#(lf)-- ============================================================#(lf)SELECT#(lf)    CAST(s.DeliveryNote AS VARCHAR)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)