e always in NIS#(lf)#(tab)#(tab),CONVERT(INT, CONVERT(VARCHAR,SUBSTRING(CS.T_CHSHBONIT,1,4) + SUBSTRING(CS.T_CHSHBONIT,5,2))) AS YearMonth#(lf)#(tab)#(tab), TM.MS_TEODH as 'DeliveryNote'#(lf)#(tab)#(tab),CASE#(lf)#(tab)#(tab)#(tab)WHEN SUBSTRING(TM.TARIKH_MSHLOCH,1,4) = '0000'#(lf)#(tab)#(tab)#(tab)#(tab)THEN CAST(SUBSTRING(CS.T_CHSHBONIT,1,4) + '-' + SUBSTRING(CS.T_CHSHBONIT,5,2) + '-' + SUBSTRING(CS.T_CHSHBONIT,7,2) as date)#(lf)#(tab)#(tab)#(tab)ELSE CAST(ISNULL(SUBSTRING(TM.TARIKH_MSHLOCH,1,4) + '-' + SUBSTRING(TM.TARIKH_MSHLOCH,5,2) + '-' + SUBSTRING(TM.TARIKH_MSHLOCH,7,2),#(lf)#(tab)#(tab)ISNULL(SUBSTRING(FTM.FirstDeliveryDateTM,1,4) + '-' + SUBSTRING(FTM.FirstDeliveryDateTM,5,2) + '-' + SUBSTRING(FTM.FirstDeliveryDateTM,7,2),#(lf)#(tab)#(tab)SUBSTRING(CS.T_CHSHBONIT,1,4) + '-' + SUBSTRING(CS.T_CHSHBONIT,5,2) + '-' + SUBSTRING(CS.T_CHSHBONIT,7,2)))#(lf)#(tab)#(tab)AS date) #(lf)#(tab)#(tab)END as 'DeliveryDate'#(lf)#(tab)#(tab),HZ.MSPR_HZMNH as 'OrderID'#(lf)#(tab)#(tab),TM.QOD_SHOLCH as 'SupplierWarehouse'#(lf)#(tab)#(tab),TM.ActionType#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)as 'ActionType'#(lf)#(tab)#(tab),CASE #(lf)#(tab)#(tab)#(tab)WHEN TM.ActionType = 6 THEN G.AOPI_PEILOT#(lf)#(tab)#(tab)#(tab)ELSE act.ActionType#(lf)#(tab)#(tab)END#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)as 'ActionTypeDesc'#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(lf)#(tab)#(tab),'0'#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)as 'AdjustmentFlag'#(lf)#(tab)#(tab),'Sales'#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)as  'QuantityCategory'#(lf)#(tab)#(tab),NULL#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)as  'TransactionType'  -- invoices are always direct sales#(lf)FROM CHSHBONIOT_COTROT CH#(lf)Left Join GORMIM G#(lf)#(tab)on CH.QOD_LQOCH = G.QOD_GORM#(lf)Left Join TBLT_ANSHI_MCIROT AM #(lf)#(tab)on AM.SHM_AISH_MCIROT = G.AISH_MCIROT_MTPL#(lf)LEFT JOIN CHSHBONIOT_SHOROT CS #(lf)    ON CH.MS_CHSHBONIT = CS.MS_CHSHBONIT#(lf)LEFT JOIN TEODOT_MSHLOCH TM #(lf)#(tab)ON CS.MS_T_MSHLOCH = TM.MS_TEODH#(lf)LEFT JOIN (SELECT MS_CHSHBONIT , Min (TM.TARIKH_MSHLOCH) as 'FirstDeliveryDateTM',Min (CHS.TARIKH_MSHLOCH) as 'FirstDeliveryDateCHS'#(lf)#(tab)#(tab)#(tab)FROM CHSHBONIOT_SHOROT CHS#(lf)#(tab)#(tab)#(tab)Left Join TEODOT_MSHLOCH TM#(lf)#(tab)#(tab)#(tab)#(tab)ON TM.MS_TEODH = CHS.MS_T_MSHLOCH#(lf)#(tab)#(tab)#(tab)Where 1=1#(lf)#(tab)#(tab)#(tab)AND TM.TARIKH_MSHLOCH <>00000000#(lf)#(tab)#(tab)#(tab)AND CHS.TARIKH_MSHLOCH <>00000000#(lf)#(tab)#(tab)#(tab)Group By CHS.MS_CHSHBONIT) FTM#(lf)#(tab)ON FTM.MS_CHSHBONIT = CH.MS_CHSHBONIT#(lf)Left Join (SELECT MS_HZMNH,MS_T_MSHLOCH#(lf)#(tab)#(tab)#(tab)FROM QISHOR_T_MSHLOCH_HZMNOT#(lf)#(tab)#(tab)#(tab)) HZT#(lf)#(tab)on TM.MS_TEODH = HZT.MS_T_MSHLOCH#(lf)Left Join HZMNOT HZ#(lf)#(tab)on HZ.MSPR_HZMNH = HZT.MS_HZMNH#(lf)left join TBLT_PEOLOT_HZMNH_T_MSHLOCH act#(lf)#(tab)on TM.ActionType = act.MS_AOPTSIH#(lf)left join CurrencyConvertion CC #(lf)#(tab)ON cs.[TARIKH_MSHLOCH] = cc.Tarikh#(lf)WHERE 1=1  #(lf)AND Cast(SUBSTRING(cs.T_CHSHBONIT,1,4) as int) >= 2025#(lf)AND TM.QOD_SHOLCH <> TM.QOD_MQBL #(lf)#(lf)-------OPEN Orders----------------------------------------------------------------------------------#(lf)UNION ALL#(lf)#(lf) SELECT #(lf)#(tab)'Delivery Note' as  'DocName'#(lf)#(tab),'Item' AS 'LineType'#(lf)#(tab),CONVERT(INT, CONVERT(VARCHAR, TM.QOD_MQBL)) AS 'AccountKey'#(lf)#(tab),SUBSTRING(TARIKH_MSHLOCH,1,4) + '-' + SUBSTRING(TARIKH_MSHLOCH,5,2) + '-' + SUBSTRING(TARIKH_MSHLOCH,7,2) as 'Date'#(lf)#(tab),CONVERT(INT, CONVERT(VARCHAR, TM.AISH_MCIROT)) AS 'AgentKey'#(lf)#(tab),CONVERT(VARCHAR, TM.QOD_MOTSR)+'-'+CONVERT(VARCHAR, TM.QOD_MOTSR) AS 'ItemKey'#(lf)#(tab),CAST(ROUND(CASE#(lf)#(tab)         WHEN TM.MTBE_SH = '$' THEN TM.MCHIR_ICH#(lf)#(tab)         ELSE TM.MCHIR_ICH * (1 / NULLIF(SM.NEW_SHER, 0))#(lf)         END, 2) AS FLOAT) AS 'UnitNetPriceUSD'#(lf)#(tab),cast(ROUND(TM.MSHQL_NTO,2)AS FLOAT) as 'Quantity'#(lf)#(tab),case#(lf)#(tab)#(tab)when TM.ActionType = 11 then TM.MSHQL_NTO#(lf)#(tab)#(tab)else 0 end#(lf)#(tab)as qty_cif#(lf)#(tab),case#(lf)#(tab)#(tab)when TM.ActionType = 1 then TM.MSHQL_NTO#(lf)#(tab)#(tab)else 0 end#(lf)#(tab)as qty_fot#(lf)#(tab),case#(lf)#(tab)#(tab)when TM.ActionType = 1 then 'FOT'#(lf)#(tab)#(tab)WHEN TM.ActionType = 11 then 'CIF'#(lf)#(tab)#(tab)WHEN TM.ActionType = 12 then 'FOT Premium'#(lf)#(tab)else null #(lf)#(tab)end as SalesType#(lf)#(tab),0 AS 'AdditionalQuantity'#(lf)#(tab),CAST(ROUND(CASE#(lf)#(tab)         WHEN TM.MTBE_SH = '$'#(lf)#(tab)#(tab)     THEN TM.MCHIR_ICH * TM.MSHQL_NTO /*TM.CMOT_SHSOPQH*/#(lf)#(tab)         ELSE TM.MCHIR_ICH * TM.MSHQL_NTO /*TM.CMOT_SHSOPQH*/ * (1 / NULLIF(SM.NEW_SHER, 0))#(lf)         END, 2) AS FLOAT) AS 'LineTotalNet_USD'#(lf)#(tab),CONVERT(INT, CONVERT(VARCHAR,SUBSTRING(T_ASPQH,1,4) + SUBSTRING(T_ASPQH,5,2))) AS YearMonth#(lf)#(tab),TM.MS_TEODH as 'DeliveryNote'#(lf)#(tab),CAST(SUBSTRING(TARIKH_MSHLOCH,1,4) + '-' + SUBSTRING(TARIKH_MSHLOCH,5,2) + '-' + SUBSTRING(TARIKH_MSHLOCH,7,2) as date) as 'DeliveryDate'#(lf)#(tab),HZ.MSPR_HZMNH as 'OrderID'#(lf)#(tab),TM.QOD_SHOLCH as 'SupplierWarehouse'#(lf)#(tab),TM.ActionType#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)as 'ActionType'#(lf)#(tab),CASE #(lf)#(tab)#(tab)WHEN TM.ActionType = 6 THEN G.AOPI_PEILOT#(lf)#(tab)#(tab)ELSE act.ActionType#(lf)#(tab)END as 'ActionTypeDesc'#(lf)#(tab),CASE#(lf)#(tab)WHEN TM.MCHIR_ICH = 0#(lf)#(tab)#(tab)THEN '1'#(lf)#(tab)ELSE '0'#(lf)#(tab)END AS 'AdjustmentFlag'#(lf)#(tab),CASE#(lf)#(tab)#(tab)WHEN TM.MCHIR_ICH <> 0 THEN 'Sales'#(lf)#(tab)#(tab)WHEN TM.MCHIR_ICH = 0 and G.AOPI_PEILOT = 'פחת' THEN 'Shortage'#(lf)#(tab)#(tab)WHEN TM.MCHIR_ICH = 0 and G.AOPI_PEILOT = 'אחסון' THEN 'Storage'#(lf)#(tab)#(tab)WHEN TM.MCHIR_ICH = 0 and G.AOPI_PEILOT NOT IN ('פחת','אחסון') then 'Swap'#(lf)#(tab)END AS 'QuantityCategory'#(lf)#(tab),CASE#(lf)#(tab)#(tab)WHEN TM.MCHIR_ICH = 0 AND W.QOD_GORM IS NOT NULL THEN G.AOPI_PEILOT#(lf)#(tab)#(tab)WHEN TM.MCHIR_ICH = 0 AND W.QOD_GORM IS NULL     THEN 'החלפה'#(lf)#(tab)#(tab)ELSE NULL#(lf)#(tab)END AS 'TransactionType'#(lf)FROM TEODOT_MSHLOCH TM#(lf)Left Join (SELECT distinct MS_T_MSHLOCH#(lf)#(tab)#(tab)#(tab)FROM CHSHBONIOT_SHOROT#(lf)#(tab)#(tab)) CH#(lf)#(tab)on TM.MS_TEODH = CH.MS_T_MSHLOCH#(lf)Left Join (SELECT MS_HZMNH,MS_T_MSHLOCH#(lf)#(tab)#(tab)#(tab)FROM QISHOR_T_MSHLOCH_HZMNOT#(lf)#(tab)#(tab)) HZT#(lf)#(tab)on TM.MS_TEODH = HZT.MS_T_MSHLOCH#(lf)Left Join HZMNOT HZ#(lf)#(tab)on HZ.MSPR_HZMNH = HZT.MS_HZMNH#(lf)LEFT JOIN CurrencyConvertion SM  -- reuse top-level CTE instead of repeating SHERI_MTBE inline#(lf)#(tab)ON SM.TARIKH = HZ.T_HZMNH#(lf)Left Join GORMIM G#(lf)#(tab)on TM.QOD_MQBL = G.QOD_GORM#(lf)Left Join (#(lf)#(tab)#(tab)#(tab)Select *#(lf)#(tab)#(tab)#(tab)From GORMIM#(lf)#(tab)#(tab)#(tab)Where EntityType Like N'%מקום אספקה%') W#(lf)#(tab)On W.QOD_GORM = TM.QOD_SHOLCH#(lf)left join TBLT_PEOLOT_HZMNH_T_MSHLOCH act#(lf)#(tab)on TM.ActionType = act.MS_AOPTSIH#(lf)WHERE#(lf)CH.MS_T_MSHLOCH is null#(lf)AND Cast(SUBSTRING(TARIKH_MSHLOCH,1,4) as int) >= 2025#(lf)AND STTOS in (0,1)#(lf)AND TM.PurchaseOrderType = 0#(lf)AND TM.QOD_SHOLCH <> TM.QOD_MQBL   -- exclude internal docs (same source and destination)#(lf)  )#(lf)#(lf)#(lf)#(lf)#(lf),base_link as (#(lf)  SELECT distinct#(lf)        a.MS_TEODT_MCIRH AS DeliveryNote,#(lf)        b.MS_HZMNH AS PurchaseOrderID#(lf)    FROM QISHOR_RCSH_LMCIRH a#(lf)    LEFT JOIN QISHOR_T_MSHLOCH_HZMNOT b#(lf)        ON a.MS_TEODT_RCSH = b.MS_T_MSHLOCH#(lf)#(lf)#(tab)#(tab))#(lf)#(lf)-- Warehouse sales: delivery notes that have no entry in base_link are not linked to any#(lf)-- purchase order, meaning they originate from a warehouse (not import or exchange).#(lf),WH_sales AS (#(lf)    SELECT#(lf)        s.DeliveryNote,#(lf)        s.DeliveryDate,#(lf)        FORMAT(s.DeliveryDate, 'yyyy-MM')                                           AS [Year-Month],#(lf)        s.AccountKey,#(lf)        s.AgentKey,#(lf)        s.ActionType,#(lf)        s.ActionTypeDesc,#(lf)        s.SupplierWarehouse,#(lf)        s.AdjustmentFlag,#(lf)        s.QuantityCategory,#(lf)        MAX(s.TransactionType)                                                      AS TransactionType,#(lf)        -- ItemKey, sale price, and SalesType come from the 'Item' line only#(lf)        MAX(CASE WHEN s.LineType = 'Item' THEN s.ItemKey        ELSE NULL END)      AS ItemKey,#(lf)        MAX(CASE WHEN s.LineType = 'Item' THEN s.SalesType      ELSE NULL END)      AS SalesType,#(lf)        MAX(CASE WHEN s.LineType = 'Item' THEN s.UnitNetPriceUSD ELSE NULL END)     AS UnitNetPriceUSD,#(lf)        -- Quantity = item qty only (excludes storage/additional-expense qty)#(lf)        SUM(CASE WHEN s.LineType = 'Item' THEN s.Quantity       ELSE 0   END)       AS Quantity,#(lf)        -- Total revenue = all lines combined (item + storage fee)#(lf)        SUM(s.LineTotalNet_USD)                                                     AS LineTotalNet_USD,#(lf)        -- Additional-line cost: the value of non-item lines (e.g. warehouse storage fee).#(lf)        -- Non-zero only when MultiLineFlag = 1; use this to compare WH additional costs vs other order types.#(lf)        SUM(CASE WHEN s.LineType <> 'Item' THEN s.LineTotalNet_USD ELSE 0 END)      AS AdditionalLineCost,#(lf)        SUM(s.AdditionalQuantity)                                                       AS AdditionalQuantity,#(lf)        -- 1 = delivery note had multiple lines (e.g. item + warehouse storage fee), 0 = single line#(lf)        CASE WHEN COUNT(*) > 1 THEN '1' ELSE '0' END                                   AS MultiLineFlag#(lf)    FROM sales s#(lf)    LEFT OUTER JOIN base_link bl ON bl.DeliveryNote = s.DeliveryNote#(lf)#(tab)WHERE s.SupplierWarehouse in (1144,1411,1367,1366,1289,1101,943)#(lf)    GROUP BY#(lf)        s.DeliveryNote, s.DeliveryDate,#(lf)        s.AccountKey, s.AgentKey,#(lf)        s.ActionType, s.ActionTypeDesc,#(lf)        s.SupplierWarehouse, #(lf)        s.AdjustmentFlag, s.QuantityCategory#(lf))#(lf)#(lf)-- ============================================================#(lf)-- Branch 1: Import / Exchange orders — cost from P_costs#(lf)-- ============================================================#(lf)SELECT#(lf)#(tab)cast(s.DeliveryNote as varchar)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS DeliveryNote,#(lf)#(tab)s.LineType#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS LineType,#(lf)#(tab)s.TransactionType#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS TransactionType,#(lf)#(tab)s.QuantityCategory#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS QuantityCategory,#(lf)#(tab)s.ActionTypeDesc#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS ActionTypeDesc,#(lf)#(tab)PC.DocName#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS Purchase_DocName,#(lf)#(tab)s.AdjustmentFlag#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS AdjustmentFlag,#(lf)#(tab)case when s.rn = 1#(lf)#(tab)#(tab) then '1' else '0' end#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS Qty_flag,#(lf)#(tab)'0'#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(t