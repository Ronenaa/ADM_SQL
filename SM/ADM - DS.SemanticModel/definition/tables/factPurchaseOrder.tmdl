	measure 'Total Purchases FOT Cost' =
			
			IF(HASONEVALUE(VAT_MeasureSelctionTable[ID ANALYSIS]),
			    SWITCH(MAX(VAT_MeasureSelctionTable[ID ANALYSIS]),
			        1,SUM(factPurchaseOrder[LineTotalFOT_USD]),
			        2,SUM(factPurchaseOrder[LineTotalFOT_NIS])
			    ),
			   SUM(factPurchaseOrder[LineTotalFOT_USD]))
