ER -- ronen#(lf)#(tab)#(tab),CASE #(lf)#(tab)#(tab)#(tab)WHEN POB.FinalWeightReceived = 0#(lf)#(tab)#(tab)#(tab)#(tab)THEN Case #(lf)#(tab)#(tab)#(tab)#(tab)#(tab)WHEN POB.OriginalWeightOrderd <> 0#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)THEN POB.OriginalWeightOrderd#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)ELSE POL.POL_QuantityOrdered#(lf)#(tab)#(tab)#(tab)#(tab)END#(lf)#(tab)#(tab)#(tab)ELSE POL_FinalWeightReceived#(lf)#(tab)#(tab)END AS 'Quantity'#(lf)#(tab)#(tab),POB.Balance AS 'Balance'#(lf)#(tab)#(tab),NULL AS 'LineTotalCost'#(lf)#(tab)#(tab),CASE#(lf)#(tab)         WHEN POL_Currency = '$' THEN POL_TotalPrice#(lf)#(tab)#(tab)#(tab) WHEN POL_Currency = 'Eur' THEN POL_TotalPrice *( SM.NEW_SHEREURO/SM.NEW_SHER)#(lf)#(tab)         ELSE POL_TotalPrice*(1/CASE WHEN SM.NEW_SHER <> 0 THEN SM.NEW_SHER ELSE 1 END)#(lf)         END AS 'LineTotalNetUSD'#(lf)#(tab)#(tab),CASE#(lf)#(tab)         WHEN POL_Currency = '$' THEN POB.Balance * POL.POL_FinalPrice#(lf)#(tab)#(tab)     --THEN (POL.POL_OriginalWeightOrderd - POB.TotalSupplied) * POL.POL_FinalPrice #(lf)#(tab)#(tab)#(tab) WHEN POL_Currency = 'Eur' THEN POB.Balance*(POL.POL_FinalPrice *( SM.NEW_SHEREURO/SM.NEW_SHER))#(lf)#(tab)         --ELSE (POL.POL_OriginalWeightOrderd - POB.TotalSupplied)*POL.POL_FinalPrice*(1/CASE WHEN SM.NEW_SHER <> 0 THEN SM.NEW_SHER ELSE 1 END)#(lf)#(tab)#(tab)#(tab) ELSE POB.Balance*POL.POL_FinalPrice*(1/CASE WHEN SM.NEW_SHER <> 0 THEN SM.NEW_SHER ELSE 1 END)#(lf)         END AS 'LineTotalBalanceUSD'#(tab)#(lf)#(tab)#(tab)--, (round(ii.IVCOST, 2)/ii.IEXCHANGE) *fnc.EXCHANGE2   *(CASE WHEN (i.DEBIT = 'C') THEN - 1 ELSE 1 END) AS 'LineTotalNet_USD'#(lf)#(tab)#(tab),CASE#(lf)#(tab)         WHEN POL_Currency = '$' THEN POL.POL_FinalPrice*SM.NEW_SHER#(lf)#(tab)#(tab)#(tab) WHEN POL_Currency = 'Eur' THEN POL.POL_FinalPrice*SM.NEW_SHEREURO#(lf)#(tab)         ELSE POL.POL_FinalPrice#(lf)         END AS 'UnitNetPriceNIS'#(lf)#(tab)    ,CASE#(lf)#(tab)         WHEN POL_Currency = '$' THEN POL_TotalPrice*SM.NEW_SHER #(lf)#(tab)#(tab)#(tab) WHEN POL_Currency = 'Eur' THEN POL_TotalPrice*SM.NEW_SHEREURO#(lf)#(tab)         ELSE POL_TotalPrice#(lf)         END AS 'LineTotalNetNIS'#(lf)#(tab)#(tab) /*,CASE#(lf)#(tab)         WHEN POL_Currency = '$'#(lf)#(tab)#(tab)     THEN POL.POL_FinalPrice*SM.NEW_SHER*(POL.POL_OriginalWeightOrderd - POL.POL_FinalWeightReceived)#(lf)#(tab)         ELSE POL.POL_FinalPrice*(POL.POL_OriginalWeightOrderd - POL.POL_FinalWeightReceived)#(lf)         END AS 'LineTotalBalanceNIS'*/#(lf)#(tab)#(tab) ,CASE#(lf)#(tab)         WHEN POL_Currency = '$' THEN POL.POL_FinalPrice*SM.NEW_SHER*POB.Balance--(POL.POL_OriginalWeightOrderd - POB.TotalSupplied)#(lf)#(tab)#(tab)#(tab) WHEN POL_Currency = 'Eur' THEN POL.POL_FinalPrice*SM.NEW_SHEREURO*POB.Balance#(lf)#(tab)         ELSE POL.POL_FinalPrice*POB.Balance--(POL.POL_OriginalWeightOrderd - POB.TotalSupplied)#(lf)         END AS 'LineTotalBalanceNIS'#(lf)#(tab)#(tab) #(lf)#(tab)#(tab) --,Op.CFFlat AS 'UnitPriceCF'#(lf)#(tab)#(tab) --,Op.CFFlat*OriginalQty AS 'LineTotalCF_USD'#(lf)#(tab)#(tab) ,OP.CFFlat*DollarRate*OriginalQty AS 'LineTotalCF_NIS'#(lf)#(tab)#(tab) --,OP.FotPrice AS 'UnitPriceFOT'#(lf)#(tab)#(tab) --Op.FotPrice*OriginalQty AS 'LineTotalFOT_USD'#(lf)#(tab)#(tab) ,OP.FotPrice*DollarRate*OriginalQty AS 'LineTotalFOT_NIS'#(lf)#(tab)#(tab) --,CFPremium AS 'UnitPricePremium'#(lf)#(tab)#(tab) --,Op.CFPremium*OriginalQty AS 'LineTotalPremium_USD'#(lf)#(tab)#(tab) --,OP.CFPremium*DollarRate*OriginalQty AS 'LineTotalPremium_NIS'#(lf)#(tab)#(tab) #(lf)#(tab)#(tab) ,Op.CFFlat*Op.Balance AS 'LineTotalBalanceCF_USD_'#(tab)#(tab)-----------------#(lf)#(tab)#(tab) ,OP.CFFlat*DollarRate*Op.Balance AS 'LineTotalBalanceCF_NIS'#(lf)#(tab)#(tab) ,Op.FotPrice*Op.Balance AS 'LineTotalBalanceFOT_USD_'   ---------------#(lf)#(tab)#(tab) ,OP.FotPrice*DollarRate*Op.Balance AS 'LineTotalBalanceFOT_NIS'#(lf)#(tab)#(tab) ,Op.CFPremium*Op.Balance AS 'LineTotalBalancePremium_USD'#(lf)#(tab)#(tab) ,OP.CFPremium*DollarRate*Op.Balance AS 'LineTotalBalancePremium_NIS'#(lf)#(lf)#(lf)#(tab)#(tab) ,Case#(lf)#(tab)#(tab)#(tab)WHEN CFPremium <>0#(lf)#(tab)#(tab)#(tab)#(tab)THEN 1#(lf)#(tab)#(tab)#(tab)ELSE 0#(lf)#(tab)#(tab)END AS 'PremiumFlag' #(lf)#(tab)#(tab),CONCAT(YEAR(PO.PO_OrderCreateDate),FORMAT(PO.PO_OrderCreateDate,'MM')) AS YearMonth#(lf)#(tab)#(tab),POL.POL_OrderLineStatus as 'OrderStatus'#(lf)#(tab)#(tab),CASE WHEN POL.POL_OrderLineStatus BETWEEN 10 AND 29 THEN 'Open' #(lf)#(tab)#(tab)      --WHEN POL.POL_OrderLineStatus BETWEEN 30 AND 39 THEN 'Canceled'#(lf)#(tab)#(tab)#(tab)  ELSE 'Closed'#(lf)#(tab)#(tab)#(tab)  END AS 'OrderLineStatus'#(lf)#(tab)#(tab),OP.ActionType AS 'TransactionType'#(lf)#(tab)#(tab)--,POL.POL_TotalOpenContract as toc#(lf)#(tab)#(tab)--,POL.POL_TotalInProcessContract tipc#(lf)#(tab)#(tab)--,POL.POL_TotalClosedContract tcc#(lf)#(tab)#(tab)--,POL.POL_totalContracts tc#(lf)#(tab)#(tab),t.PO_Family#(lf)#(tab)#(tab),CASE #(lf)#(tab)#(tab)#(tab)WHEN POL.POL_OrderLineStatus NOT IN (10,15)#(lf)#(tab)#(tab)#(tab)#(tab)THEN NULL#(lf)#(tab)#(tab)#(tab)WHEN t.PO_Family = 2#(lf)#(tab)#(tab)#(tab)#(tab)THEN CASE#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)WHEN POL.POL_totalContracts <> 0 #(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)THEN CAST((CAST(POL.POL_TotalOpenContract as decimal(18,2))+CAST(POL.POL_TotalInProcessContract as decimal(18,2)))/CAST(POL.POL_totalContracts as decimal(18,2)) AS decimal(18,2))--*POL.POL_QuantityOrdered ---- כמות שלא תומחרה =כמות הזמנה כפול(סך הכל חוזים אפשריים - חוזים שנחתמו חלקי סך כל החוזים האפשריים#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)ELSE 1--POL.POL_QuantityOrdered#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)END#(lf)#(tab)#(tab)#(tab)WHEN t.PO_Family = 1#(lf)#(tab)#(tab)#(tab)#(tab)Then Null#(lf)#(tab)#(tab)#(tab)ELSE NULL#(lf)#(tab)#(tab)END AS 'Basis'#(lf)#(tab)#(tab),CASE #(lf)#(tab)#(tab)#(tab)WHEN POL.POL_OrderLineStatus NOT IN (10,15)#(lf)#(tab)#(tab)#(tab)#(tab)Then 1--POL.POL_QuantityOrdered#(lf)#(tab)#(tab)#(tab)WHEN t.PO_Family = 2#(lf)#(tab)#(tab)#(tab)#(tab)THEN CASE#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)WHEN POL.POL_totalContracts <> 0#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)THEN CAST(CAST(POL.POL_TotalClosedContract as decimal(18,2))/CAST(POL.POL_totalContracts as decimal(18,2)) as decimal(18,2))---*POL.POL_QuantityOrdered ---- כמות שתומחרה =כמות הזמנה כפול חוזים שנחתמו חלקי סך כל החוזים האפשריים#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)ELSE NULL#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)END#(lf)#(tab)#(tab)#(tab)WHEN t.PO_Family = 1#(lf)#(tab)#(tab)#(tab)#(tab)Then 1 ----POL.POL_QuantityOrdered#(lf)#(tab)#(tab)#(tab)ELSE 1 ----POL.POL_QuantityOrdered#(lf)#(tab)#(tab)END AS 'Flat'#(lf)----------------------#(lf)#(tab)#(tab),CASE #(lf)#(tab)#(tab)#(tab)WHEN POL.POL_OrderLineStatus NOT IN (10,15)#(lf)#(tab)#(tab)#(tab)#(tab)THEN NULL#(lf)#(tab)#(tab)#(tab)WHEN t.PO_Family = 2#(lf)#(tab)#(tab)#(tab)#(tab)THEN CASE#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)WHEN POL.POL_totalContracts <> 0 #(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)THEN (POL.POL_TotalOpenContract)* pr.QtyTonePerContract--*POL.POL_QuantityOrdered ---- כמות שלא תומחרה =כמות הזמנה כפול(סך הכל חוזים אפשריים - חוזים שנחתמו חלקי סך כל החוזים האפשריים   THEN (POL.POL_TotalOpenContract+POL.POL_TotalInProcessContract)* pr.QtyTonePerContract#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)ELSE POL.POL_TotalClosedContract * pr.QtyTonePerContract--POL.POL_QuantityOrdered#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)END#(lf)#(tab)#(tab)#(tab)WHEN t.PO_Family = 1#(lf)#(tab)#(tab)#(tab)#(tab)Then Null#(lf)#(tab)#(tab)#(tab)ELSE NULL#(lf)#(tab)#(tab)END AS 'BasisQ'#(lf)#(tab)#(tab),CASE #(lf)#(tab)#(tab)#(tab)WHEN POL.POL_OrderLineStatus NOT IN (10,15)#(lf)#(tab)#(tab)#(tab)#(tab)Then POB.Balance--POL.POL_TotalOpenContract * pr.QtyTonePerContract#(lf)#(tab)#(tab)#(tab)WHEN t.PO_Family = 2#(lf)#(tab)#(tab)#(tab)#(tab)THEN CASE#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)WHEN POL.POL_totalContracts <> 0#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)--THEN CAST(CAST(POL.POL_TotalClosedContract as decimal(18,2))/CAST(POL.POL_totalContracts as decimal(18,2)) as decimal(18,2))---*POL.POL_QuantityOrdered ---- כמות שתומחרה =כמות הזמנה כפול חוזים שנחתמו חלקי סך כל החוזים האפשריים#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)THEN POL.POL_TotalClosedContract * pr.QtyTonePerContract#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)ELSE NULL#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)END#(lf)#(tab)#(tab)#(tab)WHEN t.PO_Family = 1#(lf)#(tab)#(tab)#(tab)#(tab)Then POB.Balance --POL.POL_totalContracts * pr.QtyTonePerContract----POL.POL_QuantityOrdered --- פה לקוחת כמיות FLAT של כלל ההזמנה#(lf)#(tab)#(tab)#(tab)ELSE  POB.Balance--POL.POL_totalContracts ----POL.POL_QuantityOrdered#(lf)#(tab)#(tab)END AS 'FlatQ'#(lf)-------------------#(lf)#(lf)#(tab)#(tab),POL_StockExchangeDate#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)as StockExchangeMonth#(lf)#(tab)#(tab),(POL_StockMarketPrice+POL_PremiumPrice)*sf.PF_GeneralFactor#(tab)as PricedContractsAvgPrice#(lf)#(tab)#(tab),sf.PF_GeneralFactor#(lf)#(tab)#(tab),POL_PremiumPrice#(lf)#(tab)#(tab),POL_UnitPrice#(lf)#(tab)#(tab),POL_StockMarketTempPrice#(lf)#(tab)#(tab),POL_StockMarketPrice#(lf)#(tab)#(tab),POL_FinalPrice#(lf)#(tab)#(tab),smp.SMP_Symbol#(lf)#(tab)#(tab),smpe.SMPE_TempPrice#(lf)#(tab)#(tab),OP.CFFlat#(lf)#(tab)#(tab),OP.CFFLAT_CC#(lf)#(tab)#(tab),OP.CFFLAT_NCC#(lf)#(tab)#(tab),OP.FotPrice#(lf)#(tab)#(tab),OP.FOT_CC#(lf)#(tab)#(tab),OP.FOT_NCC#(lf)#(tab)#(tab),OP.OriginalQty #(lf)#(tab)#(tab),POL.POL_StockMarketTempPriceForNoneClosed  as MarketTempPrice#(lf)#(tab)#(tab),POL_FinalPriceForClosedContract#(tab)#(tab)#(tab)as FinalPriceClosedContract#(lf)#(tab)#(tab),sl.ShipDesc#(lf)#(tab)#(tab),sa.SA_ShipLoadingPort#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)as Loading_Port#(lf)#(tab)#(tab),sa.SA_DateForLoadingFrom#(tab)#(tab)#(tab)#(tab)#(tab)as Arrival_From#(lf)#(tab)#(tab),sa.SA_DateForLoadingUntil#(tab)#(tab)#(tab)#(tab)#(tab)as Arrival_To#(lf)#(tab)#(tab),cl.CO_CountryNameENG#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)as OriginCountry#(lf)#(tab)#(tab),sa.SA_ActualETA#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)as ActualETA#(lf)#(tab)#(tab),sa.SA_ActualETB#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)as ActualETB#(lf)#(tab)#(tab),pos.PO_StatusDesc#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)as PurchaseOrderStatus#(lf)FROM PurchaseOrder PO#(lf)LEFT JOIN PurchaseOrderLines POL ON PO.PO_OrderID=POL.POL_OrderID#(lf)LEFT JOIN CurrencyConvertion SM #(lf)#(tab)ON SM.TARIKH=CAST(PO.PO_OrderCreateDate AS date)#(lf)Left Join viewPurchaseOrderBalance POB#(lf)#(tab)ON POL.POL_OrderID = POB.POID AND POL.POL_LineID = POB.POLineID#(lf)Left Join OrderPrices OP#(lf)#(tab)ON op.OrderID = PO.PO_OrderID AND op.OrderIDLine = POL.POL_LineID#(lf)LEFT JOIN PurchaseOrderTypes t#(lf)#(tab)ON t.PO_TypeID = OP.ActionType#(lf)left join StockMarketProduct smp#(lf)#(tab)on POL.POL_ProductID = smp.SMP_ProductID AND MONTH(POL.POL_StockExchangeDate) = smp.SMP_MonthID#(lf)left join MOTSRIM PR#(lf)#(tab)on PR.QOD_MOTSR = POL.POL_ProductID#(lf)left join ProductStockMarketFactors sf#(lf)#(tab)on pol.POL_ProductID = sf.PF_ProductID and POL.POL_FactorCode = sf.PF_FactorID #(lf)left join (select * from SMPE where  rownum = 1) smpe#(lf)#(tab)on POL.POL_ProductID = smpe.SMPE_ProductID AND YEAR(POL.POL_StockExchangeDate) = smpe.SMPE_Year AND MONTH(POL.POL_StockExchangeDate) = smpe.SMPE_Month#(lf)#(lf)LEFT JOIN ShipsArrivals sa ON POL.POL_ShipArrivalID = sa.SA_ID#(lf)LEFT JOIN ShipList sl ON sa.SA_ShipID = sl.ShipID#(lf)LEFT JOIN tblCountryList cl ON sa.SA_CountryOfOrigin = cl.CO_CountryID#(lf)LEFT JOIN PurchaseOrderStatus pos ON POL.POL_ContractStage = pos.PO_StatusID#(lf)#(lf)WHERE YEAR(PO.PO_OrderCreateDate)>=2018 and YEAR(PO.PO_OrderCreateDate) <= Year(Getdate())#(lf)--AND HZ.OrderStatus<>3#(lf)--AND HZ.ActionType IN(2,10)#(lf)and POL.POL_OrderLineStatus NOT BETWEEN 30 AND 39 --- לבטל לפני #(lf)#(lf)--and POL.POL_FinalWeightReceived <>0#(lf) #(lf)--and PO.PO_OrderID = 2000360#(lf)#(lf))#(lf)#(lf)SELECT#(tab)P.*#(lf)#(tab)#(tab)--Basis*Balance AS BasisQTY,#(lf)#(tab)#(tab)--Flat*Balance AS FlatQTY,#(lf)#(tab)#(tab),p.BasisQ#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS BasisQTY#(lf)#(tab)#(tab),p.FlatQ#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS FlatQTY#(lf)#(tab)#(tab)--,(PF_GeneralFactor*(SMPE_TempPrice+POL_PremiumPrice))*p.BasisQ#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS LineTotalFlatValueBalanceUSD#(lf)#(tab)#(tab)--,(PF_GeneralFactor*(POL_StockMarketPrice+POL_PremiumPrice))*p.FlatQ#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS LineTotalFlatBalanceUSD#(lf)#(tab)#(tab)    -- New computed field: if PremiumFlag = 1 then multiply FlatQTY by FinalPriceClosedContract, otherwise use LineTotalNetUSD#(lf)    ,CASE #(lf)        WHEN p.PremiumFlag = 1 THEN p.FlatQ * p.FinalPriceClosedContract#(lf)        ELSE p.LineTotalBalanceUSD#(lf)    END AS LineTotalFlatBalanceUSD,#(lf)#(lf)#(tab)------#(lf)    CASE #(lf)        WHEN p.PremiumFlag = 1 THEN p.FlatQ * p.FOT_CC#(lf)        ELSE LineTotalBalanceFOT_USD_#(lf)    END AS LineTotalBalanceFOT_USD,#(lf)#(lf)#(tab)CASE #(lf)        WHEN p.PremiumFlag = 1 THEN p.FlatQ  * p.CFFLAT_CC#(lf)        ELSE LineTotalBalanceCF_USD_#(lf)    END AS LineTotalBalanceCF_USD,#(lf)#(tab)---------#(lf)    -- New computed field: combine two calculations based on PremiumFlag#(lf)    (#(lf)      CASE #(lf)          WHEN p.PremiumFlag = 1 THEN p.BasisQ * p.MarketTempPrice#(lf)          ELSE 0#(lf)      END#(lf)      +#(lf)      CASE #(lf)          WHEN p.PremiumFlag = 1 THEN p.FlatQ * p.FinalPriceClosedContract #(lf)          ELSE p.LineTotalNetUSD * (p.FlatQ/p.OriginalQty)#(tab)#(tab)#(tab)#(tab)#(tab)-------------!!!!!!!******#(lf)      END#(lf)    ) AS LineTotalFlatValueUSD,#(lf)#(lf)    -- New computed field: choose CF unit price based on PremiumFlag#(lf)    CASE #(lf)        WHEN p.PremiumFlag = 1 THEN p.CFFLAT_CC #(lf)        ELSE p.CFFlat #(lf)    END AS UnitPriceCF,#(lf)#(lf)    -- New computed field: calculate CF total in USD#(lf)    CASE #(lf)        WHEN p.PremiumFlag = 1 THEN p.CFFLAT_CC * p.FlatQ #(lf)        ELSE p.CFFlat * p.OriginalQty #(lf)    END AS LineTotalCF_USD,#(lf)#(lf)    -- New computed field: choose FOT unit price based on PremiumFlag#(lf)    CASE #(lf)        WHEN p.PremiumFlag = 1 THEN p.FOT_CC #(lf)        ELSE p.FotPrice #(lf)    END AS UnitPriceFOT,#(lf)#(lf)    -- New computed field: calculate FOT total in USD#(lf)    CASE #(lf)        WHEN p.PremiumFlag = 1 THEN p.FOT_CC * p.FlatQ #(lf)        ELSE p.FotPrice * p.OriginalQty #(lf)    END AS LineTotalFOT_USD,#(lf)#(lf)    -- New computed field: use BasisQTY to compute flat value balance in USD#(lf)    p.MarketTempPrice * p.BasisQ AS LineTotalFlatValueBalanceUSD,#(lf)#(lf)    -- New computed field: MarketTempPriceCFF_USD (only when PremiumFlag = 1)#(lf)    CASE #(lf)        WHEN p.PremiumFlag = 1 THEN p.CFFLAT_NCC #(lf)        ELSE NULL #(lf)    END AS MarketTempPriceCFF_USD,#(lf)#(lf)    -- New computed field: multiply MarketTempPriceCFF_USD by BasisQTY#(lf)    CASE #(lf)        WHEN p.PremiumFlag = 1 THEN p.CFFLAT_NCC * p.BasisQ #(lf)        ELSE NULL #(lf)    END AS LineTotalFlatValueBalanceCFFUSD,#(lf)#(lf)    -- New computed field: MarketTempPriceFOT_USD (only when PremiumFlag = 1)#(lf)    CASE #(lf)        WHEN p.PremiumFlag = 1 THEN p.FOT_NCC #(lf)        ELSE NULL #(lf)    END AS MarketTempPriceFOT_USD,#(lf)#(lf)    -- New computed field: multiply MarketTempPriceFOT_USD by BasisQTY#(lf)    CASE #(lf)        WHEN p.PremiumFlag = 1 THEN p.FOT_NCC * p.BasisQ #(lf)        ELSE NULL #(lf)    END AS LineTotalFlatValueBalanceFOTUSD,#(lf)#(lf)    -- New computed field: combined calculation for CFF total value in USD#(lf)    CASE #(lf)        WHEN p.PremiumFlag = 1 THEN (p.CFFLAT_NCC * p.BasisQ) + (p.CFFLAT_CC * p.FlatQ)#(lf)        ELSE p.CFFlat * p.OriginalQty * (p.FlatQ/p.OriginalQty)#(tab)#(tab)#(tab)#(tab)#(tab)-------------!!!!!!!****** #(lf)    END AS LineTotalFlatValueCFFUSD,#(lf)#(lf)    -- New computed field: combined calculation for FOT total value in USD#(lf)    CASE #(lf)        WHEN p.PremiumFlag = 1 THEN (p.FOT_NCC * p.BasisQ) + (p.FOT_CC * p.FlatQ)#(lf)        ELSE p.FotPrice * p.OriginalQty * (p.FlatQ/p.OriginalQty)#(tab)#(tab)#(tab)#(tab)#(tab)-------------!!!!!!!****** #(lf)    END AS LineTotalFlatValueFOTUSD#(lf)#(lf)#(tab)#(tab),GETDATE()#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS RowInsertDatetime#(lf)FROM Purchases p#(lf)--where OrderID IN ('2000416','2000430','2000369','2000274','2000354','2000344','2000343','2000367','2000360') --'2000344'--'2000274'#(lf)--where OrderID IN ('2000484')--,'2000482')#(lf)#(lf)where (p.OriginalQty <> 0 OR p.OriginalQty IS NULL)#(lf)--and OrderID = 2000490"]),
