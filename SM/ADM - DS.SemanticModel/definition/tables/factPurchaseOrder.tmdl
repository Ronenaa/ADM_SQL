	measure 'Total Purchase Cost SWITCH Flat' =
			
			SWITCH(MIN(PriceType[ID]),
			1,SUM(factPurchaseOrder[LineTotalFlatBalanceUSD]),
			2,SUM(factPurchaseOrder[LineTotalBalanceCF_USD]),--SUM(factPurchaseOrder[LineTotalCF_USD]),
			3,SUM(factPurchaseOrder[LineTotalBalanceFOT_USD]),--SUM(factPurchaseOrder[LineTotalFOT_USD]),
			SUM(factPurchaseOrder[LineTotalFlatBalanceUSD])
			/*SWITCH(MIN(PriceType[ID]),
			1,[Total Purchases Cost Flat],
			--2,[Total Purchases CF Cost],
			--3,[Total Purchases FOT Cost],
			[Total Purchases Cost Flat]
			)*/)
		lineageTag: a4e39b9f-cc86-405f-a9c2-5349565fff6d

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Open Purchase Cost By Supply Date Flat' =
			
			CALCULATE([Total Purchase Cost SWITCH Flat],factPurchaseOrder[IsOpen]="1",USERELATIONSHIP(dimDates[Date],factPurchaseOrder[Supply Date]))
		lineageTag: 2e081b66-86f1-4e4a-ba12-0eb85a5c6122

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'All Open Purchase Cost By Supply Date - Risk Plan Flat' =
			
			VAR _MaxDate = MAX(dimDates[Date])
			return CALCULATE(
			    [Open Purchase Cost By Supply Date Flat]
			    ,FILTER(ALL(dimDates),dimDates[Date]<=_MaxDate),USERELATIONSHIP(dimDates[Date],factPurchaseOrder[Supply Date])
			)
		displayFolder: Risk Plan
		lineageTag: 22360c15-712e-44f5-b1e4-131115833cf7

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Purchase Cost Flat By Supply Date' = CALCULATE([Total Purchase Cost SWITCH Flat],factPurchaseOrder[IsOpen]="1",USERELATIONSHIP(dimDates[Date],factPurchaseOrder[Supply Date]))--
		lineageTag: 42393936-074d-4f9a-a7af-237640dde840

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Purchase Cost SWITCH Flat Value' =
			SWITCH(MIN(PriceType[ID]),
			1,SUM(factPurchaseOrder[LineTotalFlatValueBalanceUSD]),
			2,SUM(factPurchaseOrder[LineTotalFlatValueBalanceCFFUSD]),
			3,SUM(factPurchaseOrder[LineTotalFlatValueBalanceFOTUSD]),
			SUM(factPurchaseOrder[LineTotalFlatValueBalanceUSD])
			
			/*1,[Total Purchases Cost Flat Value],
			--2,[Total Purchases CF Cost],
			--3,[Total Purchases FOT Cost],
			[Total Purchases Cost Flat Value]
			)*/)
		lineageTag: 8e56c609-b11e-4faf-b4a6-aea3ab4eaf30

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Purchase Cost Flat Value By Supply Date' = CALCULATE([Total Purchase Cost SWITCH Flat Value],factPurchaseOrder[IsOpen]="1",USERELATIONSHIP(dimDates[Date],factPurchaseOrder[Supply Date]))
		lineageTag: 700eeb43-5f2c-44dc-9980-52fb15f8da6d

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Open Purchase Cost By Supply Date Flat Value' =
			
			CALCULATE([Total Purchase Cost SWITCH Flat Value],factPurchaseOrder[IsOpen]="1",USERELATIONSHIP(dimDates[Date],factPurchaseOrder[Supply Date]))
		lineageTag: a6e2e37d-4275-43f6-8033-3b53695cb4ba

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'All Open Purchase Cost By Supply Date - Risk Plan Flat Value' =
			
			VAR _MaxDate = MAX(dimDates[Date])
			return CALCULATE(
			    [Open Purchase Cost By Supply Date Flat Value]
			    ,FILTER(ALL(dimDates),dimDates[Date]<=_MaxDate),USERELATIONSHIP(dimDates[Date],factPurchaseOrder[Supply Date])
			)
		displayFolder: Risk Plan
		lineageTag: 559bfd73-dade-4493-b42a-1994bd410bff

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Avg Cost Price Supply Date - Risk Plan Flat Value' = ```
			
			VAR _MaxDate = CALCULATE(MAX(factPurchaseOrder[Supply Date]),USERELATIONSHIP(dimDates[Date],factPurchaseOrder[Supply Date]))
			VAR MinDate = MIN(dimDates[Date])
			
			var allOpenChosenMonth = 
			CALCULATE(
			    DIVIDE([Total Purchase Cost Flat Value By Supply Date],[Open Purchase Quantity Basis By Supply Date])
			    ,FILTER(ALL(dimDates),dimDates[Date]<=_MaxDate && dimDates[Date]>=MinDate)
			)
			
			var _Quantity = 
			--CALCULATE(SUM(factPurchaseOrder[Quantity]),factPurchaseOrder[IsOpen]="1",FILTER(ALL(dimDates),dimDates[Date]<=_MaxDate),USERELATIONSHIP(dimDates[Date],factPurchaseOrder[Supply Date]))
			CALCULATE(SUM(factPurchaseOrder[BasisQTY]),factPurchaseOrder[IsOpen]="1",FILTER(ALL(dimDates),dimDates[Date]<=_MaxDate),USERELATIONSHIP(dimDates[Date],factPurchaseOrder[Supply Date]))
			
			var firstMonth =
			CALCULATE(
			    DIVIDE([All Open Purchase Cost By Supply Date - Risk Plan Flat Value],_Quantity)
			    ,FILTER(ALL(dimDates),dimDates[Date]<=_MaxDate)-- && dimDates[Date]>=MinDate)
			)
			
			return 
			//allOpenChosenMonth
			IF(MAX(dimDates[Show Months])="This Month",firstMonth,allOpenChosenMonth)
			```
		displayFolder: Risk Plan
		lineageTag: adf28712-6516-4065-b29c-3ea3cc70d541

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Purchase Cost Flat+FlatValue SWITCH' =
			SWITCH(MIN(PriceType[ID]),
			1,SUM(factPurchaseOrder[LineTotalFlatValueUSD]),
			2,SUM(factPurchaseOrder[LineTotalFlatValueCFFUSD]),
			3,SUM(factPurchaseOrder[LineTotalFlatValueFOTUSD]),
			SUM(factPurchaseOrder[LineTotalFlatValueUSD])
			)
		lineageTag: 2ea4cce1-6ccb-498f-ba09-988c74c83c7f

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Avg Cost Price Flat+FlatValue' = DIVIDE([Total Purchase Cost Flat+FlatValue SWITCH] , [Total Purchase Quantity])
		lineageTag: 6c429ad9-9328-4061-88b0-3de35012213b

		changedProperty = IsHidden

