	measure 'Purchase - Risk Plan' = ```
			
			VAR _MaxDate = CALCULATE(MAX(factPurchaseOrder[Supply Date]),USERELATIONSHIP(dimDates[Date],factPurchaseOrder[Supply Date]))
			VAR MinDate = MIN(dimDates[Date])
			
			var allOpenChosenMonth = 
			CALCULATE(
			    [Open Purchase Quantity By Supply Date]
			    ,FILTER(ALL(dimDates),dimDates[Date]<=_MaxDate && dimDates[Date]>=MinDate)
			)
			return 
