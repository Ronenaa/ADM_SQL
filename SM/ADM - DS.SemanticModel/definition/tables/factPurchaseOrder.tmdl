	measure 'Avg Cost Price Supply Date - Risk Plan Flat' = ```
			
			VAR _MaxDate = CALCULATE(MAX(dimDates[Date]),USERELATIONSHIP(dimDates[Date],factPurchaseOrder[Supply Date]))
			VAR MinDate = MIN(dimDates[Date])
			
			var allOpenChosenMonth = 
			CALCULATE(
			    DIVIDE([Total Purchase Cost Flat By Supply Date],[Open Purchase Quantity Flat By Supply Date])
			    ,FILTER(ALL(dimDates),dimDates[Date]<=_MaxDate && dimDates[Date]>=MinDate)
			)
			
			var _Quantity = 
			--CALCULATE(SUM(factPurchaseOrder[Quantity]),factPurchaseOrder[IsOpen]="1",FILTER(ALL(dimDates),dimDates[Date]<=_MaxDate),USERELATIONSHIP(dimDates[Date],factPurchaseOrder[Supply Date]))
			CALCULATE(SUM(factPurchaseOrder[FlatQTY]),factPurchaseOrder[IsOpen]="1",FILTER(ALL(dimDates),dimDates[Date]<=_MaxDate),USERELATIONSHIP(dimDates[Date],factPurchaseOrder[Supply Date]))
			
			var firstMonth =
			CALCULATE(
			    DIVIDE([All Open Purchase Cost By Supply Date - Risk Plan Flat],_Quantity)
			    ,FILTER(ALL(dimDates),dimDates[Date]<=_MaxDate)-- && dimDates[Date]>=MinDate)
			)
			
			return 
			IF(MAX(dimDates[Show Months])="This Month",firstMonth,allOpenChosenMonth)
