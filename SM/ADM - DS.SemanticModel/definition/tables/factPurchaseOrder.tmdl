		changedProperty = IsHidden

	measure 'Avg Cost Price Supply Date SWITCH' =
			SWITCH(MIN(PriceType[ID]),
			1,[Avg Cost Price Supply Date],
			2,[Avg CF Cost Price Supply Date],
			3,[Avg FOT Cost Price Supply Date],
			[Avg Cost Price Supply Date]
			)
		formatString: \$#,0;(\$#,0);\$#,0
		lineageTag: b990e05f-2332-4cb4-97c9-c514682edba3

		changedProperty = IsHidden

	measure 'Avg Cost Price Supply Date - Risk Plan' = ```
			
			VAR _MaxDate = CALCULATE(MAX(dimDates[Date]),USERELATIONSHIP(dimDates[Date],factPurchaseOrder[Supply Date]))
			VAR MinDate = MIN(dimDates[Date])
			
			var allOpenChosenMonth = 
			CALCULATE(
			    DIVIDE([Open Purchase Cost By Supply Date],[Open Purchase Quantity Basis By Supply Date]+[Open Purchase Quantity Flat By Supply Date])
			    ,FILTER(ALL(dimDates),dimDates[Date]<=_MaxDate && dimDates[Date]>=MinDate)
			)
			    
			
			var _Quantity = --CALCULATE(([Total Purchase Quantity Flat] + [Total Purchase Quantity Basis]), USERELATIONSHIP(dimDates[Date],factPurchaseOrder[Supply Date]))
			--CALCULATE(SUM(factPurchaseOrder[Quantity]),factPurchaseOrder[IsOpen]="1",FILTER(ALL(dimDates),dimDates[Date]<=_MaxDate),USERELATIONSHIP(dimDates[Date],factPurchaseOrder[Supply Date])) -- before
			--CALCULATE(SUM(factPurchaseOrder[Balance]),factPurchaseOrder[IsOpen]="1",FILTER(ALL(dimDates),dimDates[Date]<=_MaxDate),USERELATIONSHIP(dimDates[Date],factPurchaseOrder[Supply Date]))
			CALCULATE([Open Purchase Quantity Basis By Supply Date]+[Open Purchase Quantity Flat By Supply Date]
			            ,factPurchaseOrder[IsOpen]="1"
			            ,FILTER(ALL(dimDates),dimDates[Date]<=_MaxDate)
			            ,USERELATIONSHIP(dimDates[Date],factPurchaseOrder[Supply Date])
			            )
			var firstMonth =
			CALCULATE(
			    DIVIDE([All Open Purchase Cost By Supply Date - Risk Plan],_Quantity)
			    ,FILTER(ALL(dimDates),dimDates[Date]<=_MaxDate)-- && dimDates[Date]>=MinDate)
			)
			
			return 
			IF(MAX(dimDates[Show Months])="This Month",firstMonth,allOpenChosenMonth)
			
			```
		displayFolder: Risk Plan
		lineageTag: 3049d6a5-288b-4489-8c23-89cc8ed9605c

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Avg Cost Price Open Supply Date' = DIVIDE([Open Purchase Cost By Supply Date] , [Open Purchase Quantity By Supply Date])
		formatString: \$#,0;(\$#,0);\$#,0
		lineageTag: b508c180-9270-4317-bd30-e4f1adb5b972

		changedProperty = IsHidden

	measure 'Open Purchase Quantity By Supply Date -' =
			
			VAR _MinO = CALCULATE(MIN(factOrders[תאריך אספקה]),ALL(dimDates),ALL(Sub_DimDates),factOrders[סטטוס]=1 || factOrders[סטטוס]=2)
			VAR _MaxO = CALCULATE(MAX(factOrders[תאריך אספקה]),ALL(dimDates),ALL(Sub_DimDates),factOrders[סטטוס]=1 || factOrders[סטטוס]=2)
			VAR _MinP = CALCULATE(MIN(factPurchaseOrder[Supply Date]),ALL(dimDates),ALL(Sub_DimDates),factPurchaseOrder[IsOpen]="1")
			VAR _MaxP = CALCULATE(MAX(factPurchaseOrder[Supply Date]),ALL(dimDates),ALL(Sub_DimDates),factPurchaseOrder[IsOpen]="1")
			VAR _Min = IF(_MinO<=_MinP,_MinO,_MinP)
			VAR _Max = IF(_MaxO>=_MaxP,_MaxO,_MaxP)
			
			
			RETURN
			SWITCH(TRUE(),
			MAX(DimDates[Date]) <_Min,BLANK(),
			MIN(DimDates[Date]) > _Max,BLANK(),
			[Open Purchase Quantity By Supply Date]=0,"-",
			[Open Purchase Quantity By Supply Date]
			)
		formatString: #,0.00
		lineageTag: a9b39dba-ffda-464f-9601-c2bcca0aeaf5

		changedProperty = IsHidden

