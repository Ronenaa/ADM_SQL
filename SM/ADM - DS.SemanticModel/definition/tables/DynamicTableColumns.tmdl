table DynamicTableColumns
	lineageTag: 8cd17312-12e0-4055-955a-c9b56fc250e5

	measure 'TooltipSwitch YTD' = ```
			
			    SWITCH(MIN(DynamicTableColumns[DynamicTableColumns]),
			        3,[Quantity Dynamic Table Switch 2Y YTD],
			        2,[Quantity Dynamic Table Switch LY YTD Visual],
			        4,[TargetToDate],
			        1,[Quantity Dynamic Table Switch]
			        )
			
			    
			```
		lineageTag: dd3758b9-4df8-4533-8065-d8587937ba7d

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'TooltipSwitch Full' = ```
			
			    SWITCH(MIN(DynamicTableColumns[Value5]),
			        3,[Quantity Dynamic Table Switch 2Y],
			        2,[Quantity Dynamic Table Switch LY No -],
			        4,[Total Target Current Year],
			        1,"-"
			        )
			
			```
		lineageTag: 3e0f3468-6d17-47c2-9ab3-9624400e1f0e

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'TooltipSwitch %' =
			
			SWITCH(MIN(DynamicTableColumns[DynamicTableColumns]),
			        1,Blank(),
			        3,
			        DIVIDE([Quantity Dynamic Table Switch]-[Quantity Dynamic Table Switch 2Y YTD],[Quantity Dynamic Table Switch 2Y YTD],BLANK()),
			        2,
			        DIVIDE([Quantity Dynamic Table Switch]-[Quantity Dynamic Table Switch LY YTD Visual],[Quantity Dynamic Table Switch LY YTD Visual],BLANK()),
			        4,
			        DIVIDE([Quantity Dynamic Table Switch]-[TargetToDate],[TargetToDate],BLANK())
			        )
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 5dca4a3c-b37c-413d-8248-26d095d00078

