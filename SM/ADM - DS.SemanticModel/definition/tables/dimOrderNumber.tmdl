	partition dimOrderNumber = m
		mode: import
		queryGroup: Dim
		source =
				let
				    Source = Sql.Database(#"SQL Address", "MT", [Query="select#(lf)#(tab)k_uniqueident as UniqeID#(lf)#(tab),CAST (MS_HZMNH as VARCHAR) as OrderID#(lf)#(tab),MS_T_MSHLOCH as DeliveryNote#(lf)from QISHOR_T_MSHLOCH_HZMNOT#(lf)#(lf)UNION#(lf)#(lf)SELECT #(lf)#(tab)#(tab)HZ.k_uniqueident as UniqeID#(lf)#(tab)#(tab),HZ.MSPR_HZMNH as OrderID#(lf)#(tab)#(tab),-ROW_NUMBER() OVER (ORDER BY HZ.k_uniqueident) as DeliveryNote#(lf)FROM [HZMNOT] HZ#(lf)left join QISHOR_T_MSHLOCH_HZMNOT HZT#(lf)on HZ.MSPR_HZMNH = HZT.MS_HZMNH#(lf)WHERE 1=1 #(lf)AND HZT.MS_T_MSHLOCH is null"])
				in
				    Source

