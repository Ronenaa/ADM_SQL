		changedProperty = IsHidden

	measure 'Remaining Working Days in Selected Period' =
			
			CALCULATE(SUM(dimDates[Is Working Day]),FILTER(dimDates,  dimDates[IsHistory]=0 && dimDates[UntilNextMonth]=1))
		formatString: 0.0
		lineageTag: 412dfcf4-935f-4ac5-970f-58711ad90ee8

