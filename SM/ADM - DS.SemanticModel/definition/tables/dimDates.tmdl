	measure 'Working Days in Selected Period' =
			
			
			CALCULATE(
			SUM(dimDates[Is Working Day]),dimDates[UntilNextMonth]=1)
		formatString: 0.0
		lineageTag: 6028f275-fd65-4801-aeb6-3af4c5fca885

		changedProperty = IsHidden

