table dimDates
	lineageTag: cb77239d-de71-4866-8cf3-cfac06b8fa73

	measure 'Maxdate - LY' =
			
			var LastYearToToday=CALCULATE(MAX(dimDates[Date]),dimDates[IsHistory]=1)
			return
			CALCULATE(MAX(dimDates[LastYear]),FILTER(dimDates,dimDates[Date]=LastYearToToday),FILTER(Sub_DimDates,Sub_DimDates[Date]=LastYearToToday))
		formatString: Short Date
		lineageTag: 2a43d4fa-a514-4b13-982f-12de7b8503e5

		changedProperty = IsHidden

	measure 'Mindate - LY' =
			
			var OnlyThisYear=Year(CALCULATE(MAX(dimDates[Date]), dimDates[IsHistory]=1))
			RETURN
			CALCULATE(MIN(dimDates[LastYear]),FILTER(dimDates,Year(dimDates[Date])=OnlyThisYear),FILTER(Sub_DimDates,Sub_DimDates[Year]=OnlyThisYear))
		formatString: General Date
		lineageTag: e15d5d37-497f-499d-8d21-285875482582

		changedProperty = IsHidden

	measure 'תקופה מוצגת' = FORMAT(CALCULATE(MIN(dimDates[Date]),dimDates[IsHistory]=1),"dd/mm/yyyy") & " - " & FORMAT(CALCULATE(MAX(dimDates[Date]),dimDates[IsHistory]=1),"dd/mm/yyyy")
		displayFolder: מדדים
		lineageTag: 6e65ded5-c137-4e81-bf8a-2727de9a470c

		changedProperty = IsHidden

	measure 'Last Sale Date' = CALCULATE(MAX(factSales[Date]),factSales[LineTotalNetNIS]>0,ALL(dimDates))
		formatString: Short Date
		lineageTag: 50515ce9-f261-4ef0-ab15-418f4df403f9

		changedProperty = IsHidden

	measure 'Mindate - LM' =
			
			var OnlyLastMonth=CALCULATE(MAX(dimDates[YearMonthSum]), dimDates[IsHistory]=1)
			return
			CALCULATE(MIN(dimDates[LastMonth]),FILTER(dimDates,dimDates[YearMonthSum]=OnlyLastMonth),FILTER(Sub_DimDates,Sub_DimDates[Date]=OnlyLastMonth))
		formatString: General Date
		lineageTag: 30b32ed4-7de6-4f1f-b6ea-2939211ece42

		changedProperty = IsHidden

	measure 'Maxdate - LM' =
			
			var OnlyThisMonth=CALCULATE(MAX(dimDates[Date]), dimDates[IsHistory]=1)
			return
			CALCULATE(MAX(dimDates[LastMonth]),FILTER(dimDates,dimDates[Date]=OnlyThisMonth))
		formatString: General Date
		lineageTag: e7db9ece-486f-418d-97a6-a5a862aa981d

		changedProperty = IsHidden

	measure 'Maxdate - LY_Full' =
			
			var OnlyThisYear=CALCULATE(MAX(dimDates[Year]), dimDates[IsHistory]=1)
			var OnlyThisYear2=YEAR(CALCULATE(MAX(dimDates[date]), dimDates[IsHistory]=1))
			RETURN
			CALCULATE(MAX(dimDates[LastYear_Full]),FILTER(dimDates,dimDates[Year]=OnlyThisYear),FILTER(Sub_DimDates,Sub_DimDates[Date]=OnlyThisYear2))
		formatString: General Date
		lineageTag: f1b6d366-9d14-4637-a487-2c912ebd4aea

		changedProperty = IsHidden

	measure 'Maxdate - LM_Full' =
			
			var OnlyThisMonth=CALCULATE(MAX(dimDates[Date]), dimDates[IsHistory]=1)
			return
			CALCULATE(MAX(dimDates[LastMonth_Full]),FILTER(dimDates,dimDates[Date]=OnlyThisMonth),FILTER(Sub_DimDates,Sub_DimDates[Date]=OnlyThisMonth))
		formatString: General Date
		lineageTag: 8e95dc8b-0272-48bb-a8f9-440e6019a1b3

