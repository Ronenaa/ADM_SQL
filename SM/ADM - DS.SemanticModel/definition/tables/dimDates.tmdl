	partition dimDates-687ce122-c7f7-4816-8c31-c8171ad70a27 = m
		mode: import
		queryGroup: 'Dates Dim'
		source = ```
				let
				 
				/* 
				
				LAST UPDATE: 14/01/2018
				 
				DimDate is Hebrew by default. For ENGLISH insert "en-US" (witout quotes). For more: http://msdn.microsoft.com/en-us/goglobal/bb896001.aspx
				
				TodayDate=DateTime.Date(DateTime.LocalNow())+1, \\choose if today sales arent count
				End of Today = EndDate = DateTime.Date(DateTime.LocalNow()),
				End of This Month = EndDate = Date.EndOfMonth(DateTime.Date(DateTime.LocalNow())),
				End of This Year = EndDate = Date.AddYears(Date.EndOfYear(DateTime.Date(DateTime.LocalNow())),1)
				Sales Module =  #date(2017,03,12)
				*/
				TodayDate=Date.From(DateTime.FixedLocalNow()),//DateTime.Date(DateTime.LocalNow()),Use For Prod //#date(219,11,11), Use For Demo 
				EndDate = Date.AddYears(Date.EndOfYear(DateTime.Date(DateTime.LocalNow())),2),
				StartDate=#date(2018, 1, 1),
				DayCount = Duration.Days(Duration.From(EndDate - StartDate))+1,
				Culture ="en-US",
				
				 Source = List.Dates(StartDate,DayCount,#duration(1,0,0,0)),
				 TableFromList = Table.FromList(Source, Splitter.SplitByNothing()),    
				 ChangedType = Table.TransformColumnTypes(TableFromList,{{"Column1", type date}}),
				 RenamedColumns = Table.RenameColumns(ChangedType,{{"Column1", "Date"}}),
				 InsertYear = Table.AddColumn(RenamedColumns, "Year", each Date.Year([Date]), type number),
				    #"Added This Year" = Table.AddColumn(InsertYear, "This Year Selection",
				each if Date.IsInCurrentYear([Date]) then "This Year"
				else
				[Year]),
				 InsertQuarter = Table.AddColumn( #"Added This Year", "QuarterNumOfYear", each Date.QuarterOfYear([Date]), type number),
				 InsertQuarterName = Table.AddColumn(InsertQuarter , "QuarterName" , each "Q-" & Number.ToText([QuarterNumOfYear])),
				 InsertHalfOfYearNum = Table.AddColumn(InsertQuarterName , "HalfOfYearNum", each  Number.RoundDown(([QuarterNumOfYear]+1)/2), type number),
				 InsertHalfOfYearName = Table.AddColumn(InsertHalfOfYearNum ,"HalfOfYearName",each "H-" & Number.ToText([HalfOfYearNum])),
				 InsertHalfOfCalendarYear = Table.AddColumn(InsertHalfOfYearName ,"HalfOfCalendarYear", each  "H" & Number.ToText([HalfOfYearNum]) & " " & Number.ToText([Year])),
				 InsertHalfOfCalendarYearSum = Table.AddColumn( InsertHalfOfCalendarYear ,"HalfOfCalendarYearSum",each [Year]*10 +[HalfOfYearNum], type number),
				 InsertMonth = Table.AddColumn(InsertHalfOfCalendarYearSum , "MonthNumberOfYear", each Date.Month([Date]), type number),
				 InsertDay = Table.AddColumn(InsertMonth, "DayOfMonth", each Date.Day([Date]), type number),
				 InsertDayInt = Table.AddColumn(InsertDay, "DateInt", each [Year] * 10000 + [MonthNumberOfYear] * 100 + [DayOfMonth], type number),
				 InsertMonthName = Table.AddColumn(InsertDayInt, "MonthName", each Date.ToText([Date], "MMMM", Culture), type text),
				 InsertCalendarMonth = Table.AddColumn(InsertMonthName, "MonthInCalendarName", each (try(Text.Range([MonthName],0,3)) otherwise [MonthName]) & " " & Number.ToText([Year])),
				    #"Added This Month Selection" = Table.AddColumn(InsertCalendarMonth, "This Month Selection", each if Date.IsInCurrentMonth([Date]) then
				(
				if Culture ="he-IL" then "חודש נוכחי" else
				"This Month"
				)
				else [MonthInCalendarName]),
				 InsertCalendarQtr = Table.AddColumn(#"Added This Month Selection", "QuarterInCalendar", each "Q" & Number.ToText([QuarterNumOfYear]) & " " & Number.ToText([Year])),
				 InsertDayWeek = Table.AddColumn(InsertCalendarQtr, "DayOFWeekNum", each 1+Date.DayOfWeek([Date]), type number),
				 InsertDayName = Table.AddColumn(InsertDayWeek, "DayOfWeekName", each Text.Trim(Text.Replace(Date.ToText([Date], "dddd", Culture),"יום","")," "), type text),
				 InsertWeekEnding = Table.AddColumn(InsertDayName, "WeekEnding", each Date.EndOfWeek([Date]), type date),
				 InsertYearMonthSum = Table.AddColumn(InsertWeekEnding,"YearMonthSum", each [Year]*100 +[MonthNumberOfYear], type number),
				 InsertYearQuarterSum = Table.AddColumn(InsertYearMonthSum ,"YearQuarterSum", each [Year]*10 +[QuarterNumOfYear], type number),
				 
				
				 InsertDaySelection = 
				 if Culture="he-IL" 
				 then 
				 (Table.AddColumn(InsertYearQuarterSum , "Show Dates", each (if Date.IsInCurrentDay(Date.AddDays([Date],1)) then "אתמול" else (if  Date.IsInCurrentDay([Date]) then "היום" else "שאר התאריכים"))))
				 else 
				 (Table.AddColumn(InsertYearQuarterSum , "Show Dates", each (if Date.IsInCurrentDay(Date.AddDays([Date],1)) then "Yesterday" else (if  Date.IsInCurrentDay([Date]) then "Today" else "Other"))))
				 ,
				
				 
				
				 InsertMonthSelection = 
				 if Culture="he-IL" 
				 then 
				 (Table.AddColumn(InsertDaySelection , "Show Months", each (if Date.IsInPreviousMonth([Date]) then "חודש שעבר" else (if  Date.IsInCurrentMonth([Date]) then "החודש" else "שאר התאריכים"))))
				 else
				 (Table.AddColumn(InsertDaySelection , "Show Months", each (if Date.IsInPreviousMonth([Date]) then "Last Month" else (if  Date.IsInCurrentMonth([Date]) then "This Month" else "Other"))))
				 ,
				
				 InsertDaysInMonth =Table.AddColumn(InsertMonthSelection ,"DaysInMonth" , each Date.DaysInMonth([Date]) ,type number),
				 InsertWeekInYear =  Table.AddColumn(InsertDaysInMonth ,"WeekInYear", each [Year]*100+Date.WeekOfYear([Date]),type number),
				 InsertYearMonthNumber = Table.AddColumn(InsertWeekInYear, "YearMonthNumber",each ([Year]-Date.Year(StartDate))*12+[MonthNumberOfYear], type number),
				
				 IsInThisYear =Table.AddColumn(InsertYearMonthNumber ,"Show This Year" , each  Date.IsInCurrentYear([Date]) , type logical),
				 
				 ShowLast7Days = Table.AddColumn( IsInThisYear, "Show Last 7 Days", each (Duration.Days(Duration.From(DateTime.Date(DateTime.LocalNow()) - [Date]))) <=7 and (Duration.Days(Duration.From(DateTime.Date(DateTime.LocalNow()) - [Date]))) >=0 , type logical),
				 ShowLast30Days = Table.AddColumn( ShowLast7Days, "Show Last 30 Days", each (Duration.Days(Duration.From(DateTime.Date(DateTime.LocalNow()) - [Date]))) <=30 and (Duration.Days(Duration.From(DateTime.Date(DateTime.LocalNow()) - [Date]))) >=0 , type logical),
				    ShowLast_12_Months = Table.AddColumn(ShowLast30Days , "Show Last 12 Months", each [Date]>=Date.AddMonths(Date.StartOfMonth(TodayDate),-11),type logical),
				    #"Show Next 12 Months" = Table.AddColumn(ShowLast_12_Months, "Show Next 12 Months", each [Date]<=Date.AddMonths(Date.StartOfMonth(TodayDate),12) and [Date]>=Date.StartOfMonth(TodayDate) ,type logical),
				    ShowLast_6_Months = Table.AddColumn(#"Show Next 12 Months", "Show Last 6 Months", each [Date]>=Date.AddMonths(Date.StartOfMonth(TodayDate),-5) and [Date]<=TodayDate,type logical),
				 ShowLast_3_Months = Table.AddColumn(ShowLast_6_Months, "Show Last 3 Months", each [Date]>=Date.AddMonths(Date.StartOfMonth(TodayDate),-2) and [Date]<=TodayDate,type logical),
				    #"Show Next 6 Months" = Table.AddColumn(ShowLast_3_Months,"Show Next 6 Months", each if  [Date]<=Date.AddMonths(Date.StartOfMonth(TodayDate),6) and [Date]>=Date.StartOfMonth(TodayDate) then true else false ,type logical),
				    #"Show Next 7 Months" = Table.AddColumn(#"Show Next 6 Months","Show Next 7 Months", each if  [Date]<=Date.AddMonths(Date.StartOfMonth(TodayDate),7) and [Date]>=Date.StartOfMonth(TodayDate) then true else false ,type logical),
				    #"Show Next 8 Months" = Table.AddColumn(#"Show Next 7 Months","Show Next 8 Months", each if  [Date]<=Date.AddMonths(Date.StartOfMonth(TodayDate),8) and [Date]>=Date.StartOfMonth(TodayDate) then true else false ,type logical),
				    ShowLast2Years = Table.AddColumn(#"Show Next 8 Months", "ShowLast2Years", each if Date.Year([Date]) = Date.Year(Date.From(DateTime.FixedLocalNow()))  then 1 
				else if Date.Year([Date]) = Date.Year(Date.From(DateTime.FixedLocalNow()))-1 
				then 1 
				else 0, Int64.Type),
				 
				 LastRefreshTime = Table.AddColumn(ShowLast2Years ,"Refresh Time", each  Time.From(DateTime.LocalNow()),type time),
				 LastRefreshDate = Table.AddColumn(LastRefreshTime ,"Refresh Date", each  DateTime.Date(DateTime.LocalNow()),type date),
				 FisrtDayOfMonth = Table.AddColumn( LastRefreshDate ,"FirstDayOfMonth", each Date.StartOfMonth([Date])  ,type date),
				
				
				
				    #"Added Last Month" = Table.AddColumn(#"FisrtDayOfMonth", "LastMonth", each if [Date]=Date.EndOfMonth([Date]) then 
				(if Date.Day([Date])=Date.Day(Date.EndOfMonth(Date.AddMonths([Date],-1))) then 
				Date.AddMonths([Date],-1)
				else
				Date.EndOfMonth(Date.AddMonths([Date],-1)))
				else 
				Date.AddMonths([Date],-1),type date),
				
				
				    #"Added Last Year" = Table.AddColumn(#"Added Last Month", "LastYear", each if [Date]=Date.EndOfMonth([Date]) then 
				(if Date.Day([Date])=Date.Day(Date.EndOfMonth(Date.AddYears([Date],-1))) then 
				Date.AddYears([Date],-1)
				else
				Date.EndOfMonth(Date.AddYears([Date],-1)))
				else 
				Date.AddYears([Date],-1),type date),
				    #"Added Last Month - Full" = Table.AddColumn(#"Added Last Year", "LastMonth_Full", each Date.EndOfMonth([LastMonth])),
				    #"Added Last Year - Full" = Table.AddColumn(#"Added Last Month - Full", "LastYear_Full", each Date.EndOfMonth([LastYear])),
				
				
				    #"Changed Type Dates Compare" = Table.TransformColumnTypes(#"Added Last Year - Full",{{"LastYear", type date}, {"LastMonth", type date}, {"LastMonth_Full", type date}, {"LastYear_Full", type date}}),
				    #"Add Working Day" = Table.AddColumn(#"Changed Type Dates Compare", "Is Working Day", each if [DayOFWeekNum] = 6 then 0.5 else if [DayOFWeekNum] = 7
				then
				0
				else
				1,type number),
				 #"Added IsHistory" = Table.AddColumn(#"Add Working Day", "IsHistory", each if [Date] > TodayDate then 0 else 1 , Int64.Type),
				    #"Added Day History category" = Table.AddColumn( #"Added IsHistory", "Is History To Today", each if
				Date.Month([Date])*100+Date.Day([Date]) > 
				Date.Month(TodayDate)*100 +
				Date.Day(TodayDate)
				then
				 0 else 1 ,  Int64.Type),
				    UntilNextMonth = Table.AddColumn(#"Added Day History category", "UntilNextMonth", each if [Date]>Date.EndOfMonth(TodayDate) then 0 else 1,  Int64.Type),
				    UntilThisMonth = Table.AddColumn( UntilNextMonth, "UntilThisMonth", each if [Date]<Date.StartOfMonth(TodayDate) then 1 else 0, Int64.Type),
				    #"Changed Type" = Table.TransformColumnTypes(UntilThisMonth ,{{"Year", type text}}),
				    #"Around 6 Month" = Table.AddColumn(#"Changed Type", "Show Around 6 Months", each if Date.AddMonths(Date.StartOfMonth([Date]),-3)<= Date.From(DateTime.FixedLocalNow()) and Date.AddMonths(Date.StartOfMonth([Date]),4)>= Date.From(DateTime.FixedLocalNow()) then true else false, type logical),
				    #"Around 12 Months" = Table.AddColumn(#"Around 6 Month", "Show Around 12 Months", each if Date.AddMonths(Date.StartOfMonth([Date]),-6)<= Date.From(DateTime.FixedLocalNow()) and Date.AddMonths(Date.StartOfMonth([Date]),7)>= Date.From(DateTime.FixedLocalNow()) then true else false, type logical),
				    #"Insert WeekInYearName" = Table.AddColumn(#"Around 12 Months", "WeekInYearName", each Text.Combine({"Week", Text.From(Date.WeekOfYear([Date])),Text.From([Year])}," ")),
				    #"Week Name" = Table.AddColumn(#"Insert WeekInYearName", "WeekName", each Text.Combine({"Week", Text.From(Date.WeekOfYear([Date]))}," ")),
				    #"Inserted Week of Year" = Table.AddColumn(#"Week Name", "Week of Year", each Date.WeekOfYear([Date]), Int64.Type),
				    #"Add WeekStart" = Table.AddColumn(#"Inserted Week of Year", "WeekStart", each Date.AddDays(Date.EndOfWeek([Date]),-6),type date),
				    #"Inserted First Characters" = Table.AddColumn(#"Add WeekStart", "ShortMonthName", each Text.Start([MonthName], 3), type text),
				    MonthInCalenderShortName = Table.AddColumn(#"Inserted First Characters", "MonthInCalendarShortName", each (try(Text.Range([MonthName],0,3)) otherwise [MonthName]) & " " & Text.Range([Year],2,2), type text),
				    MonthtoShow = Table.AddColumn(MonthInCalenderShortName, "MonthToShow", each if Date.Month(DateTime.FixedLocalNow())<=4 then if Date.Year([Date])=Date.Year(DateTime.FixedLocalNow())-1 or Date.Year([Date])=Date.Year(DateTime.FixedLocalNow()) then 1 else 0
				else if Date.Month(DateTime.FixedLocalNow())>10 then if Date.Year([Date])=Date.Year(DateTime.FixedLocalNow())+1 or Date.Year([Date])=Date.Year(DateTime.FixedLocalNow()) then 1 else 0
				else if Date.Year([Date])=Date.Year(DateTime.FixedLocalNow()) then 1 else 0, Int64.Type),
				    show3Years = Table.AddColumn(MonthtoShow, "Show3Years", each if Date.Month(DateTime.FixedLocalNow())<=4 then if Date.Year([Date])=Date.Year(DateTime.FixedLocalNow())-1 or Date.Year([Date])=Date.Year(DateTime.FixedLocalNow()) or Date.Year([Date])=Date.Year(DateTime.FixedLocalNow()) -2 then 1 else 0
				else if Date.Month(DateTime.FixedLocalNow())>10 then if Date.Year([Date])=Date.Year(DateTime.FixedLocalNow())+1 or Date.Year([Date])=Date.Year(DateTime.FixedLocalNow()) or Date.Year([Date])=Date.Year(DateTime.FixedLocalNow())-1 then 1 else 0
				else if Date.Year([Date])=Date.Year(DateTime.FixedLocalNow()) then 1 else 0, Int64.Type),
				AddMTDColumn = Table.AddColumn(
				    show3Years,
				    "MTD_Indicator",
				    each if Date.IsInCurrentMonth([Date]) then "MTD" else "Other",
				    type text
				),
				AddYTDColumn = Table.AddColumn(
				    AddMTDColumn,
				    "YTD_Indicator",
				    each if Date.IsInCurrentYear([Date]) then "YTD" else "Other",
				    type text
				),
				// --- Weeks offset vs current week (Sunday-based) ---
				AddWeekPassed =
				    Table.AddColumn(
				        AddYTDColumn,
				        "Week Passed",
				        each
				            let
				                startOfThisWeek = Date.StartOfWeek(Date.From(DateTime.FixedLocalNow()), Day.Sunday),
				                rowWeekStart    = [WeekStart],
				                weekDiff        = Duration.Days(startOfThisWeek - rowWeekStart) / 7,
				                offset          = Int64.From(weekDiff)   // Past = negative, future = positive
				            in
				                offset,
				        Int64.Type
				    ),
				
				// --- Friendly English text ---
				AddWeekPassedFormatted =
				    Table.AddColumn(
				        AddWeekPassed,
				        "Week Passed Formatted",
				        each
				            let w = [Week Passed]
				            in
				                if w = 0 then "This Week"
				                else if w = 1 then "Last Week"
				                else if w = -1 then "Next Week"
				                else if w > 0 then Text.From(Number.Abs(w)) & " Weeks Ago"
				                else "In " & Text.From(Number.Abs(w)) & " Weeks Ahead",
				        type text
				    )
				in
				    AddWeekPassedFormatted
				```

	annotation PBI_Id = 0338cb02-0624-4859-9012-4d0cc589f987

