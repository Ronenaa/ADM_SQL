	measure 'Quantity MTD (Sales)' =
			
			VAR ThisMonth=CALCULATE(MAX(dimDates[YearMonthSum]),dimDates[IsHistory]=1)
			VAR SubThisMonth=CALCULATE(MAX(Sub_DimDates[YearMonthSum]),Sub_DimDates[IsHistory]=1)
