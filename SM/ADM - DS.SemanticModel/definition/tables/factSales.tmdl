		lineageTag: 45b9a50c-90a9-4530-a68c-db3c7fa80146

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Quantity Adjustment (Sales)' =
			
			CALCULATE(SUM(factSales[Quantity]), factSales[AdjustmentFlag] = 1)
		lineageTag: 34165083-ac82-490a-9230-6f2c1d5a6568

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Adjustment Quantity Shortage' =
			
			CALCULATE([Total Quantity Adjustment (Sales)],
			            factSales[TransactionType] = "פחת"
			)
		lineageTag: 890ecbf1-ec7b-4d99-bb4d-a468fe02d828

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'AVG Unit Price (Sales) - CIF' =
			
			CALCULATE([Avg Unit Price (Sales) Item],FILTER(factSales,[ActionTypeDesc]="מכירה בדוקומנטים"))
		formatString: \$#,0.0;(\$#,0.0);\$#,0.0
		lineageTag: b39fe157-3a9e-4981-b746-85b2de76d846

		changedProperty = IsHidden

	measure 'AVG Unit Price (Sales) - FOT' =
			
			CALCULATE(
			    [Avg Unit Price (Sales) Item],
			    FILTER(factSales,[ActionTypeDesc] = "מכירה")
			    )
		lineageTag: 172e9098-a909-488e-8790-bbff3ca24a52

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Adjustment Shortage %' =
			
			IF( [Adjustment Quantity Shortage] && [Total Order Quantity (Hzmnot)],
			DIVIDE(
			[Adjustment Quantity Shortage],
			[Total Order Quantity (Hzmnot)],0)
			)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 199fddf0-cdb4-4c97-96de-6687d211a458

		changedProperty = IsHidden

	measure 'Quantity CIF' =
			
			CALCULATE(
			    SUM(factSales[Quantity]),
			    FILTER(factSales,[ActionTypeDesc]="מכירה בדוקומנטים")
			)
		formatString: #,0.00
		lineageTag: d11fa984-6f5a-4386-ab9b-ec577ae4388f

		changedProperty = IsHidden

	measure 'Quantity FOT' =
			
			CALCULATE(
			    SUM(factSales[Quantity]),
			    FILTER(factSales,[ActionTypeDesc] = "מכירה")
			)
		formatString: #,0.00
		lineageTag: 7abfeec1-c36d-4cf4-b5a4-60eb424bc1ae

		changedProperty = IsHidden

	measure 'Total Quantity Adjustment+Sales' =
			
			[Total Quantity Adjustment (Sales)] + [Total Quantity (Sales)]
		formatString: #,0
		lineageTag: 3b6d10ee-6a14-4721-8f5e-e2b1811df391

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'CIF Profit' =
			
			IF(
			    [AVG Unit Price (Sales) - CIF], --check if exist
			    [AVG Unit Price (Sales) - CIF] - [CIF Price],
			    BLANK()
			)
		formatString: \$#,0.0;(\$#,0.0);\$#,0.0
		lineageTag: e30af17e-4c78-4a5a-8686-3b477a4dd18e

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'FOT Profit' =
			
			IF(
			    [AVG Unit Price (Sales) - FOT], --check if exist
			    [AVG Unit Price (Sales) - FOT] - [Avg Price USD (Expenses) Non Invoice]
			    ,BLANK()
			
			)
		formatString: \$#,0.0;(\$#,0.0);\$#,0.0
		lineageTag: dad1a141-6125-4050-9b51-9509aa875563

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Price Term' =
			
			SWITCH(TRUE(),
			    SELECTEDVALUE(factSales[ActionTypeDesc]) = "מכירה", "FOT",
			    SELECTEDVALUE(factSales[ActionTypeDesc]) = "FOT Premium", "FOT Premium",
			    SELECTEDVALUE(factSales[ActionTypeDesc]) = "מכירה בדוקומנטים", "CIF",
			    SELECTEDVALUE(factSales[QuantityCategory])
			)
			
			// if(
			//     [AVG Unit Price (Sales) - CIF] , "CIF",
			//     IF(
			//         [AVG Unit Price (Sales) - FOT], "FOT",
			//         IF(MAX(factSales[ActionTypeDesc]) = "FOT Premium", "FOT Premium",
			//         MAX(factSales[QuantityCategory])
			//         )
			//     )
			// )
		lineageTag: db694b24-796f-4e1a-9a8e-58a48efd072b

		changedProperty = IsHidden

	measure 'Total Gain' = ```
			
			 [FOT Profit]*[Quantity FOT]+[CIF Profit]*[Quantity CIF]+[FOT Premium Profit]*[Quantity FOT Premium]
			// SUMX (
			//     factSales,
			//     VAR Qty = [Total Quantity (Sales)]
			//     VAR SalePricePerUnit =
			//         DIVIDE ([Total Sales (Sales)], Qty )
			//     VAR PurchasePricePerUnit =
			//         SWITCH (
			//             factSales[ActionTypeDesc],
			//             "מכירה בדוקומנטים", [CIF Price],
			//             "מכירה", [Avg Price USD (Expenses)],
			//             BLANK()
			//         )
			//     RETURN
			//         (SalePricePerUnit - PurchasePricePerUnit) * Qty
			// )
			
			```
		formatString: \$#,0.0;(\$#,0.0);\$#,0.0
		lineageTag: 68d00b2b-0a66-42eb-a9da-68ab9aebfed0

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Total Gain per Ton' =
			
			DIVIDE(
			    [Total Gain],
			    [Total Quantity Adjustment+Sales]
			)
		formatString: \$#,0.0;(\$#,0.0);\$#,0.0
		lineageTag: 896f5323-b14f-4cce-9ef7-f601768172bd

		changedProperty = IsHidden

	measure 'AVG Unit Price (Sales) - FOT Premium' =
			
			CALCULATE(
			    [Avg Unit Price (Sales) Item],
			    FILTER(factSales,[ActionTypeDesc] = "FOT Premium")
			    )
		lineageTag: 686d9397-286a-46ec-b417-cbdc777bc965

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'FOT Premium Profit' = ```
			
			IF(
			    // SELECTEDVALUE(factSales[ActionTypeDesc]) = "FOT Premium",
			    [AVG Unit Price (Sales) - FOT Premium], --check if exist
			    [AVG Unit Price (Sales) - FOT Premium] - [Avg Price USD (Expenses)]
			    ,BLANK()
			)
			
			```
		formatString: \$#,0.0;(\$#,0.0);\$#,0.0
		lineageTag: 00bcff9c-41f7-4f61-8d40-896f2a3c8617

		changedProperty = IsHidden

	measure 'Quantity FOT Premium' =
			
			CALCULATE(
			    SUM(factSales[Quantity]),
			    FILTER(factSales,[ActionTypeDesc]="FOT Premium")
			)
		lineageTag: b0d1d07f-619d-4505-882f-4c31ef91437f

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Sales - CIF' =
			
			CALCULATE([Total Sales (Sales)],FILTER(factSales,[ActionTypeDesc]="מכירה בדוקומנטים"))
		lineageTag: 6be6548c-33b9-4d3a-adca-9a9c95f3a4a1

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Sales - FOT' =
			
			CALCULATE([Total Sales (Sales)],FILTER(factSales,[ActionTypeDesc]="מכירה"))
		lineageTag: 9f52ccfc-028e-42d3-aa22-016e31283708

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Sales - FOT Premium' =
			
			CALCULATE([Total Sales (Sales)],FILTER(factSales,[ActionTypeDesc]="FOT Premium"))
		lineageTag: 25fafde6-7e9e-4bd3-88c6-2c52432e7d08

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Sales (other)' =
			
			CALCULATE(
			    [Total Sales (Sales)],
			    FILTER(factSales,NOT(factSales[ActionTypeDesc] IN {"מכירה","מכירה בדוקומנטים","FOT Premium"})
			    )
			)
		lineageTag: faa8deca-5af5-462e-a56a-84dbce9fb987

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Sales USD (Sales) Only Item' =
			
			CALCULATE(SUM(factSales[LineTotalNet_USD]), factSales[AdjustmentFlag] <> 1 && factSales[LineType] = "Item")
		lineageTag: eb753dcb-1771-4297-a17c-fffa743d02aa

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Avg Unit Price (Sales) Item' = ```
			
			 DIVIDE([Total Sales USD (Sales) Only Item],[Total Quantity (Sales)])
			```
		lineageTag: 5fb49693-5510-4a47-b643-4a3c0c4fedfc

		annotation PBI_FormatHint = {"isGeneralNumber":true}

