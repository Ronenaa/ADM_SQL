	measure 'New Customers (Sales)' = ```
			
			
			SUMX(
			    VALUES(dimDates[MonthInCalendarName]),
			CALCULATE(COUNTROWS (
			
			    FILTER (
			        ADDCOLUMNS (
			            //CROSSJOIN(VALUES(factSales[AccountKey]),VALUES(factSales[AgentKey])),
			            VALUES ('factSales'[AccountKey]), 
			            "PreviousSales", 
			                CALCULATE (
			                  
			                    COUNTROWS ( 'factSales'), //Original Calc
			                    ALL(dimCustomers),
			                    FILTER (
			                        ALL ( dimDates ),
			                        dimDates[Date] < min(dimDates[Date])
			                    )
			                )
			                ,"ThisSales"
			              ,[Total Sales (Sales)]
			        ),
			      
			          [PreviousSales]=0
			          && [ThisSales]>0
			         
			    )
			)))
			```
		formatString: #,0
		lineageTag: 7e749d17-16c5-4456-9a64-8d5163effcea

		changedProperty = IsHidden

