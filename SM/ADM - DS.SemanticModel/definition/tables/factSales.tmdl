	partition factSales = m
		mode: import
		queryGroup: 'fact Tables'
		source =
				let
				    Source = Sql.Database(#"SQL Address", "MT", [Query="---factSales#(lf)-- Create a temporary table with the values#(lf)DECLARE @SubItemsMapping TABLE (#(lf)    ItemID varchar(10),#(lf)    ItemDesc varchar(20)#(lf));#(lf)#(lf)-- Insert values into the table variable#(lf)INSERT INTO @SubItemsMapping (ItemID, ItemDesc)#(lf)VALUES (9990, 'ריבית'),#(lf)       (9991, 'הובלה'),#(lf)       (9992, 'הפרשי שער');#(lf)#(lf)with CurrencyConvertion as ( --Curenncy COnvertion Table--#(lf)SELECT *, #(lf)         CASE#(lf)         #(tab)WHEN sher = 0#(lf)         #(tab)THEN FIRST_VALUE(sher) OVER (PARTITION BY value_partition ORDER BY Tarikh) #(lf)         #(tab)ELSE sher#(lf)         END AS new_sher#(lf)         ,CASE#(lf)         #(tab)WHEN SHER_EURO = 0#(lf)         #(tab)THEN FIRST_VALUE(SHER_EURO) OVER (PARTITION BY value_partitionEuro ORDER BY Tarikh) #(lf)         #(tab)ELSE  SHER_EURO#(lf)         END AS new_sherEuro#(lf) FROM ( SELECT *#(lf) ,SUM(CASE WHEN sher=0 THEN 0 ELSE 1 END) OVER (ORDER BY tarikh ) AS value_partition#(lf) ,SUM(CASE WHEN SHER_EURO=0 THEN 0 ELSE 1 END) OVER (ORDER BY tarikh ) AS value_partitionEuro#(lf)          FROM SHERI_MTBE) m#(lf)#(tab)#(tab)  )#(lf)----------------חשבוניות--------------------#(lf)SELECT #(lf)        '1' as 'EntityID'#(lf)        ,CH.MS_CHSHBONIT  AS 'DocID'#(lf)#(tab)#(tab),ROW_NUMBER () over (partition by CH.MS_CHSHBONIT order by CS.T_CHSHBONIT,TM.TARIKH_MSHLOCH) AS 'InvoiceLineNumber'#(lf)#(tab)#(tab),'Invoice' AS 'DocName'#(lf)#(tab)#(tab),Case#(lf)#(tab)#(tab)#(tab)WHEN CS.QOD_MOTSR = TM.QOD_MOTSR#(lf)#(tab)#(tab)#(tab)#(tab)THEN 'Item'#(lf)#(tab)#(tab)#(tab)ELSE 'Additional Expense'#(lf)#(tab)#(tab)END AS 'LineType'#(lf)#(tab)#(tab),Case#(lf)#(tab)#(tab)#(tab)WHEN CS.QOD_MOTSR = TM.QOD_MOTSR#(lf)#(tab)#(tab)#(tab)#(tab)THEN 0#(lf)#(tab)#(tab)#(tab)ELSE 1#(lf)#(tab)#(tab)END AS 'LineTypeCode'#(lf)#(tab)#(tab)--,CONCAT('1' , CONVERT(INT, CONVERT(VARCHAR, c.CUST)))   AS 'AccountKey' -- customer from invoices in case you need just invoices #(lf)#(tab)#(tab),CONVERT(VARCHAR,CS.QOD_LQOCH) 'AccountKey' -- customer from invoices in case you need just invoices #(lf)#(tab)#(tab),SUBSTRING(CS.T_CHSHBONIT,1,4) + '-' + SUBSTRING(CS.T_CHSHBONIT,5,2) + '-' + SUBSTRING(CS.T_CHSHBONIT,7,2) AS 'Date' -- Invoice date  #(lf)#(tab)#(tab)--,null AS 'Time'#(lf)#(tab)#(tab),CAST(CONVERT(INT, CONVERT(VARCHAR,AM.QOD))as varchar) 'AgentKey' -- Agent from Customer method#(lf)#(tab)#(tab)--,'1' + CONVERT(INT, CONVERT(VARCHAR, ii.PART)) AS 'ItemKey'#(lf)#(tab)#(tab)--,CONCAT('1' , CONVERT(INT, CONVERT(VARCHAR, ii.PART))  AS 'ItemKey'#(lf)#(tab)#(tab)--,CASE WHEN CS.QOD_MOTSR<>0 THEN CAST('1' as varchar) + CAST(CONVERT(INT, CONVERT(VARCHAR,CS.QOD_MOTSR)) as varchar) ELSE CAST('1' as varchar) + CAST(CONVERT(INT, CONVERT(VARCHAR,CS.QOD_MOTSR)) as varchar) +'-'+SIM.ItemID END AS 'ItemKey'#(lf)#(tab)#(tab),CAST( CONVERT(VARCHAR,CS.QOD_MOTSR) as varchar) +'-' + CAST( CONVERT(VARCHAR,CS.QOD_MOTSR) as varchar) AS 'ItemKey'#(lf)#(tab)#(tab),CASE WHEN TM.QOD_MOTSR IS NOT NULL THEN CAST(CONVERT(VARCHAR,TM.QOD_MOTSR) as varchar) ELSE CAST( CONVERT(VARCHAR,CS.QOD_MOTSR) as varchar) END +'-' + CASE WHEN CS.QOD_MOTSR<>0 THEN CAST( CONVERT(VARCHAR,CS.QOD_MOTSR) as varchar) ELSE SIM.ItemID END AS 'ItemKey_backup'#(lf)#(tab)#(tab),CASE WHEN TM.QOD_MOTSR IS NOT NULL THEN CAST(CONVERT(VARCHAR,TM.QOD_MOTSR) as varchar) ELSE CAST( CONVERT(VARCHAR,CS.QOD_MOTSR) as varchar) END AS Item#(lf)#(tab)#(tab),CASE WHEN CS.QOD_MOTSR<>0 THEN CAST( CONVERT(VARCHAR,CS.QOD_MOTSR) as varchar) ELSE SIM.ItemID END AS AdditionalKey#(lf)#(tab)#(tab)--,CAST('1' as varchar) + CAST(CONVERT(INT, CONVERT(VARCHAR, i.BRANCH)) as varchar) AS 'BranchKey'#(lf)#(tab)#(tab)--,null as 'EmployeeKey'#(lf)#(tab)#(tab)--,NULL AS 'BranchKey'#(lf)#(tab)#(tab)--,null as 'חבר מועדון'#(lf)#(tab)#(tab)--,(1 - (1 - ii.[T$PERCENT] / 100) * (1 - i.[T$PERCENT] / 100)) AS 'DiscountPercent' -- the DiscountPercent for the invoice and invoice line#(lf)#(tab)#(tab),NULL AS 'DiscountPercent'#(lf)#(tab)#(tab)--,(1 - (1 - ii.[T$PERCENT] / 100) * (1 - i.[T$PERCENT] / 100)) * ii.TQUANT / 1000 * ROUND(ii.PRICE, 2) * ii.IEXCHANGE AS 'LineTotalDiscount' -- the discount from gross price to the net#(lf)#(tab)#(tab),NULL AS 'LineTotalDiscount'#(lf)#(tab)#(tab)--,ROUND(ii.PRICE, 2) * ii.IEXCHANGE AS 'UnitGrossPrice'#(lf)#(tab)#(tab),NULL AS 'UnitGrossPrice'#(lf)#(tab)#(tab)--,ROUND(ii.PRICE * (1 - ii.[T$PERCENT] / 100) * (1 - i.[T$PERCENT] / 100), 2) * ii.IEXCHANGE AS 'UnitNetPrice'#(lf)#(tab)#(tab),CAST(CS.MCHIR_ICH_LLA_ME_M/(case when SHER_LCHISHOB<>0 then SHER_LCHISHOB else 1 end) AS decimal (12,2)) AS 'UnitNetPriceUSD'#(lf)#(tab)#(tab),CAST(CS.MCHIR_ICH_LLA_ME_M as decimal(12,2)) 'UnitNetPriceNIS'#(lf)#(tab)#(tab)--,ii.TQUANT / 1000 * (CASE WHEN i.DEBIT = 'C' THEN - 1 ELSE 1 END) AS 'Quantity'#(lf)#(tab)#(tab),CS.MSHQL_NTO AS 'Quantity'#(lf)#(tab)#(tab),CASE#(lf)#(tab)#(tab)#(tab)WHEN CS.QOD_MOTSR=TM.QOD_MOTSR#(lf)#(tab)#(tab)#(tab)#(tab)THEN 0#(lf)#(tab)#(tab)#(tab)ELSE Cs.CMOT#(lf)#(tab)#(tab)END as AdditionalQuantity#(lf)#(tab)#(tab)--The cost can be tor.cost * Quant or just tor.cost#(lf)#(tab)#(tab)--Option 1#(lf)#(tab)#(tab)--,CASE WHEN tor.COSTFLAG NOT IN ('C', '\0') #(lf)#(tab)#(tab)--THEN tor.COST * (CASE WHEN (tor.QUANT) < 0.0 THEN - 1 ELSE 1 END)#(lf)#(tab)#(tab)--ELSE p.COST * ((ii.QUANT / 1000) / p.COSTQUANT) * (CASE WHEN i.DEBIT = 'C' THEN - 1 ELSE 1 END) * (CASE WHEN ii.CREDITFLAG = 'Y' THEN 0 ELSE 1 END)#(lf)#(tab)#(tab)--END AS 'LineTotalCost' --------Cost without Quant#(lf)#(tab)#(tab),NULL AS 'LineTotalCost'#(lf)#(tab)#(tab)--Option 2#(lf)#(tab)#(tab)--,Case when tor.COSTFLAG NOT IN ('C','\0') then tor.COST * (ii.TQUANT/1000) * (Case when (tor.QUANT) < 0.0 then -1 else 1 end)#(lf)#(tab)#(tab)-- else #(lf)#(tab)#(tab)-- p.COST * ((ii.QUANT/1000) / p.COSTQUANT) * (CASE when i.DEBIT = 'C' then -1 else 1 end) *(case when ii.CREDITFLAG = 'Y' then 0 else 1 end) #(lf)#(tab)#(tab)-- end as 'Line Total Cost' ----Cost with Quant#(lf)#(tab)#(tab)--choose one of the above , The defauls is uncomment :#(lf)#(tab)#(tab),CAST(CASE #(lf)#(tab)#(tab)#(tab)WHEN CS.QOD_MOTSR<>0 #(lf)#(tab)#(tab)#(tab)#(tab)THEN CAST((CS.MCHIR_ICH_LLA_ME_M * CS.MSHQL_NTO) AS decimal (18,2)) #(lf)#(tab)#(tab)#(tab)ELSE CS.MCHIR_ICH_LLA_ME_M #(lf)#(tab)#(tab)END #(lf)#(tab)#(tab)+#(lf)#(tab)#(tab)CASE#(lf)#(tab)#(tab)#(tab)WHEN CS.QOD_MOTSR=TM.QOD_MOTSR#(lf)#(tab)#(tab)#(tab)#(tab)THEN 0#(lf)#(tab)#(tab)#(tab)--WHEN TM.QOD_MOTSR IS NULL#(lf)#(tab)#(tab)#(tab)--#(tab)THEN 0#(lf)#(tab)#(tab)#(tab)ELSE Cs.CMOT*CAST(CS.MCHIR_ICH_LLA_ME_M as decimal(12,2))#(lf)#(tab)#(tab)END #(lf)#(tab)#(tab)AS decimal (18,2))#(tab)AS 'LineTotalNetNIS'#(lf)#(lf)#(tab)#(tab),CAST(CASE #(lf)#(tab)#(tab)#(tab)WHEN CS.QOD_MOTSR<>0 #(lf)#(tab)#(tab)#(tab)#(tab)THEN CAST((CS.MCHIR_ICH_LLA_ME_M * CS.MSHQL_NTO)/(case when SHER_LCHISHOB<>0 then SHER_LCHISHOB else CC.new_sher end) AS decimal (18,2))#(lf)#(tab)#(tab)     ELSE CAST((CS.MCHIR_ICH_LLA_ME_M)/case when SHER_LCHISHOB<>0 then SHER_LCHISHOB else CC.new_sher end AS decimal (18,2)) #(lf)#(tab)#(tab)END#(lf)#(tab)#(tab)+#(lf)#(tab)#(tab)CASE#(lf)#(tab)#(tab)#(tab)WHEN CS.QOD_MOTSR=TM.QOD_MOTSR#(lf)#(tab)#(tab)#(tab)#(tab)THEN 0#(lf)#(tab)#(tab)#(tab)WHEN TM.QOD_MOTSR IS NULL#(lf)#(tab)#(tab)#(tab)#(tab)THEN 0#(lf)#(tab)#(tab)#(tab)ELSE Cs.CMOT * CAST(CS.MCHIR_ICH_LLA_ME_M/(case when SHER_LCHISHOB<>0 then SHER_LCHISHOB else CC.new_sher  end) AS decimal (12,2))#(lf)#(tab)#(tab)END AS decimal (18,2))#(tab)#(tab)AS'LineTotalNet_USD' --Invoices are always in NIS#(lf)#(lf)#(tab)#(tab),null AS 'LineTotalNetVAT'#(lf)#(tab)#(tab),null AS 'LineTotalNetVAT_USD'#(lf)#(tab)#(tab),CONVERT(INT, CONVERT(VARCHAR,SUBSTRING(CS.T_CHSHBONIT,1,4) + SUBSTRING(CS.T_CHSHBONIT,5,2))) AS YearMonth#(lf)#(tab)#(tab)--,case when (i.DEBIT='C')  then round(ii.IVCOST  ,2)*-1 else round(ii.IVCOST  ,2) end  as 'LineTotalNet'  -- Without Exchange#(lf)#(tab)#(tab)--,case when (i.DEBIT='C')  then round(ii.IVCOST  ,2)*-1*ii.IEXCHANGE else round(ii.IVCOST  ,2)*ii.IEXCHANGE end  as 'LineTotalNet' --allways exchange#(lf)#(tab)#(tab)--,case when (i.DEBIT='C')  then round(ii.QPRICE  ,2)*-1*ii.IEXCHANGE else round(ii.QPRICE  ,2)*ii.IEXCHANGE end  as 'LineTotalNet' -- the invoice items price without the total invoice discount#(lf)#(tab)#(tab)----#(lf)#(tab)#(tab),NULL as 'Status'#(lf)#(tab)#(tab)--,NULL as 'ChargeFlag'  #(lf)#(tab)#(tab)--,null as 'סטטוס ליקוט כותרת'#(lf)#(tab)   -- ,null  as 'סטטוס ליקוט שורה'#(lf)#(tab)--#(tab),NULL as 'דגל סטורנו'#(lf)#(tab)#(tab), TM.MS_TEODH as 'DeliveryNote'#(lf)#(tab)#(tab),CASE#(lf)#(tab)#(tab)#(tab)WHEN SUBSTRING(TM.TARIKH_MSHLOCH,1,4) = '0000'#(lf)#(tab)#(tab)#(tab)#(tab)THEN CAST(SUBSTRING(CS.T_CHSHBONIT,1,4) + '-' + SUBSTRING(CS.T_CHSHBONIT,5,2) + '-' + SUBSTRING(CS.T_CHSHBONIT,7,2) as date)#(lf)#(tab)#(tab)#(tab)ELSE CAST(ISNULL(SUBSTRING(TM.TARIKH_MSHLOCH,1,4) + '-' + SUBSTRING(TM.TARIKH_MSHLOCH,5,2) + '-' + SUBSTRING(TM.TARIKH_MSHLOCH,7,2),#(lf)#(tab)#(tab)ISNULL(SUBSTRING(FTM.FirstDeliveryDateTM,1,4) + '-' + SUBSTRING(FTM.FirstDeliveryDateTM,5,2) + '-' + SUBSTRING(FTM.FirstDeliveryDateTM,7,2),#(lf)#(tab)#(tab)SUBSTRING(CS.T_CHSHBONIT,1,4) + '-' + SUBSTRING(CS.T_CHSHBONIT,5,2) + '-' + SUBSTRING(CS.T_CHSHBONIT,7,2)))#(lf)#(tab)#(tab)AS date) #(lf)#(tab)#(tab)END as 'DeliveryDate'#(lf)#(tab)#(tab),HZ.MSPR_HZMNH as 'OrderID'#(lf)#(tab)#(tab),TM.QOD_SHOLCH as 'SupplierWarehouse'#(lf)#(tab)#(tab),CASE#(lf)#(tab)#(tab)#(tab)WHEN W.Qod_Gorm is Null#(lf)#(tab)#(tab)#(tab)#(tab)THEN 0#(lf)#(tab)#(tab)#(tab)ELSE 1#(lf)#(tab)#(tab)END AS 'WarehouseFlag'#(lf)#(tab)#(tab),GETDATE() AS RowInsertDatetime#(lf)#(tab)#(tab),TM.ActionType#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)as 'ActionType'#(lf)#(tab)#(tab)--,act.ActionType#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)as 'ActionTypeDesc'#(lf)#(tab)#(tab),CASE #(lf)#(tab)#(tab)#(tab)WHEN TM.ActionType = 6 THEN G.AOPI_PEILOT#(lf)#(tab)#(tab)#(tab)ELSE act.ActionType#(lf)#(tab)#(tab)END#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)as 'ActionTypeDesc'#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(lf)#(tab)#(tab),'0'#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)as 'AdjustmentFlag'#(lf)#(tab)#(tab),null#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)as  'TransactionType'#(lf)#(tab)#(tab),'Sales'#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)as  'QuantityCategory'#(lf)#(tab)#(tab)#(lf)#(tab)#(tab)--,SIM.ItemID AS 'SubItemID'#(lf)FROM CHSHBONIOT_COTROT CH#(lf)/*left join (Select CHSHBONIT, SUM(SCOM_MOTAM) as SCOM#(lf)#(tab)#(tab)#(tab)from QISHOR_QBLOT_CHSHBONIOT#(lf)#(tab)#(tab)#(tab)GROUP BY CHSHBONIT#(lf)) QCH#(lf)on CH.MS_CHSHBONIT = QCH.CHSHBONIT*/#(lf)--left join QISHOR_QBLOT_CHSHBONIOT QB #(lf)--   on CH.MS_CHSHBONIT = QB.CHSHBONIT#(lf)--left join QBLOT_COTROT Q#(lf)--on QB.QBLH = Q.MS_QBLH#(lf)Left Join GORMIM G#(lf)#(tab)on CH.QOD_LQOCH = G.QOD_GORM#(lf)Left Join TBLT_ANSHI_MCIROT AM #(lf)#(tab)on AM.SHM_AISH_MCIROT = G.AISH_MCIROT_MTPL#(lf)LEFT JOIN CHSHBONIOT_SHOROT CS #(lf)    ON CH.MS_CHSHBONIT = CS.MS_CHSHBONIT#(lf)LEFT JOIN @SubItemsMapping SIM #(lf)#(tab)ON (#(lf)#(tab)#(tab)CASE WHEN (TAOR_MOTSR LIKE '%ריבית%' OR TAOR_MOTSR LIKE '%הובלה%' OR TAOR_MOTSR LIKE '%הפרשי שער%') AND  CS.QOD_MOTSR=0 AND TAOR_MOTSR LIKE '%'+SIM.ItemDesc+'%'#(lf)#(tab)#(tab)then 1 else 0 end = 1)#(lf)LEFT JOIN TEODOT_MSHLOCH TM #(lf)#(tab)ON CS.MS_T_MSHLOCH = TM.MS_TEODH#(lf)LEFT JOIN (SELECT MS_CHSHBONIT , Min (TM.TARIKH_MSHLOCH) as 'FirstDeliveryDateTM',Min (CHS.TARIKH_MSHLOCH) as 'FirstDeliveryDateCHS'#(lf)#(tab)#(tab)#(tab)FROM CHSHBONIOT_SHOROT CHS#(lf)#(tab)#(tab)#(tab)Left Join TEODOT_MSHLOCH TM#(lf)#(tab)#(tab)#(tab)#(tab)ON TM.MS_TEODH = CHS.MS_T_MSHLOCH#(lf)#(tab)#(tab)#(tab)Where 1=1#(lf)#(tab)#(tab)#(tab)AND TM.TARIKH_MSHLOCH <>00000000#(lf)#(tab)#(tab)#(tab)AND CHS.TARIKH_MSHLOCH <>00000000#(lf)#(tab)#(tab)#(tab)Group By CHS.MS_CHSHBONIT) FTM#(lf)#(tab)ON FTM.MS_CHSHBONIT = CH.MS_CHSHBONIT#(lf)Left Join (SELECT MS_HZMNH,MS_T_MSHLOCH#(lf)#(tab)#(tab)#(tab)F