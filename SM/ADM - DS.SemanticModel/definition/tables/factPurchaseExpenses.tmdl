	partition factPurchaseExpenses = m
		mode: import
		queryGroup: 'fact Tables'
		source =
				let
				    Source = Sql.Database(#"SQL Address", "MT", [Query="with CurrencyConvertion as (#(lf)SELECT *, #(lf)         CASE#(lf)         #(tab)WHEN sher = 0#(lf)         #(tab)THEN FIRST_VALUE(sher) OVER (PARTITION BY value_partition ORDER BY Tarikh) #(lf)         #(tab)ELSE sher#(lf)         END AS new_sher#(lf)         ,CASE#(lf)         #(tab)WHEN SHER_EURO = 0#(lf)         #(tab)THEN FIRST_VALUE(SHER_EURO) OVER (PARTITION BY value_partitionEuro ORDER BY Tarikh) #(lf)         #(tab)ELSE  SHER_EURO#(lf)         END AS new_sherEuro#(lf) FROM (#(lf)          SELECT *#(lf) ,SUM(CASE WHEN sher=0 THEN 0 ELSE 1 END) OVER (ORDER BY tarikh ) AS value_partition#(lf) ,SUM(CASE WHEN SHER_EURO=0 THEN 0 ELSE 1 END) OVER (ORDER BY tarikh ) AS value_partitionEuro#(lf)          FROM SHERI_MTBE#(lf) ) m#(lf))#(lf),LastCreation as (#(lf)Select OrderId,MAX(CreateDate) AS LastCreation#(lf)From tblOrderPriceS#(lf)Group By OrderID#(lf))#(lf)#(lf),LastVersion as (#(lf)Select o.OrderId,Max(DayVersion) as LastVersion#(lf)From tblOrderPriceS o#(lf)Inner Join LastCreation LC#(lf)#(tab)ON o.OrderID=LC.OrderID AND o.CreateDate=LC.LastCreation#(lf)Group By o.OrderID#(lf))#(lf)#(lf),OrderPrices as (#(lf)Select O.*#(lf)from tblOrderPriceS o#(lf)Inner Join LastCreation LC#(lf)#(tab)ON o.OrderID=LC.OrderID And o.CreateDate=LC.LastCreation#(lf)Inner Join LastVersion LV#(lf)#(tab)ON o.OrderID=LV.OrderID AND o.DayVersion = LV.LastVersion#(lf)Where 1=1#(lf)),#(lf)--------------------------------------------------------------- the below part should be a view is the database ----------------------------------------------------#(lf)totals_raw AS (#(lf)    -- Step 1: per-row calculations#(lf)    SELECT#(lf)        CONCAT(#(lf)            CAST(CONVERT(BIGINT, POL.POL_OrderID) AS VARCHAR(20)),#(lf)            CAST(POL.POL_LineID AS VARCHAR(10))#(lf)        ) AS PurchaseOrderID,#(lf)        #(lf)        CONVERT(VARCHAR, HS.QOD_MOTSR) + '-' + CONVERT(VARCHAR, HS.QOD_MOTSR) AS ItemKey,#(lf)#(lf)        -- PNL classification#(lf)        CASE#(lf)            WHEN HST.QOD_SHROT IN (5, 19, 30, 4)#(lf)              OR HST.QOD_SHROT IS NULL#(lf)                THEN 999#(lf)            ELSE HST.QOD_SHROT#(lf)        END AS PNLKey,#(lf)#(lf)        -- Order quantity (only main item rows)#(lf)        CASE#(lf)            WHEN HS.QOD_SHROT = 0 THEN HS.CMOT#(lf)            ELSE 0#(lf)        END AS OrderQuantity,#(lf)#(lf)        -- Line total in USD (exactly כמו הקטע ששלחת)#(lf)        CASE#(lf)            WHEN HS.MTBE = '$' THEN HS.MCHIR_ICH * HS.CMOT#(lf)            WHEN HS.MTBE = 'Eur' THEN HS.MCHIR_ICH * HS.CMOT * (SM.NEW_SHEREURO / SM.NEW_SHER)#(lf)            ELSE HS.MCHIR_ICH * HS.CMOT * (#(lf)                    1 / CASE WHEN HC.SHER_MTBE = 0 THEN 1 ELSE HC.SHER_MTBE END#(lf)                 )#(lf)        END AS LineTotalNetUSD#(lf)    FROM HOTSAOT_COTROT HC#(lf)    LEFT JOIN HOTSAOT_SHOROT HS#(lf)        ON HC.NOMRTOR = HS.NOMRTOR#(lf)    LEFT JOIN PurchaseOrderLines POL#(lf)        ON CONCAT(#(lf)               CAST(CONVERT(BIGINT, POL.POL_OrderID) AS VARCHAR(20)),#(lf)               CAST(POL.POL_LineID AS VARCHAR(10))#(lf)           ) = CAST(HS.MS_MSMKH_QSHOR AS VARCHAR(30))#(lf)    LEFT JOIN HOTSAOT_SHROTIM_New HST#(lf)        ON HS.QOD_SHROT = HST.QOD_SHROT#(lf)    LEFT JOIN CurrencyConvertion SM#(lf)        ON SM.TARIKH = HC.T_ERKH#(lf)    WHERE 1 = 1#(lf)      AND CAST(SUBSTRING(HC.T_MSMKH, 1, 4) AS INT) >= 2018#(lf)      AND CAST(SUBSTRING(HC.T_MSMKH, 1, 4) AS INT) <= YEAR(GETDATE())#(lf)      AND HS.QOD_SHROT NOT IN (14)#(lf)),#(lf)#(lf)totals AS (#(lf)    -- Step 2: aggregate like the DAX measure#(lf)    SELECT#(lf)        PurchaseOrderID,#(lf)        ItemKey,#(lf)        999 as PNLKey,#(lf)        SUM(LineTotalNetUSD) AS LineTotalNetUSD,       -- same as [Total Expenses USD]#(lf)        SUM(OrderQuantity)   AS OrderQuantity,     -- same as [Total Order Quantity (Hzmnot)]#(lf)        SUM(LineTotalNetUSD) /#(lf)            NULLIF(SUM(OrderQuantity), 0) AS UnitNetPriceUSD  -- Avg Price USD (Expenses)#(lf)    FROM totals_raw#(lf)    GROUP BY#(lf)        PurchaseOrderID,#(lf)        ItemKey--,#(lf)        --PNLKey#(lf)),#(lf)--select * from totals#(lf)--where PurchaseOrderID = 20005431#(lf)main AS (#(lf)    -- Monthly quantity of items loaned between parties (exchanges), by PO and item#(lf)    SELECT#(lf)        TM.QOD_SHOLCH AS DeliveredFrom,#(lf)        W.SHM_GORM AS DeliveredFromName,#(lf)        ISNULL(b.MS_HZMNH, bb.MS_HZMNH) AS PurchaseOrderID,#(lf)        CASE #(lf)            WHEN ISNULL(b.MS_HZMNH, bb.MS_HZMNH) LIKE '2000%' THEN 'P' -- Purchase order#(lf)            ELSE 'E'                                                   -- Expense / other#(lf)        END AS Order_Type,#(lf)        CONVERT(VARCHAR, TM.QOD_MOTSR) + '-' + CONVERT(VARCHAR, TM.QOD_MOTSR) AS ItemKey,#(lf)        SUM(TM.MSHQL_NTO) AS qty_loaned,#(lf)        G.QOD_GORM AS DeliveredTo,#(lf)        G.SHM_GORM AS DeliveredToName,#(lf)        SUBSTRING(TARIKH_MSHLOCH, 1, 4) + '-' + SUBSTRING(TARIKH_MSHLOCH, 5, 2) AS [Date]#(lf)    FROM TEODOT_MSHLOCH TM#(lf)    LEFT JOIN GORMIM G#(lf)        ON TM.QOD_MQBL = G.QOD_GORM    -- Customer#(lf)    LEFT JOIN GORMIM W#(lf)        ON TM.QOD_SHOLCH = W.QOD_GORM  -- Supplier / source#(lf)    LEFT JOIN QISHOR_RCSH_LMCIRH a#(lf)        ON a.MS_TEODT_MCIRH = TM.MS_TEODH#(lf)    LEFT JOIN QISHOR_T_MSHLOCH_HZMNOT b#(lf)        ON a.MS_TEODT_RCSH = b.MS_T_MSHLOCH#(lf)    LEFT JOIN QISHOR_T_MSHLOCH_HZMNOT bb#(lf)        ON bb.MS_T_MSHLOCH = TM.MS_TEODH#(lf)    WHERE 1 = 1#(lf)      AND TM.MCHIR_ICH = 0                          -- Only free/loaned shipments#(lf)      AND G.AOPI_PEILOT NOT IN (N'פחת', N'אחסון')  -- Exclude waste/storage#(lf)    GROUP BY#(lf)        SUBSTRING(TARIKH_MSHLOCH, 1, 4) + '-' + SUBSTRING(TARIKH_MSHLOCH, 5, 2),#(lf)        TM.QOD_SHOLCH,#(lf)        W.SHM_GORM,#(lf)        b.MS_HZMNH,#(lf)        CONVERT(VARCHAR, TM.QOD_MOTSR) + '-' + CONVERT(VARCHAR, TM.QOD_MOTSR),#(lf)        G.QOD_GORM,#(lf)        G.SHM_GORM,#(lf)        bb.MS_HZMNH#(lf)),#(lf)#(lf)base AS (#(lf)    -- Link exchange movements to USD unit price from totals (only PNLKey=999 and non-zero order qty)#(lf)    SELECT DISTINCT#(lf)        a.*,#(lf)        b.UnitNetPriceUSD,#(lf)#(tab)#(tab)b.LineTotalNetUSD,#(lf)#(tab)#(tab)b.OrderQuantity #(lf)    FROM main a#(lf)    LEFT JOIN (#(lf)        SELECT *#(lf)        FROM totals#(lf)        WHERE PNLKey = 999#(lf)          AND OrderQuantity <> 0#(lf)    ) b#(lf)        ON a.PurchaseOrderID = b.PurchaseOrderID#(lf)    WHERE a.[Date] >= '2024-01'#(lf)),#(lf)#(lf)purchase_orders AS (#(lf)    -- Aggregate original purchase orders (P-type) by item and counterparty#(lf)    SELECT #(lf)        DeliveredFrom,#(lf)        DeliveredFromName,#(lf)        PurchaseOrderID,#(lf)        ItemKey,#(lf)        SUM(qty_loaned) AS quantity,#(lf)        DeliveredTo,#(lf)        DeliveredToName,#(lf)        [Date] AS Purchase_Date,#(lf)        MAX(UnitNetPriceUSD) AS max_unit_price,#(lf)#(tab)#(tab)MAX(LineTotalNetUSD) as max_LineTotalNetUSD,#(lf)#(tab)#(tab)MAX(OrderQuantity)#(tab) as max_OrderQuantity#(lf)    FROM base#(lf)    WHERE Order_Type = 'P'#(lf)    GROUP BY #(lf)        DeliveredFrom,#(lf)        DeliveredFromName,#(lf)        PurchaseOrderID,#(lf)        ItemKey,#(lf)        DeliveredTo,#(lf)        DeliveredToName,#(lf)        [Date]#(lf)),#(lf)#(lf)final AS (#(lf)    -- Match exchange (E/P) movements to the most recent purchase within 0–3 months#(lf)    SELECT #(lf)        b.DeliveredFrom,#(lf)        b.DeliveredFromName,#(lf)        b.PurchaseOrderID AS Exchange_order,#(lf)        b.[Date] AS Exchange_Order_Date,#(lf)        b.ItemKey,#(lf)        b.qty_loaned AS Qty_Sold,#(lf)        p.PurchaseOrderID AS Purchase,#(lf)        p.Purchase_Date,#(lf)        ROW_NUMBER() OVER (#(lf)            PARTITION BY b.ItemKey, b.PurchaseOrderID#(lf)            ORDER BY p.Purchase_Date DESC#(lf)        ) AS rn,#(lf)        p.quantity,#(lf)        p.max_unit_price AS UnitNetPriceUSD,#(lf)#(tab)#(tab)p.max_LineTotalNetUSD as LineTotalNetUSD,#(lf)#(tab)#(tab)p.max_OrderQuantity as OrderQuantity#(lf)    FROM base b #(lf)    LEFT JOIN purchase_orders p#(lf)        ON b.DeliveredFrom = p.DeliveredTo#(lf)       AND b.ItemKey = p.ItemKey#(lf)    WHERE 1 = 1#(lf)      -- Month-diff between exchange date and purchase date between 0 and 3#(lf)      AND CONVERT(INT, SUBSTRING(b.[Date], 1, 4) + SUBSTRING(b.[Date], 6, 2))#(lf)        - CONVERT(INT, SUBSTRING(p.Purchase_Date, 1, 4) + SUBSTRING(p.Purchase_Date, 6, 2))#(lf)        BETWEEN 0 AND 3#(lf)),#(lf)final2 as (#(lf)SELECT #(lf)    DeliveredFrom,#(lf)    DeliveredFromName,#(lf)    Exchange_order,#(lf)    Exchange_Order_Date,#(lf)    ItemKey,#(lf)    Qty_Sold,#(lf)    Purchase,#(lf)    Purchase_Date,#(lf)    UnitNetPriceUSD,#(lf)#(tab)LineTotalNetUSD,#(lf)#(tab)OrderQuantity#(lf)FROM final#(lf)WHERE 1 = 1 #(lf)  AND rn = 1#(lf)  AND Exchange_order IS NOT NULL #(lf)  AND UnitNetPriceUSD IS NOT NULL#(lf) -- and Purchase = 20005431#(lf)--order by Exchange_Order_Date desc, Exchange_order#(lf))#(lf)--select * from final2#(lf)--where Exchange_order = 133902#(lf)-----------------------------------------------------------------------------------------------------------------------------------------------#(lf)#(lf)SELECT#(lf)'1' as 'EntityID'#(lf)        ,CAST(HS.NOMRTOR AS VARCHAR) AS 'ExpenseOrderID'#(lf)#(tab)#(tab)--,CAST(HZ.MSPR_HZMNH AS VARCHAR) AS 'OrderID'#(lf)#(tab)#(tab),CAST(HS.MS_MSMKH_QSHOR  AS VARCHAR) AS 'OrderID'--'PurchaseOrderID'#(lf)#(tab)#(tab)--,CONCAT(CAST(POL.POL_OrderID AS VARCHAR(20)),CAST(POL.POL_LineID AS VARCHAR(10)))#(lf)#(tab)#(tab),CONCAT(#(lf)#(tab)#(tab)#(tab)CAST(CONVERT(BIGINT, POL.POL_OrderID) AS VARCHAR(20)),#(lf)#(tab)#(tab)#(tab)CAST(POL.POL_LineID AS VARCHAR(10))#(lf)#(tab)#(tab) )#(tab)as 'PurchaseOrderID'#(lf)#(tab)#(tab),HS.SHORH AS 'OrderLineNumber'#(lf)#(tab)#(tab),'Order Expenses' AS 'DocName'#(lf)#(tab)#(tab)--,CAST(CONVERT(INT, CONVERT(VARCHAR,HS.QOD_GORM_MQBL))as varchar) AS 'AccountKey' -- customer from invoices in case you need just invoices #(lf)#(tab)#(tab),CAST(CONVERT(INT, CONVERT(VARCHAR,HC.QOD_SPQ))as varchar) AS 'SupplierKey'#(lf)#(tab)#(tab),CAST(#(lf)#(tab)#(tab)  MAX(#(lf)#(tab)#(tab)#(tab)CASE WHEN HS.QOD_SHROT = 0#(lf)#(tab)#(tab)#(tab)#(tab) THEN CONVERT(INT, CONVERT(VARCHAR, HC.QOD_SPQ))#(lf)#(tab)#(tab)#(tab)END#(lf)#(tab)#(tab)  ) OVER (PARTITION BY HS.MS_MSMKH_QSHOR)#(lf)#(tab)#(tab)#(tab)AS VARCHAR)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS 'OrderSupplierKey'#(lf)#(tab)#(tab),CAST(CONVERT(INT, CONVERT(VARCHAR,hz.QOD_MQBL))as varchar) AS 'SourceKey'#(lf)#(tab)#(tab)--,NULL AS 'Transport Type'--M.SHM_MOBIL AS 'Transport Type'#(lf)#(tab)#(tab)--,SUBSTRING(HZ.T_ASPQH,1,4) + '-' + SUBSTRING(HZ.T_ASPQH,5,2) + '-' + SUBSTRING(HZ.T_ASPQH,7,2) as 'Supply Date'#(lf)#(tab)#(tab)--,SUBSTRING(HZ.T_HZMNH,1,4) + '-' + SUBSTRING(HZ.T_HZMNH,5,2) + '-' + SUBSTRING(HZ.T_HZMNH,7,2) as 'Order Date'#(lf)        --,SUBSTRING(HS.T_ERKH,1,4) + '-' + SUBSTRING(HS.T_ERKH,5,2) + '-' + SUBSTRING(HS.T_ERKH,7,2) as 'Value Date'#(lf)#(tab)#(tab)--,SUBSTRING(HS.T_BITSOE,1,4) + '-' + SUBSTRING(HS.T_BITSOE,5,2) + '-' + SUBSTRING(HS.T_BITSOE,7,2) as 'Value Date'#(lf)#(tab)#(tab) -- grab the header-string once per order, convert to date, then expose on every row#(lf)#(tab)#(tab),CASE #(lf)#(tab)#(tab)#(tab)WHEN HS.MS_MSMKH_QSHOR = 0 #(lf)#(tab)#(tab)#(tab)  THEN CONVERT(date, HC.T_ERKH, 112)#(lf)#(tab)#(tab)#(tab)ELSE#(lf)#(tab)#(tab)#(tab)  -- pull the header-row date per order (using corrected key)#(lf)#(tab)#(tab)#(tab)  MAX(#(lf)#(tab)#(tab)#(tab)#(tab)CASE WHEN HS.QOD_SHROT = 0 #(lf)#(tab)#(tab)#(tab)#(tab)#(tab) THEN CONVERT(date, HC.T_ERKH, 112) #(lf)#(tab)#(tab)#(tab)#(tab)END#(lf)#(tab)#(tab)#(tab)  ) OVER (#(lf)#(tab)#(tab)#(tab)#(tab)PARTITION BY #(lf)#(tab)#(tab)#(tab)#(tab)  CASE #(lf)#(tab)#(tab)#(tab)#(tab)#(tab)WHEN HS.MS_MSMKH_QSHOR = 0 #(lf)#(tab)#(tab)#(tab)#(tab)#(tab)  THEN HZ.MSPR_HZMNH #(lf)#(tab)#(tab)#(tab)#(tab)#(tab)ELSE HS.MS_MSMKH_QSHOR #(lf)#(tab)#(tab)#(tab)#(tab)  END#(lf)#(tab)#(tab)#(tab)  )#(lf)#(tab)#(tab)  END AS 'Value Date'#(lf)#(tab)#(tab),SUBSTRING(HS.T_HQLDH,1,4) + '-' + SUBSTRING(HS.T_HQLDH,5,2) + '-' + SUBSTRING(HS.T_HQLDH,7,2) as 'EntryDate'#(lf)#(tab)#(tab),cast(CONVERT(INT, CONVERT(VARCHAR,HS.QOD_MOTSR)) as varchar)+ '-' + cast(CONVERT(INT, CONVERT(VARCHAR,HS.QOD_MOTSR)) as varchar) AS 'ItemKey_backup'#(lf)#(tab)#(tab),CASE#(lf)#(tab)#(tab)#(tab)--WHEN  HST.QOD_SHROT IS NULL THEN cast(CONVERT(INT, CONVERT(VARCHAR,HS.QOD_MOTSR)) as varchar)+ '-' + cast(CONVERT(INT, CONVERT(VARCHAR,HS.QOD_MOTSR)) as varchar) - לפני שינוי של העמסת עלויות#(lf)#(tab)#(tab)#(tab)WHEN  HST.QOD_SHROT IS NULL OR HS.QOD_SHROT IN (5, 19, 30, 4) THEN cast(CONVERT(INT, CONVERT(VARCHAR,HS.QOD_MOTSR)) as varchar)+ '-' + cast(CONVERT(INT, CONVERT(VARCHAR,HS.QOD_MOTSR)) as varchar) -- העמסת עליות הובלה והפרש מחיר על המוצר#(lf)#(tab)#(tab)#(tab)ELSE cast(CONVERT(INT, CONVERT(VARCHAR,HS.QOD_MOTSR)) as varchar)+ '-' + cast(CONVERT(INT, CONVERT(VARCHAR,HST.QOD_SHROT)) as varchar)+'S' #(lf)#(tab)#(tab)#(tab)END#(tab)#(tab)AS 'ItemKey'#(lf)#(tab)#(tab)/*,CASE#(lf)#(tab)         WHEN HS.MTBE = '$' THEN HS.MCHIR_ICH#(lf)#(tab)#(tab)   --THEN CAST(HZ.MCHIR_ICH AS decimal (12,4))#(lf)#(tab)         ELSE CAST(HS.MCHIR_ICH *(1/CASE WHEN HC.SHER_MTBE=0 THEN 1 ELSE HC.SHER_MTBE END)  AS decimal (12,4))#(lf)         END AS 'UnitNetPriceUSD'*/ #(lf)#(tab)#(tab) ,CASE#(lf)#(tab)#(tab)#(tab)WHEN HST.QOD_SHROT IS NOT NULL THEN#(lf)#(tab)#(tab)#(tab)#(tab)CASE #(lf)#(tab)#(tab)#(tab)#(tab)#(tab)WHEN HS.MTBE = '$' THEN #(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)CAST(HS.MCHIR_ICH / NULLIF(POL.POL_FinalWeightReceived, 0) AS decimal(12,4))#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)WHEN HS.MTBE = 'Eur' THEN#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)CAST(#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)HS.MCHIR_ICH * (SM.NEW_SHEREURO/SM.NEW_SHER) / NULLIF(POL.POL_FinalWeightReceived, 0)#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS decimal(12,4)#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab))#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)ELSE #(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)CAST(#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)HS.MCHIR_ICH * (1 / NULLIF(HC.SHER_MTBE, 0)) / NULLIF(POL.POL_FinalWeightReceived, 0)#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS decimal(12,4)#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab))#(lf)#(tab)#(tab)#(tab)#(tab)END#(lf)#(tab)#(tab)#(tab)ELSE #(lf)#(tab)#(tab)#(tab)#(tab)CASE #(lf)#(tab)#(tab)#(tab)#(tab)#(tab)WHEN HS.MTBE = '$' THEN HS.MCHIR_ICH#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)WHEN HS.MTBE = 'Eur' THEN#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)CAST(#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)HS.MCHIR_ICH * (SM.NEW_SHEREURO/SM.NEW_SHER)#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS decimal(12,4)#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab))#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)ELSE #(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)CAST(#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)HS.MCHIR_ICH * (1 / NULLIF(HC.SHER_MTBE, 0)) #(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS decimal(12,4)#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab))#(lf)#(tab)#(tab)#(tab)#(tab)END#(lf)#(tab)#(tab)END AS 'UnitNetPriceUSD'#(lf)#(tab)#(tab),HS.MTBE#(lf)#(tab)#(tab),HS.CMOT AS 'Quantity'#(lf)#(tab)#(tab)--,POL.POL_FinalWeightReceived as tst#(lf)#(tab)#(tab)--,HZ.CMOT_MOZMNT AS 'OrderQuantity1' -- מוריד לבדיקה#(lf)#(tab)#(tab),CASE WHEN HS.QOD_SHROT = 0 then HS.CMOT#(lf)#(tab)#(tab)#(tab)#(tab)ELSE 0#(lf)#(tab)#(tab)#(tab)#(tab)END#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS 'OrderQuantity'#(lf)#(tab)#(tab)--,ISNULL(HST.QOD_SHROT,999) AS 'PNLKey'#(lf)#(tab)#(tab),CASE #(lf)#(tab)#(tab)#(tab)WHEN HST.QOD_SHROT IN (5, 19, 30, 4,18) OR HST.QOD_SHROT IS NULL #(lf)#(tab)#(tab)#(tab)THEN 999#(lf)#(tab)#(tab)#(tab)ELSE HST.QOD_SHROT#(lf)#(tab)#(tab)END#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS 'PNLKey'  ----------  העמסת עליות הובלה על המ