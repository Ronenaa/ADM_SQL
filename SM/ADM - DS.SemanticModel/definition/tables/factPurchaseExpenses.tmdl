table factPurchaseExpenses
	lineageTag: e89423a5-0ca5-40f5-88a7-a6668858d8ac

	measure 'Total Quantity (Expenses)' = SUM(factPurchaseExpenses[Quantity])
		formatString: 0.00
		lineageTag: da0d73d4-2042-4828-97e2-e199f944b3f7

		changedProperty = IsHidden

	measure 'Total Expenses NIS' = SUM(factPurchaseExpenses[LineTotalNetNIS])
		formatString: "₪"\ #,0.00;"₪"-#,0.00;"₪"\ #,0.00
		lineageTag: a87eb6f1-2fd2-4cf7-a17d-1dfbf12653d7

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"currencyCulture":"he-IL"}

	measure 'Total Expenses USD' = SUM(factPurchaseExpenses[LineTotalNetUSD])
		formatString: \$#,0;(\$#,0);\$#,0
		lineageTag: 8a69ff38-48ce-496f-bccd-7231b1b9e523

		changedProperty = IsHidden

	measure 'Total Order Quantity (Hzmnot)' = SUM(factPurchaseExpenses[OrderQuantity])
		formatString: #,0
		lineageTag: 4044acc3-f43f-40d4-9c6d-3433235e9663

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'Avg Price USD (Expenses)' = DIVIDE([Total Expenses USD],[Total Order Quantity (Hzmnot)])
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		lineageTag: 71f52325-9586-47d4-941b-2932f4fe42ec

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure PurchaseOrderDetailsMatrix = ```
			
			IF(HASONEVALUE(factPurchaseExpenses[ShipID]),
			SWITCH(
			    SELECTEDVALUE(hlp_ExpensesMatrixTableFileds[Filed]),
			
			    --"Boat", SELECTEDVALUE(dimBoats[ShipDesc]),
			    --"Supplier", SELECTEDVALUE(dimSuppliersCompare[Supplier Name]),
			    "Supplier",
			            LOOKUPVALUE(
			                dimSuppliersCompare[Supplier Name],
			                dimSuppliersCompare[SupplierKey], 
			                SELECTEDVALUE(factPurchaseExpenses[OrderSupplierKey])
			            ),
			   /* "Product", --SELECTEDVALUE(factPurchaseExpenses[ItemKey_backup]),--SELECTEDVALUE(dimItemsSimple[שם מוצר]),
			            LOOKUPVALUE(
			                        dimItemsSimple[Article_Description],
			                        dimItemsSimple[ItemKey], 
			                        SELECTEDVALUE(factPurchaseExpenses[ItemKey_backup])
			                    ),*/
			    --"OrderID", SELECTEDVALUE('factPurchaseExpenses'[OrderID]),
			    "OrderDate", FORMAT(SELECTEDVALUE('factPurchaseExpenses'[OrderDate]), "dd/mm/yyyy"),
			    "SupplyDate", FORMAT(SELECTEDVALUE('factPurchaseExpenses'[Value Date]), "dd/mm/yyyy"),
			    "Quantity", FORMAT([Total Order Quantity (Hzmnot)], "#,##0.00"),
			    "Order Type",
			            LOOKUPVALUE(
			                        dimTransactionType[Desc],
			                        dimTransactionType[ID], 
			                        SELECTEDVALUE(factPurchaseExpenses[TransactionType])
			                    ),
			    "CIF Price", FORMAT([CIF Price], "$#,##0.00"),
			    BLANK()
			),BLANK())
			```
		lineageTag: 91f990ab-c34f-45e1-8671-7c9907251a45

		changedProperty = IsHidden

	measure 'CIF Price' =
			
			CALCULATE([Avg Price USD (Expenses)]
			            ,dimItems[PNL Description] = "Purchase Inventory"
			)
			
			/*DIVIDE(
			    CALCULATE(
			        [Total Expenses USD],
			        dimItems[PNL Description] = "Purchase Inventory"
			    ),
			    [Total Order Quantity (Hzmnot)]
			)*/
		formatString: \$#,0.0;(\$#,0.0);\$#,0.0
		lineageTag: f07f0282-e466-4fc3-abfa-e19e2b43c81a

		changedProperty = IsHidden

	measure 'Total Order Quantity Order date' =
			
			CALCULATE([Total Order Quantity (Hzmnot)],
			            USERELATIONSHIP(dimDates[Date],factPurchaseExpenses[OrderDate]
			            ))
		lineageTag: c57b76e5-92ba-4797-807d-703cb9ec3ecb

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Avg Unit Price (weighted)' = ```
			
			SUMX(
			    ADDCOLUMNS(
			        factPurchaseExpenses,
			        "RealItemQtyForThisOrder",
			            CALCULATE(
			                SUM( factPurchaseExpenses[OrderQuantity] ),
			                FILTER(
			                    ALLEXCEPT(
			                        factPurchaseExpenses,
			                        factPurchaseExpenses[PurchaseOrderID]
			                    ),
			                    RIGHT( factPurchaseExpenses[ItemKey], 1 ) <> "S"
			                    
			                )
			            )
			    ),
			    DIVIDE(
			        factPurchaseExpenses[LineTotalNetUSD],
			        [RealItemQtyForThisOrder]
			    )
			)
			```
		formatString: \$#,0.0;(\$#,0.0);\$#,0.0
		lineageTag: 86353866-fade-47a6-a741-ac24d5a6160a

		changedProperty = IsHidden

	measure 'Boat & MonthYear Show' =
			
			VAR _Boat =
			    SELECTEDVALUE( 'dimBoats'[ShipDesc] )
			VAR _Date =
			    SELECTEDVALUE( 'factPurchaseExpenses'[SupplyDate] )
			RETURN
			IF(
			    NOT( ISBLANK( _Boat ) )
			        && NOT( ISBLANK( _Date ) ),
			    _Boat
			        & " – "
			        & FORMAT( _Date, "MMM yyyy" ),
			   "Select Boat"
			)
		lineageTag: b25a2184-1442-49ae-a6ca-e4ab9dd84b70

		changedProperty = IsHidden

	measure 'Total Shortage Amount' =
			
			[Avg Price USD (Expenses)]*[Adjustment Quantity Shortage]
		lineageTag: 94993112-e9a6-4f28-a076-4b14cc0639d6

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Purchase Cost - AVG Price' =
			
			VAR _amount = [Total Shortage Amount] + [Total Expenses USD]
			VAR _quantity = [Adjustment Quantity Shortage] + [Total Order Quantity (Hzmnot)]
			RETURN
			DIVIDE(_amount,_quantity)
		lineageTag: f669438d-9140-49dc-80cc-8027bdaf414e

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Port_Name =
			
			CALCULATE(
			    SELECTEDVALUE(dimSuppliersCompare[Supplier Name]),
			    FILTER(
			        ALL(factGain),
			        factGain[PurchaseOrderID] in VALUES(factGain[PurchaseOrderID])
			    )
			)
		lineageTag: 167606e7-f7ed-4dc1-b58f-4886e4ea3f0d

		changedProperty = IsHidden

	measure 'USD rate by order date' = ```
			
			IF(
			    ISFILTERED(dimPurchaseOrderNumber[PurchaseOrderID]),
			        CALCULATE(
			            max(factPurchaseExpenses[NEW_SHER]),    
			            FILTER(factPurchaseExpenses,factPurchaseExpenses[PNLKey] = 999)
			            // ,REMOVEFILTERS(dimSuppliers)
			            // ,REMOVEFILTERS(dimItems)
			            // ,REMOVEFILTERS(factGain)
			        ),
			        BLANK()
			)
			```
		formatString: 0.000
		lineageTag: fdd3e630-cf8a-4813-b486-974912ff6b7d

		changedProperty = IsHidden

	measure 'Quantity Exchange or Purchase' = ```
			
			var exchange_doc = SELECTEDVALUE(factPurchaseExpenses[DocName])
			RETURN
			IF(
			    exchange_doc = "Orders",
			    factSales[Total Quantity Adjustment+Sales],
			    factPurchaseExpenses[Total Order Quantity (Hzmnot)]
			)
			
			```
		lineageTag: 362d37b1-b865-4bae-97d2-176c4008cdbb

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Avg Price USD (Expenses) Non Invoice' =
			
			CALCULATE(
			    DIVIDE([Total Expenses USD],[Total Order Quantity (Hzmnot)]),
			    FILTER(factPurchaseExpenses,factPurchaseExpenses[DocType] <> "Invoice")
			)
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		lineageTag: b5eb8d94-f2a6-4249-af92-ee59075da982

	measure Total_Balance_NIS =
			
			CALCULATE(
			    SUM(factPurchaseExpenses[LineTotalBalanceNIS]),
			    REMOVEFILTERS(dimSuppliers),
			    REMOVEFILTERS(dimItems),
			    KEEPFILTERS(dimPurchaseOrderNumber)
			)
		formatString: "₪"#,0.00;-"₪"#,0.00;"₪"#,0.00
		lineageTag: 932771eb-3b4f-422e-923c-6ddb400fb219

		annotation PBI_FormatHint = {"currencyCulture":"en-IL"}

	measure Total_Balance_USD =
			
			CALCULATE(
			    SUM(factPurchaseExpenses[LineTotalBalanceUSD]),
			    REMOVEFILTERS(dimSuppliers),
			    REMOVEFILTERS(dimItems),
			    KEEPFILTERS(dimPurchaseOrderNumber)
			)
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		lineageTag: 703730b5-c8b2-4b1e-986e-87b00fbc4c05

	measure Total_Net_USD =
			
			CALCULATE(
			    SUM(factPurchaseExpenses[LineTotalNetUSD]),
			    REMOVEFILTERS(dimSuppliers),
			    REMOVEFILTERS(dimItems),
			    KEEPFILTERS(dimPurchaseOrderNumber)
			)
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		lineageTag: f92a90ef-9800-4acd-931f-285b4aa7b4ba

