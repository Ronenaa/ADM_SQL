    AS [סטטוס],#(lf)     NULL                                    AS Details,#(lf)     NULL                               AS ServiceDetail,#(lf)     NULL                                    AS ShipID,#(lf)     NULL                                   AS OrderDate,#(lf)     NULL                                  AS SupplyDate,#(lf)     GETDATE()                      AS RowInsertDatetime,#(lf)     'Invoice'                          AS ExpenseSource,#(lf)     NULL                             AS TransactionType,#(lf)    'Invoice'                                AS DocType,#(lf)#(tab)CASE WHEN SHER_LCHISHOB <> 0 THEN SHER_LCHISHOB ELSE CC2.new_sher END#(lf)#(lf)FROM [dbo].[CHIOBI_CHOTS_COTROT] CC#(lf)LEFT JOIN GORMIM G2#(lf)       ON CC.QOD_LQOCH = G2.QOD_GORM#(lf)LEFT JOIN TBLT_ANSHI_MCIROT AM2#(lf)       ON AM2.SHM_AISH_MCIROT = G2.AISH_MCIROT_MTPL#(lf)LEFT JOIN [dbo].[CHIOBI_CHOTS_SHOROT] CCS#(lf)       ON CC.MS_CHSHBONIT = CCS.MS_CHSHBONIT#(lf)LEFT JOIN CurrencyConvertion CC2#(lf)       ON CCS.[TARIKH_MSHLOCH] = CC2.Tarikh#(lf)LEFT JOIN ( ---- Connect to the base purchase in order to get the relative productID#(lf)#(tab)#(tab)#(tab)select DISTINCT#(lf)#(tab)#(tab)#(tab)POL_SQL_POID, POL_ProductID#(lf)#(tab)#(tab)#(tab)from PurchaseOrderLines POL#(lf)#(tab)#(tab)#(tab)) POL#(lf)#(tab)#(tab)ON CCS.HZMNT_RCSH = POL.POL_SQL_POID#(lf)LEFT JOIN MOTSRIM M#(lf)#(tab)ON CCS.QOD_MOTSR = M.QOD_MOTSR#(lf)LEFT JOIN HOTSAOT_SHROTIM_New HST #(lf)#(tab)ON M.ServiceCode = HST.QOD_SHROT#(lf)#(lf)UNION ALL#(lf)#(lf)SELECT#(lf)    '1'                                                                 AS EntityID,#(lf)    NULL                                                                AS ExpenseOrderID,#(lf)    CAST(HZ.MSPR_HZMNH AS VARCHAR)                                      AS OrderID,#(lf)    HZ.MSPR_HZMNH                                                       AS PurchaseOrderID,#(lf)    NULL                                                                AS OrderLineNumber,#(lf)    'Orders'                                                            AS DocName,#(lf)    HZ.QOD_SHOLCH                                                                AS SupplierKey,#(lf)    NULL                                                                AS OrderSupplierKey,#(lf)#(tab)NULL#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS SourceKey,#(lf)#(lf)    -- Supply date as value date#(lf)    CAST(SUBSTRING(HZ.T_ASPQH,1,4) + '-' + SUBSTRING(HZ.T_ASPQH,5,2) + '-' + SUBSTRING(HZ.T_ASPQH,7,2)#(lf)         AS DATE)                                                       AS [Value Date],#(lf)#(lf)    -- Order date as entry date#(lf)    CAST(SUBSTRING(HZ.T_HZMNH,1,4) + '-' + SUBSTRING(HZ.T_HZMNH,5,2) + '-' + SUBSTRING(HZ.T_HZMNH,7,2)#(lf)         AS DATE)                                                       AS EntryDate,#(lf)#(lf)    -- Item key (must match totals.ItemKey)#(lf)    CAST(CONVERT(INT, CONVERT(VARCHAR,HZ.MOTSR_MOZMN)) AS VARCHAR) + '-' +#(lf)    CAST(CONVERT(INT, CONVERT(VARCHAR,HZ.MOTSR_MOZMN)) AS VARCHAR)      AS ItemKey_backup,#(lf)    CAST(CONVERT(INT, CONVERT(VARCHAR,HZ.MOTSR_MOZMN)) AS VARCHAR) + '-' +#(lf)    CAST(CONVERT(INT, CONVERT(VARCHAR,HZ.MOTSR_MOZMN)) AS VARCHAR)      AS ItemKey,#(lf)#(lf)    -- >>> Take unit price from totals (Avg Price USD (Expenses))#(lf)    t.UnitNetPriceUSD                                                   AS UnitNetPriceUSD,#(lf)#(lf)    HZ.MTBE                                                             AS MTBE,#(lf)#(lf)    -- Physical ordered quantity (for reference)#(lf)    HZ.CMOT_MOZMNT                                                      AS Quantity,#(lf)#(lf)#(tab)--HZ.CMOT_MOZMNT#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AS 'OrderQuantity',#(lf)#(lf)     -->>> Order quantity used by DAX = from totals#(lf)    t.OrderQuantity                                                     AS OrderQuantity,#(lf)#(lf)    999                                                                 AS PNLKey,#(lf)    (HZ.CMOT_MOZMNT - HZ.CMOT_SHSOPQH)                                  AS Balance,#(lf)    NULL                                                                AS LineTotalCost,#(lf)#(lf)    -- >>> Total expenses in USD from totals (feeds Total Expenses USD in DAX)#(lf)    t.LineTotalNetUSD                                                  AS LineTotalNetUSD,#(lf)#(lf)    -- Balance in USD can stay based on HZ (business choice)#(lf)    CASE#(lf)        WHEN HZ.MTBE = '$' THEN CAST(HZ.MCHIR_ICH * (HZ.CMOT_MOZMNT - HZ.CMOT_SHSOPQH) AS DECIMAL(12,4))#(lf)        ELSE CAST(HZ.MCHIR_ICH * (HZ.CMOT_MOZMNT - HZ.CMOT_SHSOPQH) * (1 / NULLIF(SM.NEW_SHER, 0))#(lf)                  AS DECIMAL(12,4))#(lf)    END                                                                 AS LineTotalBalanceUSD,#(lf)#(lf)    -- NIS fields (unchanged)#(lf)    CASE#(lf)        WHEN HZ.MTBE = '$' THEN CAST(HZ.MCHIR_ICH * SM.NEW_SHER AS DECIMAL(12,4))#(lf)        ELSE CAST(HZ.MCHIR_ICH AS DECIMAL(12,4))#(lf)    END                                                                 AS UnitNetPriceNIS,#(lf)    CASE#(lf)        WHEN HZ.MTBE = '$' THEN CAST(HZ.MCHIR_ICH * SM.NEW_SHER * HZ.CMOT_MOZMNT AS DECIMAL(12,4))#(lf)        ELSE CAST(HZ.MCHIR_ICH * HZ.CMOT_MOZMNT AS DECIMAL(12,4))#(lf)    END                                                                 AS LineTotalNetNIS,#(lf)    CASE#(lf)        WHEN HZ.MTBE = '$' THEN CAST(HZ.MCHIR_ICH * SM.NEW_SHER * (HZ.CMOT_MOZMNT - HZ.CMOT_SHSOPQH)#(lf)                                     AS DECIMAL(12,4))#(lf)        ELSE CAST(HZ.MCHIR_ICH * (HZ.CMOT_MOZMNT - HZ.CMOT_SHSOPQH) AS DECIMAL(12,4))#(lf)    END                                                                 AS LineTotalBalanceNIS,#(lf)#(lf)    CONVERT(INT, CONVERT(VARCHAR, SUBSTRING(HZ.T_ASPQH,1,4) + SUBSTRING(HZ.T_ASPQH,5,2))) AS YearMonth,#(lf)    HZ.OrderStatus                                                      AS [סטטוס],#(lf)    NULL                                                                AS Details,#(lf)    NULL                                                                AS ServiceDetail,#(lf)    NULL                                                                AS ShipID,#(lf)#(lf)    CAST(SUBSTRING(HZ.T_HZMNH,1,4) + '-' + SUBSTRING(HZ.T_HZMNH,5,2) + '-' + SUBSTRING(HZ.T_HZMNH,7,2)#(lf)         AS DATE)                                                       AS OrderDate,#(lf)    CAST(SUBSTRING(HZ.T_ASPQH,1,4) + '-' + SUBSTRING(HZ.T_ASPQH,5,2) + '-' + SUBSTRING(HZ.T_ASPQH,7,2)#(lf)         AS DATE)                                                       AS SupplyDate,#(lf)#(lf)    GETDATE()                                                           AS RowInsertDatetime,#(lf)    'Orders'                                                            AS ExpenseSource,#(lf)    OP.ActionType                                                       AS TransactionType,#(lf)    'Order'                                                             AS DocType,#(lf)    SM.NEW_SHER#(lf)FROM HZMNOT HZ#(lf)LEFT JOIN CurrencyConvertion SM#(lf)    ON SM.TARIKH = HZ.T_HZMNH#(lf)#(lf)-- >>> Join to totals (same source as first query)#(lf)LEFT JOIN final2 t#(lf)    ON t.Exchange_order = HZ.MSPR_HZMNH#(lf)   AND t.ItemKey =#(lf)        CAST(CONVERT(INT, CONVERT(VARCHAR,HZ.MOTSR_MOZMN)) AS VARCHAR) + '-' +#(lf)        CAST(CONVERT(INT, CONVERT(VARCHAR,HZ.MOTSR_MOZMN)) AS VARCHAR)#(lf)#(lf)LEFT JOIN OrderPrices OP#(lf)    ON OP.OrderID = HZ.MSPR_HZMNH#(lf)WHERE CAST(SUBSTRING(HZ.T_HZMNH,1,4) AS INT) BETWEEN 2018 AND YEAR(GETDATE())#(lf)  AND HZ.OrderStatus <> 3#(lf)  AND HZ.ActionType IN (6,7)#(lf)--and hz.MSPR_HZMNH = 20005361#(lf)"]),
