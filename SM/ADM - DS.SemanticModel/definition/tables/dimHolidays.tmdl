	partition dimHolidays-1f7668fe-51f4-449e-9090-82cc19bf0a9c = m
		mode: import
		queryGroup: 'Dates Dim'
		source = ```
				let
				    Source = dimDates,
				    #"1 - Removed Other Columns" = Table.SelectColumns(Source,{"Date"}),
				    #"1 - Merged HolidayPivot TBL" = Table.NestedJoin(#"1 - Removed Other Columns",{"Date"},HolidayPivot,{"Date"},"HolidayPivot",JoinKind.Inner),
				    #"1 - Expanded HolidayPivot" = Table.ExpandTableColumn(#"1 - Merged HolidayPivot TBL", "HolidayPivot", {"HebYearID", "HebYearName", "HolidayID", "HolidayName", "Year"}, {"HebYearID", "HebYearName", "HolidayID", "HolidayName", "Year"}),
				    #"2 - Added list 30" = Table.AddColumn(#"1 - Expanded HolidayPivot", "DaysFromHoliday", each {-30..30}),
				    #"2 - Expanded DaysFromHoliday" = Table.ExpandListColumn(#"2 - Added list 30", "DaysFromHoliday"),
				    #"2 - Changed Type" = Table.TransformColumnTypes(#"2 - Expanded DaysFromHoliday",{{"DaysFromHoliday", Int64.Type}}),
				    #"2 - Added Date before+after" = Table.AddColumn(#"2 - Changed Type", "Custom Date", each Date.AddDays([Date], [DaysFromHoliday]),type date),
				    #"3 - Merged HolidayNotPivot" = Table.NestedJoin(#"2 - Added Date before+after",{"Custom Date"},HolidayNOTPivot,{"Date"},"HolidayNOTPivot",JoinKind.LeftOuter),
				    #"3 - Expanded HolidayNOTPivot" = Table.ExpandTableColumn(#"3 - Merged HolidayNotPivot", "HolidayNOTPivot", {"SpecialDayName"}, {"SpecialDayName"}),
				    #"4 - Added Days Category" = Table.AddColumn(#"3 - Expanded HolidayNOTPivot", "קטגורית ימים לחג", each if [SpecialDayName]<>null then [SpecialDayName] & " " & Number.ToText([DaysFromHoliday]) & " "
				else if [DaysFromHoliday]>0 then " ימים מ"&[HolidayName] & " " & Number.ToText([DaysFromHoliday]) & " "
				else " ימים ל"&[HolidayName] & " " & Number.ToText([DaysFromHoliday]) & " ", type text),
				    #"4 - Added DaysSort" = Table.AddColumn(#"4 - Added Days Category", "DaysSort", each [HolidayID]*1000 + [DaysFromHoliday], Int64.Type),
				    #"4 - Added Holiday Category" = Table.AddColumn(#"4 - Added DaysSort", "קבוצת חג", each if Text.Contains(
				if [SpecialDayName]<>null then [SpecialDayName] else Number.ToText([DaysFromHoliday]) 
				,[HolidayName]) then "חג"
				else if [DaysFromHoliday]<0 then "לפני חג"
				else "אחרי חג", type text),
				    #"4 - Added Holiday CategorySort" = Table.AddColumn(#"4 - Added Holiday Category", "HolidayCategorySort", each if [קבוצת חג]="חג" then 1
				else if [קבוצת חג]= "לפני חג" then 0
				else 2, Int64.Type),
				    #"5 - Removed Other Columns" = Table.SelectColumns(#"4 - Added Holiday CategorySort",{"HebYearID", "HebYearName", "HolidayID", "HolidayName", "Year", "DaysFromHoliday", "Custom Date", "קטגורית ימים לחג", "DaysSort", "קבוצת חג", "HolidayCategorySort"})
				in
				    #"5 - Removed Other Columns"
				```

	changedProperty = IsHidden

