table dimHolidays
	lineageTag: 4743208b-b1f6-4008-8460-d331d695c515

	measure 'מכירות חגים' =
			
			SUMX(dimHolidays,
				[Total Sales]
			)
		formatString: #,0
		lineageTag: 1e58f8e3-c219-46bd-b8fa-a0a5e4f1e5c7

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'מכירות חגים שנה נוכחית' =
			
			var maxYear = [This Holiday Year]
			return
			CALCULATE(
				[מכירות חגים],
				dimHolidays[Year]=maxYear
			)
		formatString: #,0
		lineageTag: 6f73ef98-7d15-46c9-ac88-c01f5e319f7f

		changedProperty = IsHidden

	measure 'מכירות חגים אשתקד' =
			
			var maxYear = [Previous Holiday Year]
			var maxDay = [Max Available Day - This Holiday Year]
			return
			CALCULATE(
			    [מכירות חגים],
				dimHolidays[Year]=maxYear,
			    FILTER(VALUES(dimHolidays[DaysFromHoliday]),dimHolidays[DaysFromHoliday]<=maxDay && NOT(ISBLANK(maxDay)))
			)
		formatString: #,0
		lineageTag: 71c8896f-b678-4e34-ba45-930908ed461c

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'שינוי מכירות חגים אשתקד' =
			
			[מכירות חגים שנה נוכחית]-[מכירות חגים אשתקד]
		formatString: #,0
		lineageTag: 53d810e2-a727-46dd-b42f-bea849f52e2a

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'אחוז רווח חגים' = ```
			
			DIVIDE([מכירות חגים]-[הוצאות חגים], 
			    [מכירות חגים],
			    BLANK())
			```
		lineageTag: 0806fea8-cf8b-4ca2-b192-fd177166e12f

		changedProperty = IsHidden

	measure 'הוצאות חגים' =
			
			SUMX(dimHolidays,
				[Total Cost]
			)
		formatString: #,0
		lineageTag: 38eb7581-7cde-47ce-b6f8-19c9fe458f04

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'אחוז רווח חגים שנה נוכחית' =
			
			var maxYear = [This Holiday Year]--CALCULATE(MAX(dimHolidays[HebYearID]), dimDates[IsHistory]=1)
			return
			CALCULATE(
				[אחוז רווח חגים],
				--dimHolidays[HebYearID]=maxYear
			    dimHolidays[year]=maxYear
			)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: b41e79bb-decc-4305-a8e3-6877e9f7fe8b

		changedProperty = IsHidden

	measure 'אחוז רווח חגים אשתקד' =
			
			var maxYear = [Previous Holiday Year]--CALCULATE(MAX(dimHolidays[HebYearID])-1, dimDates[IsHistory]=1)
			var maxDay = [Max Available Day - This Holiday Year]
			return
			CALCULATE(
				[אחוז רווח חגים],
				--ALLSELECTED(dimHolidays[HebYearID]),
				--dimHolidays[HebYearID]=maxYear
			    dimHolidays[Year]=maxYear,
			    FILTER(VALUES(dimHolidays[DaysFromHoliday]),dimHolidays[DaysFromHoliday]<=maxDay && NOT(ISBLANK(maxDay)))
			)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: bb480499-2708-417f-a2b0-76856899c431

		changedProperty = IsHidden

	measure 'ממוצע מכירות לעסקה חגים שנה נוכחית' =
			
			DIVIDE([מכירות חגים שנה נוכחית],[כמות עסקאות חגים שנה נוכחית])
		lineageTag: efe00d75-04f5-483c-a917-e4f2e9b26e2a

		changedProperty = IsHidden

	measure 'כמות עסקאות חגים' =
			
			SUMX(dimHolidays,
				[Transactions Quantity]
			)
		formatString: #,0
		lineageTag: a52c99a8-24ba-4d5c-9a43-3d9f718bcb85

		changedProperty = IsHidden

	measure 'כמות עסקאות חגים שנה נוכחית' =
			
			var maxYear = [This Holiday Year]
			return
			CALCULATE(
				[כמות עסקאות חגים],
				dimHolidays[Year]=maxYear
			)
		formatString: #,0
		lineageTag: c6964014-b65c-4c92-843b-988153208f1f

		changedProperty = IsHidden

	measure 'ממוצע מכירות לעסקה חגים אשתקד' =
			
			DIVIDE([מכירות חגים אשתקד],[כמות עסקאות חגים אשתקד])
		lineageTag: 449f01d1-6187-4815-8f4b-aec0382525c3

		changedProperty = IsHidden

	measure 'כמות עסקאות חגים אשתקד' =
			
			var maxYear = [Previous Holiday Year]
			var maxDay = [Max Available Day - This Holiday Year]
			return
			CALCULATE(
				[כמות עסקאות חגים],
				dimHolidays[Year]=maxYear,
			    FILTER(VALUES(dimHolidays[DaysFromHoliday]),dimHolidays[DaysFromHoliday]<=maxDay && NOT(ISBLANK(maxDay)))
			)
		formatString: #,0
		lineageTag: b76f923f-904b-43c8-a6ed-5e87696cfdc0

		changedProperty = IsHidden

	measure 'ממוצע מכירות ליום בחג' =
			
			DIVIDE([מכירות חגים],
				[כמות ימים עם מכירה])
		formatString: #,0
		lineageTag: 7b61ec2f-aba2-4aeb-93b4-58ff5aee647b

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'This Holiday Year' =
			
			IF(HASONEVALUE(dimHolidayYear[Year]), MAX(dimHolidayYear[Year]),
			CALCULATE(MAX(dimHolidays[Year]), dimDates[IsHistory]=1,  all(dimHolidays[DaysSort],dimHolidays[קבוצת חג],dimHolidays[קטגורית ימים לחג],dimHolidays[DaysFromHoliday],dimHolidays[HolidayCategorySort])))
		formatString: 0
		lineageTag: 238a26e0-2009-4af6-945a-74553a6e1093

		changedProperty = IsHidden

	measure 'Previous Holiday Year' =
			
			IF(HASONEVALUE(dimHolidayYear_Compare[Year]), MAX(dimHolidayYear_Compare[Year]),
			[This Holiday Year]-1)
		formatString: 0
		lineageTag: 464591ae-cc80-4aa3-a086-b1c204e19667

		changedProperty = IsHidden

	measure 'Max Available Day - This Holiday Year' =
			
			var maxYear = [This Holiday Year]
			return
			CALCULATE(
			CALCULATE(
			    MAX(dimHolidays[DaysFromHoliday]),
			    dimHolidays[Year] = maxYear,
			    FILTER(VALUES(dimHolidays[DaysFromHoliday]),
			        NOT(ISBLANK(CALCULATE([Total Sales],dimHolidays[Year] = maxYear))))
			)
			,all(dimHolidays[DaysSort],dimHolidays[קבוצת חג],dimHolidays[קטגורית ימים לחג],dimHolidays[DaysFromHoliday],dimHolidays[HolidayCategorySort]))
		formatString: 0
		lineageTag: 54e50f78-3524-47a4-ab27-ea4e00bcbaf6

		changedProperty = IsHidden

