table InventoryOtherOrAllParameter
	lineageTag: d02f5c67-fb85-43e4-a1ea-8cfb04197c8a

	measure 'InventoryOtherOrAll Switch' =
			
			SWITCH(MIN(InventoryOtherOrAllParameter[InventoryOtherOrAllParameter Order]),
			 0,[Inventory Balance - Quantity] - [Total Allocation Messages QTY] ,
			 1,[Inventory Balance - Quantity Other]
			 )
		lineageTag: e3cc72ce-61a8-436d-90a7-a94399f71b1a

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'InventoryOtherOrAll Value Switch' =
			
			SWITCH(MIN(InventoryOtherOrAllParameter[InventoryOtherOrAllParameter Order]),
			 0,[Inventory Balance - Value FOT],
			 1,[Inventory Balance - Value Other]
			 )
		lineageTag: 205c4612-ae13-4ba8-92c0-d4842a37fc4f

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'InventoryOtherOrAll Avg Value Switch' =
			
			SWITCH(MIN(InventoryOtherOrAllParameter[InventoryOtherOrAllParameter Order]),
			 0,[Inventory Balance - Avg Value FOT],
			 1,[Inventory Balance - Avg Value Other]
			 )
		lineageTag: c84d5a69-7b53-4222-93bc-c51273955ad9

		annotation PBI_FormatHint = {"isGeneralNumber":true}

