	partition dimBoats = m
		mode: import
		queryGroup: Dim
		source =
				let
				    Source = Sql.Database(#"SQL Address", "MT", [Query="WITH LatestLoading AS (#(lf)    SELECT#(lf)        SA_ShipID,#(lf)        MAX(SA_DateForLoadingfrom) AS MaxLoadingFromDate#(lf)    FROM ShipsArrivals#(lf)    GROUP BY SA_ShipID#(lf))#(lf), RankedShips AS (#(lf)    SELECT#(lf)        sl.*,#(lf)        ll.MaxLoadingFromDate,#(lf)        ROW_NUMBER() #(lf)          OVER (#(lf)            ORDER BY #(lf)              -- newest dates first; NULLs (no loadings) last#(lf)              CASE WHEN ll.MaxLoadingFromDate IS NULL THEN 1 ELSE 0 END,#(lf)              ll.MaxLoadingFromDate DESC#(lf)          ) AS LoadingRank#(lf)    FROM ShipList sl#(lf)    LEFT JOIN LatestLoading ll #(lf)      ON ll.SA_ShipID = sl.ShipID#(lf)    WHERE sl.ShipActive = 1#(lf))#(lf)SELECT *#(lf)FROM RankedShips#(lf)--ORDER BY LoadingRank"])
				in
				    Source

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

