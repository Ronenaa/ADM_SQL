	partition dimWarehouses = m
		mode: import
		queryGroup: Dim
		source =
				let
				    Source = Sql.Database(#"SQL Address", "MT", [Query="Select#(lf)'1' as 'EntityID'#(lf)--,'1' + w.WARHS as 'WarehsKey'#(lf)--,CONCAT('1' , w.WARHS) as 'WarehsKey'#(lf),G.QOD_GORM as 'WarehsKey'#(lf)---,w.TYPE as 'WarehouseType'#(lf),G.SHM_GORM as 'WarehouseName'#(lf),G.EntityType as 'WarehouseType'#(lf),G.AOPI_PEILOT as 'WarehouseActivity'#(lf),CASE#(lf)#(tab)WHEN QOD_GORM = 1144 ----לוגוס#(lf)#(tab)#(tab)THEN 1#(lf)#(tab)WHEN QOD_GORM = 1411 ----גורן הכפר#(lf)#(tab)#(tab)THEN 2#(lf)#(tab)WHEN QOD_GORM = 1220 ----מספנות ישראל#(lf)#(tab)#(tab)THEN 3#(lf)#(tab)ELSE ROW_NUMBER () OVER (Order By G.Qod_Gorm) + 3#(lf)END AS 'WarehouseOrder'#(lf),GETDATE() AS RowInsertDatetime#(lf)#(lf)From  GORMIM G#(lf)WHERE EntityType = N'מקום אספקה'"])
				in
				    Source

