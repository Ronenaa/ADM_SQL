	partition dimSuppliersCompare = m
		mode: import
		queryGroup: Dim
		source =
				let
				    Source = Sql.Database(#"SQL Address", "MT", [Query="With SupplierTable AS (#(lf)#(tab)SELECT#(lf)#(lf)#(tab)    '1' as 'EntityID'#(lf)#(lf)#(tab)    --,'1'+CONVERT(INT, CONVERT(VARCHAR, c.CUST)) AS 'AccountKey'#(lf)#(lf)#(tab)#(tab)--,CONCAT('1',CONVERT(INT, CONVERT(VARCHAR, c.CUST))) AS 'AccountKey'#(lf)#(lf)#(tab)#(tab),CAST(CONVERT(INT, CONVERT(VARCHAR,G.QOD_GORM))as varchar) AS 'SupplierKey'#(lf)#(lf)#(tab)#(tab),G.QOD_GORM AS 'מספר לקוח'#(lf)#(lf)#(tab)#(tab),Case#(lf)#(tab)#(tab)#(tab)when CHARINDEX('=',SHM_GORM,0) >0#(lf)#(tab)#(tab)#(tab)#(tab)Then RIGHT(SHM_GORM,Len(SHM_GORM)-1) #(lf)#(tab)#(tab)#(tab)Else SHM_GORM#(lf)#(tab)#(tab)End As 'Supplier Name'#(lf)#(lf)#(tab)#(tab),Case#(lf)#(tab)#(tab)#(tab)when CHARINDEX('=',SHM_GORM,0) >0#(lf)#(tab)#(tab)#(tab)#(tab)Then cast(G.QOD_GORM as nvarchar(9)) + ' | ' + RIGHT(SHM_GORM,Len(SHM_GORM)-1) #(lf)#(tab)#(tab)#(tab)Else cast(G.QOD_GORM as nvarchar(9)) + ' | ' + SHM_GORM#(lf)#(tab)#(tab)End as 'מזהה לקוח'#(lf)#(lf)#(tab)#(tab),null AS 'מספר לקוח אב'#(lf)#(lf)#(tab)#(tab),Case #(lf)#(tab)#(tab)#(tab)When ARGON_QNIOT = 'פרטי' or ARGON_QNIOT = ''#(lf)#(tab)#(tab)#(tab)#(tab)then 'No Main Customer'#(lf)#(tab)#(tab)#(tab)Else ARGON_QNIOT#(lf)#(tab)#(tab)END AS 'שם לקוח אב'#(lf)#(lf)#(tab)#(tab),null AS 'מזהה לקוח אב'#(lf)#(lf)#(tab)#(tab),Case #(lf)#(tab)#(tab)#(tab)When ARGON_QNIOT = 'פרטי' or ARGON_QNIOT = ''#(lf)#(tab)#(tab)#(tab)#(tab)then Case#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)When CHARINDEX('=',SHM_GORM,0) >0#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)Then RIGHT(SHM_GORM,Len(SHM_GORM)-1) #(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)Else SHM_GORM#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)End#(lf)#(tab)#(tab)#(tab)Else Case#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)When CHARINDEX('=',SHM_GORM,0) >0#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)Then ARGON_QNIOT+' | '+RIGHT(SHM_GORM,Len(SHM_GORM)-1) #(lf)#(tab)#(tab)#(tab)#(tab)#(tab)Else ARGON_QNIOT+' | '+SHM_GORM#(lf)#(tab)#(tab)#(tab)#(tab)end#(lf)#(tab)#(tab)#(tab)END 