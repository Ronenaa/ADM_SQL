table dimCustomers
	lineageTag: cbb3683a-9005-496e-b70c-8206ef715cb1

	measure 'לקוח נבחר' = ```
			
			     IF(HASONEVALUE(dimCustomers[AccountKey]),
			     VALUES(dimCustomers[שם לקוח])
			    ,IF(NOT(ISFILTERED(dimCustomers[שם לקוח]))
			        ,"Choose a Customer"
			        ,CONCATENATEX(VALUES(dimCustomers[שם לקוח]),dimCustomers[שם לקוח],",")
			))
			```
		displayFolder: אחר
		lineageTag: e579ae90-e5bc-4c4d-afbe-158ef6affe4d

		changedProperty = IsHidden

	measure 'Max Obligo' = ```
			
			sumx(VALUES(dimCustomers[AccountKey]), CALCULATE(MAX(dimCustomers[אובליגו]))) // VALUES(dimCustomers[שם לקוח]) - Demo , VALUES(dimCustomers[AccountKey]) -Prod  
			//Old IF(HASONEVALUE(dimCustomers[שם לקוח]),MAX(dimCustomers[MAXOBLIGO]))
			```
		formatString: "₪"\ #,0;"₪"-#,0;"₪"\ #,0
		lineageTag: c2d9352d-bee8-4c1c-b6ae-5612b18a45e4

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"currencyCulture":"he-IL"}

	measure 'סהכ אובליגו' = IF(HASONEVALUE(dimCustomers[שם לקוח]),FORMAT(VALUES(dimCustomers[אובליגו]),"#,0"),"")
		displayFolder: חוב
		lineageTag: a00f0cdb-ea82-44fe-a584-0fe698e6c595

		changedProperty = IsHidden

	measure 'תנאי תשלום' = IF(HASONEVALUE(dimCustomers[שם לקוח]),VALUES(dimCustomers[תנאי תשלום ללקוח]),"")
		displayFolder: חוב
		lineageTag: bd86be80-0a92-403f-80f8-884c472b0876

		changedProperty = IsHidden

	measure 'כמות צירופים/חידושים' =
			[לקוחות חדשים]
			
			
			/*CALCULATE(
			var StartDate=CALCULATE(Min(dimDates[תאריך]),dimDates[IsHistory]=1)
			var EndDate=CALCULATE(Max(dimDates[תאריך]),dimDates[IsHistory]=1)
			return CALCULATE( COUNTROWS(VALUES(dimCustomers[שם לקוח])), DATESBETWEEN(dimCustomers[תאריך הצטרפות], StartDate,EndDate)), TREATAS(VALUES(dimBranches[BranchKey]),dimCustomers[JoinBranchID]))*/
		formatString: #,0
		displayFolder: כמות
		lineageTag: 2008edb4-6d18-4bf0-82bc-f59bb7217c5d

		changedProperty = IsHidden

	measure 'Top Category Last 3 Month' =
			
			IF(CALCULATE([Total Sales],dimDates[Show Last 3 Months]=TRUE())>0,
			TOPN(1,
			VALUES(dimItems[קטגוריה]),
			CALCULATE([Total Sales],dimDates[Show Last 3 Months]=TRUE())
			,desc,
			dimItems[קטגוריה],desc
			)
			,"ללא קטגוריה מועדפת")
			
			
			
			/*
			
			TOPN(1,
			VALUES(dimItems[קטגוריה]),
			CALCULATE([Total Sales],dimDates[Show Last 12 Months]=TRUE())
			,desc
			)*/
		lineageTag: 029614da-52da-4766-93d6-5aaa4817d669

		changedProperty = IsHidden

	measure 'Top Category' =
			
			IF(CALCULATE([Total Sales],dimDates[Show Last 12 Months]=TRUE())>0,
			TOPN(1,
			VALUES(dimItems[קטגוריה]),
			CALCULATE([Total Sales],dimDates[Show Last 12 Months]=TRUE())
			,desc,
			dimItems[קטגוריה],desc
			)
			,"ללא קטגוריה מועדפת")
			
			
			
			/*
			
			TOPN(1,
			VALUES(dimItems[קטגוריה]),
			CALCULATE([Total Sales],dimDates[Show Last 12 Months]=TRUE())
			,desc
			)*/
		lineageTag: 2e52b522-6a15-4b01-9fc4-11eb5c2eec4e

		changedProperty = IsHidden

	measure 'Top Day' =
			
			IF(CALCULATE([Total Sales],dimDates[Show Last 12 Months]=TRUE())>0,
			TOPN(1,
			VALUES(dimDates[DayOfWeekName]),
			CALCULATE([Total Sales],dimDates[Show Last 12 Months]=TRUE())
			,desc,
			dimDates[DayOfWeekName],desc
			)
			,"ללא יום מועדף")
		lineageTag: a070944a-b9ad-4393-a53b-69435acb926b

		changedProperty = IsHidden

	measure 'חריגה מאובליגו' = [Max Obligo] - [Commited Debt for Obligo]
		formatString: #,0
		displayFolder: חוב
		lineageTag: c9f970d2-b973-49f9-82e1-e70fa0fb365e

		changedProperty = IsHidden

	measure 'Customer Card' = ```
			Switch(TRUE(),
			HASONEVALUE(dimCustomers[שם לקוח אב]),--HASONEVALUE(dimCustomers[AccountKey]),
			 MAX(dimCustomers[שם לקוח אב]) 
			//& UNICHAR(10) & " " & UNICHAR(10) & "ID: " & MAX(dimCustomers[AccountKey])
			//& UNICHAR(10) & " " & UNICHAR(10) & "Category: " & MAX(dimCustomers[סוג לקוח]) 
			//& UNICHAR(10) & " " & UNICHAR(10) & "Since: " & FORMAT(CALCULATE(MIN(factOrders[Date]),ALL(dimDates)),"dd/mm/yyyy"),
			 ,"Choose a Customer")
			```
		lineageTag: 0aa52690-2341-4c14-be68-e81d13b7a2d2

		changedProperty = IsHidden

	measure 'Customer Group Card' = ```
			Switch(TRUE(),
			HASONEVALUE(dimCustomers[סוג לקוח]),
			 MAX(dimCustomers[סוג לקוח]) 
			 ,"Choose Customer Group")
			```
		lineageTag: c49cb124-b6df-4280-94ee-00ada83e4f14

		changedProperty = IsHidden

	measure 'InterestRate - Monthly' =
			
			DIVIDE(
			    (SUM(dimCustomers[InterestRate])*12),
			    100
			)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 70cd5eff-1911-4ccc-bce6-307b95dd2b6c

		changedProperty = IsHidden

	measure 'Agent Card' = ```
			Switch(TRUE(),
			HASONEVALUE(dimCustomers[Agent]),
			 MAX(dimCustomers[Agent]) 
			 ,"Agent")
			```
		lineageTag: e955ed3d-5734-494d-9b66-a350a79f230f

