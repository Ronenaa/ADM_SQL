ab)#(tab)#(tab)#(tab)#(tab)When CHARINDEX('=',G.SHM_GORM,0) >0#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)Then RIGHT(G.SHM_GORM,Len(G.SHM_GORM)-1) #(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)Else G.SHM_GORM#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)End#(lf)#(tab)#(tab)#(tab)Else Case#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)When CHARINDEX('=',G.SHM_GORM,0) >0#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)Then ARGON_QNIOT+' | '+RIGHT(G.SHM_GORM,Len(G.SHM_GORM)-1) #(lf)#(tab)#(tab)#(tab)#(tab)#(tab)Else ARGON_QNIOT+' | '+G.SHM_GORM#(lf)#(tab)#(tab)#(tab)#(tab)end#(lf)#(tab)#(tab)#(tab)END AS 'OrgName' -- this fiels enable to contain all regular customers and all Fathers in the sam column#(lf)#(lf)#(tab)#(tab),SOG_GORM AS 'קוד סוג לקוח'#(lf)#(lf)#(tab)#(tab),EntityType AS 'קטגוריית לקוח' #(lf)#(lf)#(tab)#(tab),Case #(lf)#(tab)#(tab)#(tab)When AOPI_PEILOT IS NULL OR AOPI_PEILOT = '' #(lf)#(tab)#(tab)#(tab)#(tab)Then 'No Group'#(lf)#(tab)#(tab)#(tab)Else AOPI_PEILOT#(lf)#(tab)#(tab)END AS 'סוג לקוח'#(lf)#(lf)#(tab)#(tab),null AS 'פרמטר 1'#(lf)#(lf)#(tab)#(tab),null AS 'פרמטר 2'#(lf)#(lf)#(tab)#(tab),null AS 'פרמטר 3'#(lf)#(lf)#(tab)#(tab),null AS 'פרמטר 4'#(lf)#(lf)#(tab)#(tab),null AS 'פרמטר 5'#(lf)#(lf)#(tab)#(tab),null AS 'פרמטר 6'#(lf)#(lf)#(tab)#(tab),null AS 'פרמטר 7'#(lf)#(lf)#(tab)#(tab),null AS 'פרמטר 8'#(lf)#(lf)#(tab)#(tab),null AS 'עיר'#(lf)#(tab)#(tab),G.CTOBT AS 'כתובת'#(lf)#(tab)#(tab),G.TLPON_1 AS 'מספר טלפון'#(lf)#(tab)#(tab),G.IsActive AS 'סטטוס לקוח'#(lf)#(tab)#(tab),AM.QOD AS 'AgentKey' --- יש בעיברית#(lf)#(tab)#(tab),AM.SHM_AISH_MCIROT as 'Agent'#(lf)#(lf)#(tab)#(tab),Case#(lf)#(tab)#(tab)#(tab)#(tab)When TNAI_TSHLOM_IMIM = 0#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)Then 'Immidate'#(lf)#(tab)#(tab)#(tab)Else '+'+cast(TNAI_TSHLOM_IMIM as nvarchar(3))#(lf)#(tab)#(tab)End as 'תנאי תשלום ללקוח'#(lf)#(lf)#(tab)#(tab),TNAI_TSHLOM_IMIM As 'PaymentTermOrder'#(lf)#(lf)#(tab)#(tab)--,null AS 'MAXOBLIGO'#(lf)#(tab)#(tab),ob.OBL_ObligoAmount as#(tab)#(tab)#(tab)#(tab)#(tab)'Obligo'#(lf)#(t