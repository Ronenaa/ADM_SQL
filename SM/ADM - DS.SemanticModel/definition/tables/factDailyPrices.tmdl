	partition factDailyPrices = m
		mode: import
		queryGroup: 'fact Tables'
		source =
				let
				    Source = Sql.Database(#"SQL Address", "MT", [Query="WITH DateList AS (#(lf)  --SELECT CAST(DATEADD(MONTH,DATEDIFF(month,0,DATEADD(MM,+1,MIN(AsOfDate))),0) AS date) AS 'Date'#(lf)Select Cast(dateadd(dd,[index]-1,'2023-09-01') as date) as date#(lf)FROM (select ROW_NUMBER () over (order by name) as 'index' from sys.all_columns) O#(lf)Where Cast(dateadd(dd,[index]-1,'2023-09-01') as date) <= (EOMONTH(DATEADD(MONTH,DATEDIFF(month,0,DATEADD(MM,+12,GETDATE())),0)) )#(lf)#(lf)#(lf)  #(lf))#(lf)#(lf),STG1 AS (#(lf)SELECT#(lf)    ProductID,#(lf)#(tab)AsOfDate,#(lf)    Months,#(lf)#(tab)MONTH(DATEADD(MM, case when RIGHT(MONTHS,2) IN ('10','11','12') THEN CAST(RIGHT(MONTHS,2) AS INT)-1 ELSE CAST(RIGHT(MONTHS,1) AS INT)-1 END, ASOFDATE)) AS MonthNum,#(lf)#(tab)YEAR(DATEADD(MM, case when RIGHT(MONTHS,2) IN ('10','11','12') THEN CAST(RIGHT(MONTHS,2) AS INT)-1 ELSE CAST(RIGHT(MONTHS,1) AS INT)-1 END, ASOFDATE)) AS YearNum,#(lf)#(tab)YEAR(DATEADD(MM, case when RIGHT(MONTHS,2) IN ('10','11','12') THEN CAST(RIGHT(MONTHS,2) AS INT)-1 ELSE CAST(RIGHT(MONTHS,1) AS INT)-1 END, ASOFDATE)) *100 + MONTH(DATEADD(MM, case when RIGHT(MONTHS,2) IN ('10','11','12') THEN CAST(RIGHT(MONTHS,2) AS INT)-1 ELSE CAST(RIGHT(MONTHS,1) AS INT)-1 END, ASOFDATE)) as YearMonthNum,#(lf)#(tab)LEFT(Months,3)AS 'MinMaxIndicator',#(lf)#(tab)Price,#(lf)#(tab)Case When Price = 0 Then 0 Else 1 End as Flag#(lf)FROM (#(lf)    SELECT#(lf)        ProductID,#(lf)#(tab)#(tab)AsOfDate,#(lf)        MinPriceMonth1,#(lf)        MaxPriceMonth1,#(lf)        MinPriceMonth2,#(lf)        MaxPriceMonth2,#(lf)#(tab)#(tab)MinPriceMonth3,#(lf)        MaxPriceMonth3,#(lf)#(tab)#(tab)MinPriceMonth4,#(lf)        MaxPriceMonth4,#(lf)#(tab)#(tab)MinPriceMonth5,#(lf)        MaxPriceMonth5,#(lf)#(tab)#(tab)MinPriceMonth6,#(lf)        MaxPriceMonth6,#(lf)#(tab)#(tab)MinPriceMonth7,#(lf)        MaxPriceMonth7,#(lf)#(tab)#(tab)MinPriceMonth8,#(lf)        MaxPriceMonth8,#(lf)#(tab)#(tab)MinPriceMonth9,#(lf)        MaxPriceMonth9,#(lf)#(tab)#(tab)MinPriceMonth10,#(lf)        MaxPriceMonth10,#(lf)#(tab)#(tab)MinPriceMonth11,#(lf)        MaxPriceMonth11,#(lf)#(tab)#(tab)MinPriceMonth12,#(lf)        MaxPriceMonth12#(lf)#(lf)    FROM [tblDailyPrices]#(lf)) AS SourceTable#(lf)UNPIVOT (#(lf)    Price FOR Months IN (#(lf)        MinPriceMonth1, MaxPriceMonth1,#(lf)        MinPriceMonth2, MaxPriceMonth2,#(lf)#(tab)#(tab)MinPriceMonth3, MaxPriceMonth3,#(lf)#(tab)#(tab)MinPriceMonth4, MaxPriceMonth4,#(lf)#(tab)#(tab)MinPriceMonth5, MaxPriceMonth5,#(lf)#(tab)#(tab)MinPriceMonth6, MaxPriceMonth6,#(lf)#(tab)#(tab)MinPriceMonth7, MaxPriceMonth7,#(lf)#(tab)#(tab)MinPriceMonth8, MaxPriceMonth8,#(lf)#(tab)#(tab)MinPriceMonth9, MaxPriceMonth9,#(lf)#(tab)#(tab)MinPriceMonth10, MaxPriceMonth10,#(lf)#(tab)#(tab)MinPriceMonth11, MaxPriceMonth11,#(lf)#(tab)#(tab)MinPriceMonth12, MaxPriceMonth12#(lf)    )#(lf)) AS UnpivotedTable#(lf))#(lf)#(lf),STG2 AS (#(lf)Select ProductID,#(lf)AsOfDate,#(lf)Months,#(lf)MonthNum,#(lf)YearNum,#(lf)YearMonthNum,#(lf)MinMaxIndicator,#(lf)Price,#(lf)Sum (Flag) over (partition by ProductID,MinMaxIndicator,YearMonthNum Order by AsOfDate) as Ranking#(lf)from STG1#(lf))#(lf)#(lf),STG3 AS (#(lf)Select ProductID,#(lf)AsOfDate,#(lf)Months,#(lf)MonthNum,#(lf)YearNum,#(lf)YearMonthNum,#(lf)MinMaxIndicator,#(lf)Max (Price) over (partition by ProductID,MinMaxIndicator,YearMonthNum,Ranking Order by AsOfDate) AS Price#(lf)from STG2#(lf))#(lf)#(lf),MAXPRICE as (#(lf)Select ProductID,#(lf)AsOfDate,#(lf)Months,#(lf)MonthNum,#(lf)YearNum,#(lf)YearMonthNum,#(lf)Price as 'MAXPrice'#(lf)From STG3#(lf)Where MinMaxIndicator = 'MAX'#(lf))#(lf)#(lf),MINPRICE as (#(lf)Select ProductID,#(lf)AsOfDate,#(lf)Months,#(lf)MonthNum,#(lf)YearNum,#(lf)YearMonthNum,#(lf)Price as 'MINPrice'#(lf)From STG3#(lf)Where MinMaxIndicator = 'MIN'#(lf))#(lf)#(lf),MARKETPRICE as (#(lf)Select ProductID,#(lf)AsOfDate,#(lf)MonthNum,#(lf)YearNum,#(lf)YearMonthNum,#(lf)AVG(Price) as 'MarketPrice'#(lf)From STG3#(lf)Group By ProductID,AsOfDate,MonthNum,YearNum,YearMonthNum#(lf))#(lf)#(lf),STG4 AS (#(lf)Select MX.ProductID,#(lf)MX.AsOfDate,#(lf)MX.Months,#(lf)MX.MonthNum,#(lf)MX.YearNum,#(lf)MX.YearMonthNum,#(lf)MAXPrice,#(lf)MINPrice,#(lf)MarketPrice#(lf)From MAXPRICE MX#(lf)Left Join MINPRICE MN#(lf)#(tab)ON MX.AsOfDate = MN.AsOfDate AND MX.YearMonthNum = MN.YearMonthNum AND MX.ProductID=MN.ProductID#(lf)Left Join MARKETPRICE MK#(lf)#(tab)ON MX.AsOfDate = MK.AsOfDate AND MX.YearMonthNum = MK.YearMonthNum AND MX.ProductID=MK.ProductID#(lf))#(lf)#(lf),STG5 AS(#(lf)SELECT *#(lf)FROM STG4#(lf)CROSS APPLY (#(lf)SELECT *#(lf)FROM DateList #(lf))dl#(lf)WHERE DL.Date>=STG4.AsOfDate #(lf)      AND Month(DL.Date)- Month(STG4.AsOfDate)<=12 #(lf)#(tab)  AND ( CASE --WHEN MonthNum = MONTH(STG_2.AsOfDate) THEN 1 #(lf)#(tab)             WHEN MONTH(DL.Date) = MonthNum AND  Year(DL.Date) = YearNum  THEN 1#(lf)#(tab)#(tab)#(tab)#(tab) ELSE 0 END=1)#(lf)#(tab)--AND MonthNum = 3#(lf))#(lf)#(lf)SELECT  CAST( CONVERT(BIGINT, CONVERT(VARCHAR, ProductID)) as varchar) +'-'+ CAST( CONVERT(BIGINT, CONVERT(VARCHAR, ProductID)) as varchar)AS 'ItemKey'#(lf)      ,AsOfDate#(lf)#(tab)  ,[Date]#(lf)#(tab)  ,MAXPrice#(lf)#(tab)  ,MINPrice#(lf)#(tab)  ,MarketPrice#(lf)FROM STG5#(lf)#(lf)#(lf)", CommandTimeout=#duration(0, 2, 30, 0)]),
