table factDailyPrices
	lineageTag: 1b11c4c7-4e66-43ed-b247-a73280f9131c

	measure 'Daily Price Date' =
			
			/*תקופה מוצגת = FORMAT(CALCULATE(MIN(dimDates[תאריך]),dimDates[IsHistory]=1),"dd/mm/yyyy") & " - " & FORMAT(CALCULATE(MAX(dimDates[תאריך]),dimDates[IsHistory]=1),"dd/mm/yyyy")*/
			"As of date" & " - " & FORMAT(CALCULATE(MAX(Sub_DimDates[Date]),Sub_DimDates[IsHistory]=1),"dd/mm/yyyy")
		lineageTag: d06fc450-e6a2-497a-9cb8-c249e46c959e

		changedProperty = IsHidden

	measure 'Avg Price Indicator (Target VS Actual)' =
			
			IF([Avg Unit Price By Supply Date _ DailyPrice]=BLANK(),Blank(),
			    IF([Avg Unit Price By Supply Date _ DailyPrice]<=[Min Price Target],0,
			        IF([Avg Unit Price By Supply Date _ DailyPrice]>=[Max Price Target],2,1
			        )
			    )
			)
		formatString: 0
		lineageTag: 509562c3-ead3-4fc5-aee3-cbed0f8c105b

		changedProperty = IsHidden

	measure 'Min Price Target' =
			
			VAR MaxDate = CALCULATE(MAX(Sub_DimDates[Date]),Sub_DimDates[IsHistory]=1)--CALCULATE(LASTDATE(factDailyPrices[AsOfDate]))--,ALL(factDailyPrices))
			RETURN
			
			CALCULATE(
			    CALCULATE(MIN(factDailyPrices[MinPrice])
			    ,FILTER(factDailyPrices,factDailyPrices[MinPrice]>0 && factDailyPrices[AsOfDate]=MaxDate))
			    --,FILTER(dimDates,dimDates[תאריך]>=MaxDate)
			     -- ,FILTER(Sub_DimDates,Sub_DimDates[תאריך]>=MaxDate)
			     --,USERELATIONSHIP(Sub_DimDates[Date],factDailyPrices[Date])
			    )
		formatString: #,0
		lineageTag: fb976e1d-9945-489f-8206-c49659aa59af

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'Max Price Target' = ```
			
			VAR MaxDate = CALCULATE(MAX(Sub_DimDates[Date]),Sub_DimDates[IsHistory]=1)--,ALL(factDailyPrices))
			RETURN
			CALCULATE(
			    CALCULATE(MAX(factDailyPrices[MaxPrice]),FILTER(dimDates,dimDates[Date]>=MaxDate)
			    ,FILTER(factDailyPrices,factDailyPrices[MaxPrice]>0 && factDailyPrices[AsOfDate]=MaxDate))
			    --,USERELATIONSHIP(Sub_DimDates[Date],factDailyPrices[Date])
			    )
			    
			```
		formatString: 0
		lineageTag: 8b0d4420-d527-4408-b3b3-3971db60ec47

		changedProperty = IsHidden

	measure 'Min - Max' = ```
			
			VAR DailyDate =CALCULATE(MAX(Sub_DimDates[Date]),Sub_DimDates[IsHistory]=1)--CALCULATE(LASTDATE(factDailyPrices[AsOfDate]),ALL(factDailyPrices))
			Var _MaxDate = MAX(dimDates[Date]) 
			
			
			RETURN
			Switch(TRUE(),
			    ISBLANK([Max Price Target]),
			        BLANK(),
			     _MaxDate<>BLANK(),
			        [Min Price Target] & "-" & [Max Price Target],
			BLANK()
			)
			
			```
		lineageTag: 91c2047f-ec21-4341-9b19-f8f4c3903eab

		changedProperty = IsHidden

	measure MonthsIndicator = ```
			
			Var _Parameter = PricingMonthParameter[PricingMonthParameter Value]
			Var _Today = MAX(factDailyPrices[AsOfDate])
			Var _MaxDate = CALCULATE(MAX(dimDates[Date]),dimDates[IsHistory]=0) 
			Var _ParameterDate = EOMONTH(_Today, _Parameter)
			
			RETURN
			Switch(TRUE(),
			    _MaxDate <=_ParameterDate && _MaxDate<>BLANK(),1
			    ,0
			    )
			```
		formatString: 0
		lineageTag: f2944dc7-57dd-4d87-8c70-c53f32ea66fa

		changedProperty = IsHidden

	measure 'Market Price' =
			
			VAR MaxDate = CALCULATE(MAX(factDailyPrices[AsOfDate]),factDailyPrices[MinPrice]>0)--CALCULATE(LASTDATE(factDailyPrices[AsOfDate]))--,ALL(factDailyPrices))
			RETURN
			ROUND(
			CALCULATE(
			    CALCULATE(AVERAGE(factDailyPrices[MarketPrice])
			    ,FILTER(factDailyPrices,factDailyPrices[MinPrice]>0 /*&& factDailyPrices[AsOfDate]=MaxDate*/ && factDailyPrices[AsOfDate]>=MaxDate))
			)
			,0)
		formatString: #,0
		lineageTag: e0b21414-d9be-49b0-9b9b-eed6f6f11bc7

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'Market Price - Risk Plan No Total' = ```
			
			 SWITCH(TRUE(),
			 ISBLANK([AVG Price - Risk Plan No Total]),
			    BLANK(),
			HASONEVALUE(dimDates[MonthInCalendarName]),
			    [Market Price],
			BLANK()
			)
			```
		lineageTag: 36b955e7-ec70-4472-93fc-291ccf15a721

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

