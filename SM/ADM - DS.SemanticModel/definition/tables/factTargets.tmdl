	partition factTargets = m
		mode: import
		queryGroup: 'fact Tables'
		source =
				let
				    Source = Sql.Database(#"SQL Address", "MT", [Query="WITH DateList AS (#(lf)                  SELECT CAST(DATEFROMPARTS(YEAR(GETDATE())-1,1,1) AS DATE) AS [Date]#(lf)                  UNION ALL#(lf)                  SELECT  DATEADD(DAY, 1, [Date]) AS 'Date'#(lf)                  FROM DateList#(lf)                  WHERE [Date]<DATEFROMPARTS(YEAR(GETDATE()),12,31)#(lf))#(lf),STG1 AS (#(lf)          SELECT #(lf)          '1' as 'EntityID'#(lf)#(tab)#(tab)  ,CPT.CPT_Year AS 'Year'#(lf)          ,CAST(CONVERT(INT, CONVERT(VARCHAR,AM.QOD)) AS VARCHAR) AS 'AgentKey'#(lf)          ,CAST(CONVERT(INT, CONVERT(VARCHAR,G.QOD_GORM))AS VARCHAR) AS 'AccountKey'#(lf)          ,NULL AS 'CategoryCode' #(lf)          ,CAST(CONVERT(INT, CONVERT(VARCHAR,CPT.CPT_ProductID)) AS VARCHAR)+ '-' + CAST(CONVERT(INT, CONVERT(VARCHAR,CPT.CPT_ProductID)) AS VARCHAR) AS 'ItemKey'#(lf)          --,DATENAME(MONTH,CONVERT(DATETIME,'1'+ (replace(Date,'PRICE','')) + '1')) AS 'Date'#(lf)          --,Year#(lf)          ,CPT.[CPT_PotentialInTone] AS 'PotentialInTone'#(lf)          ,CPT.[CPT_TargetInPercent] AS 'TargetInPercent'#(lf)          ,CPT.[CPT_PotentialInTone] * (CPT.[CPT_TargetInPercent]/100) as 'Target'#(lf)          ,NULL as 'TargetVAT'#(lf)          ,null as 'BranchKey'#(lf)         -- ,GETDATE() AS RowInsertDatetime#(lf)          FROM [tblCustomerProductYearTargets] CPT#(lf)          LEFT JOIN GORMIM G ON CPT.CPT_CustomerID=G.QOD_GORM#(lf)          LEFT JOIN TBLT_ANSHI_MCIROT AM ON AM.SHM_AISH_MCIROT = G.AISH_MCIROT_MTPL#(lf)          WHERE CPT.CPT_IsActive=1 #(lf)#(lf)#(tab)#(tab)  UNION ALL#(lf)#(lf)#(tab)#(tab)  SELECT #(lf)          '1' as 'EntityID'#(lf)#(tab)#(tab)  ,CPT.POT_Year AS 'Year'#(lf)          ,CAST(CONVERT(INT, CONVERT(VARCHAR,AM.QOD)) AS VARCHAR) AS 'AgentKey'#(lf)          ,CAST(CONVERT(INT, CONVERT(VARCHAR,G.QOD_GORM))AS VARCHAR) AS 'AccountKey'#(lf)          ,NULL AS 'CategoryCode' #(lf)          ,CAST(CONVERT(INT, CONVERT(VARCHAR,CPT.POT_Product)) AS VARCHAR)+ '-' + CAST(CONVERT(INT, CONVERT(VARCHAR,CPT.POT_Product)) AS VARCHAR) AS 'ItemKey'#(lf)          --,DATENAME(MONTH,CONVERT(DATETIME,'1'+ (replace(Date,'PRICE','')) + '1')) AS 'Date'#(lf)          --,Year#(lf)          ,CPT.[POT_PotentialInTone] AS 'PotentialInTone'#(lf)          ,CPT.[POT_TargetInPercent] AS 'TargetInPercent'#(lf)          ,CPT.[POT_TargetInTone] as 'Target'#(lf)          ,NULL as 'TargetVAT'#(lf)          ,null as 'BranchKey'#(lf)         -- ,GETDATE() AS RowInsertDatetime#(lf)          FROM [dbo].[tblCustomerPotential] CPT#(lf)          LEFT JOIN GORMIM G ON CPT.POT_Customer=G.QOD_GORM#(lf)          LEFT JOIN TBLT_ANSHI_MCIROT AM ON AM.SHM_AISH_MCIROT = G.AISH_MCIROT_MTPL#(lf)#(tab)#(tab)  WHERE POT_Year>=2024#(lf))#(lf),STG2 AS (#(lf)SELECT EntityID#(lf)      ,[Year]#(lf)#(tab)  --,DATEPART(WEEKDAY,[Date]) AS 'DayOfWeek'#(lf)#(tab)  --,CASE WHEN DATEPART(WEEKDAY,[Date]) IN (6,7) THEN 0 ELSE 1 END AS DayIndic#(lf)      ,[Date]#(lf)      ,AgentKey#(lf)#(tab)  ,AccountKey#(lf)#(tab)  ,CategoryCode#(lf)#(tab)  ,ItemKey#(lf)#(tab)  ,PotentialInTone#(lf)#(tab)  ,[Target]#(lf)#(tab)  ,TargetInPercent#(lf)#(tab)--,ROUND(CAST(((PotentialInTone) / #(lf)    --       (CASE WHEN YEAR([Date]) = [Year] THEN DATEDIFF(DAY, DATEFROMPARTS([Year], 1, 1), DATEFROMPARTS([Year], 12, 31)) + 1 ELSE 365 END))as decimal (8,3)),3) AS 'PotentialInTone'#(lf)#(tab)--,ROUND(CAST(((PotentialInTone * (TargetInPercent / 100)) / #(lf)    --       (CASE WHEN YEAR([Date]) = [Year] THEN DATEDIFF(DAY, DATEFROMPARTS([Year], 1, 1), DATEFROMPARTS([Year], 12, 31)) + 1 ELSE 365 END))as decimal (8,3)),3) AS 'Target'#(lf)#(tab)  ,TargetVAT#(lf)#(tab)  ,BranchKey#(lf)#(tab)  #(lf)FROM DateList DL#(lf)CROSS APPLY (#(lf)             SELECT *#(lf)             FROM STG1#(lf)             WHERE [Year] = YEAR(DL.[Date])#(lf)         ) AS STG#(lf))#(lf),NumOfDays AS (#(lf)SELECT *#(lf)#(tab)  ,SUM(VacationRate) OVER (PARTITION BY YEAR(VacationDate)) AS 'DaysOff'#(lf)#(tab)  ,DATEDIFF(DAY,DATEFROMPARTS(YEAR(VacationDate),01,01), DATEFROMPARTS(YEAR(VacationDate),12,31))+1 - SUM(VacationRate) OVER (PARTITION BY YEAR(VacationDate)) AS 'DaysInYear'#(lf)FROM ADM.dbo.tblVacationSettings#(lf)#(lf))#(lf),TotalDaysInYear AS (#(lf)SELECT DISTINCT DL.*#(lf),CASE WHEN N.VacationType IS NULL THEN 'יום עבודה' ELSE N.VacationType END AS 'VacationType' #(lf),CASE WHEN N.VacationRate IS NULL THEN 0 ELSE N.VacationRate END AS DayOff,N2.DaysInYear#(lf)FROM DateList DL#(lf)LEFT join NumOfDays N#(lf)ON DL.Date = N.VacationDate#(lf)LEFT JOIN NumOfDays N2 ON YEAR(DL.Date)=YEAR(N2.VacationDate)#(lf)#(lf))#(lf)#(lf)SELECT EntityID#(lf)#(tab)  ,STG2.[Date]#(lf)#(tab)  ,AgentKey#(lf)#(tab)  ,AccountKey#(lf)#(tab)  ,CategoryCode#(lf)#(tab)  ,ItemKey#(lf)#(tab)  ,ROUND(CAST((PotentialInTone / (DaysInYear))as decimal (8,4)),4) AS 'PotentialInTone'#(lf)      ,ROUND(CAST(CASE WHEN DayOff>0 THEN 0 ELSE [TARGET] / (DaysInYear) END AS DECIMAL(8,5)),5) AS 'Target'#(lf)#(tab)  ,TargetVAT#(lf)      ,BranchKey#(lf)FROM STG2#(lf)LEFT JOIN TotalDaysInYear TD ON STG2.[Date]=TD.[Date]#(lf)order by Date#(lf)OPTION (MAXRECURSION 0);"]),
