	measure Potential =
			SUM(factTargets[PotentialInTone])
			--IF(ISBLANK(SUM(factTargets[PotentialInTone])),[Quantity Dynamic Table Switch LY No -]*1.5,SUM(factTargets[PotentialInTone]))
		lineageTag: 593cb977-5dd5-4e78-8f92-b9bfb7a5eb90

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Target Current Year' =
			
			VAR _YEAR = YEAR(CALCULATE(MAX(dimDates[Date]),dimDates[IsHistory]=1))
			
			RETURN
			CALCULATE([Total Target],Sub_DimDates[Year]=_YEAR)
		lineageTag: ddf4f4a2-05b5-4ec8-b16b-f52acf08a6cd

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Potential Current Year' =
			
			VAR _YEAR = YEAR(CALCULATE(MAX(dimDates[Date]),dimDates[IsHistory]=1))
			
			RETURN
			CALCULATE([Potential],Sub_DimDates[Year]=_YEAR)
		lineageTag: 537cb4d8-b577-4736-b8b5-a1609317688c

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure TargetToDate = CALCULATE(CALCULATE([Total Target],DATESYTD(dimDates[Date]),DATESYTD(Sub_DimDates[Date])),dimDates[IsHistory]=1,Sub_DimDates[IsHistory]=1)
		lineageTag: 552b5e27-9415-479b-9419-af1b4e909d9a

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Full Monthly Target' =
			
			VAR _YEAR = CALCULATE(YEAR(MAX(dimDates[Date])),dimDates[IsHistory]=1)
			RETURN
			CALCULATE([Total Target],FILTER(ALL(Sub_DimDates),Sub_DimDates[Year]=_YEAR))/12
		lineageTag: 6f8e2124-b8dd-455e-ac93-8a7c159b77cb

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '% Actual From Potential' = DIVIDE([Quantity Dynamic Table Switch],[Potential Current Year])
		formatString: 0.00%;(0.00)%;0.00%
		displayFolder: יעדים כללי
		lineageTag: 97212763-b71f-4ade-bfde-456fa7b27bc1

		changedProperty = IsHidden

	measure 'Full Monthly Potential' =
			
			VAR _YEAR = CALCULATE(YEAR(MAX(dimDates[Date])),dimDates[IsHistory]=1)
			RETURN
			CALCULATE([Potential],FILTER(ALL(Sub_DimDates),Sub_DimDates[Year]=_YEAR))/12
		lineageTag: 8c0c2f92-e8e9-495b-9e67-367ae0e13f7c

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

