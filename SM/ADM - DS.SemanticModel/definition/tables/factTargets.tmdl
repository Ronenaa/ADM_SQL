table factTargets
	lineageTag: 48fec6bc-98b1-4166-b590-dc9a2ecfa038

	measure 'מכירות חודשי לתקופה סניפים עם יעד' =
			
			VAR ThisMonth=CALCULATE(MAX(dimDates[YearMonthSum]),dimDates[IsHistory]=1)
			return
			 CALCULATE([כמות מכירה לתקופה וסניפים עם יעד],FILTER(dimDates,dimDates[YearMonthSum]=ThisMonth))
		formatString: #,0
		lineageTag: ca91f735-065e-4e67-90f0-42cc236a69dd

		changedProperty = IsHidden

	measure 'Agent Below 70% Target' = ```
			
			COUNTROWS(
			FILTER(VALUES(dimCustomers[Agent]),
			[אחוז ביצוע מיעד]<0.7 && [אחוז ביצוע מיעד] > 0 
			))
			```
		formatString: #,0
		lineageTag: 27982b4b-8b43-40c9-8337-03bfb5b3c372

		changedProperty = IsHidden

	measure 'Agent Abover Target' =
			
			COUNTROWS(
			FILTER(VALUES(dimCustomers[Agent]),
			[אחוז ביצוע מיעד]>=1.0
			))
		formatString: 0
		lineageTag: dcdf6c06-9330-4055-aed1-78ffd553bf93

		changedProperty = IsHidden

	measure 'Agent Below 90% and Over 70% Target' =
			
			COUNTROWS(
			FILTER(VALUES(dimCustomers[Agent]),
			[אחוז ביצוע מיעד]>=0.7 && [אחוז ביצוע מיעד]<1
			))
		formatString: 0
		lineageTag: 4e00edb0-bdca-4679-9f62-7e5eed3ecdb3

		changedProperty = IsHidden

	measure 'סוכני יעדים' =
			COUNTROWS(
			FILTER(VALUES(dimCustomers[Agent]),[אחוז ביצוע מיעד]>= 0))
		formatString: 0
		lineageTag: b5d44788-12b9-4308-b74c-694a5567f346

		changedProperty = IsHidden

	measure 'קצב חודשי ליום נדרש' =
			
			IF([קצב יומי נדרש לעמידה ביעד חודשי]<[ממוצע מכירות ליום חודשי]
				,
				 [ממוצע מכירות ליום חודשי יעדים]
			      , [קצב יומי נדרש לעמידה ביעד חודשי])
		formatString: #,0
		displayFolder: קצב
		lineageTag: 7e4b3ac2-f621-4388-bed2-39288632d845

		changedProperty = IsHidden

	measure 'קצב יומי נדרש לעמידה ביעד חודשי' =
			
			IF( [מרחק מיעד חודשי]>0,
			    0,
			[ממוצע מכירות ליום חודשי יעדים] + CALCULATE(DIVIDE([מרחק מיעד חודשי],[Remaining Working Days in Selected Period]),FILTER(dimDates,dimDates[Show This Year]=TRUE()))
			*-1)
		formatString: #,0
		displayFolder: קצב
		lineageTag: a627c786-a6ce-4167-acd8-6725bf668a85

		changedProperty = IsHidden

	measure 'קצב יומי נדרש לעמידה ביעד שנתי' =
			
			IF([מרחק מיעד]>0,
			    0,
			[ממוצע כמות מכירה ליום שנתי יעדים] + CALCULATE(DIVIDE([מרחק מיעד],[Remaining Working Days in Selected Period All Year]),FILTER(dimDates,dimDates[Show This Year]=TRUE()))
			*-1)
		displayFolder: קצב
		lineageTag: f8a37b07-5531-4c53-983f-dfd02a07106c

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'קצב שנתי ליום נדרש' = ```
			
			IF([קצב יומי נדרש לעמידה ביעד שנתי]<[ממוצע כמות מכירה ליום שנתי]
				,  [ממוצע כמות מכירה ליום שנתי יעדים]  
			      , [קצב יומי נדרש לעמידה ביעד שנתי])
			```
		formatString: #,0
		displayFolder: קצב
		lineageTag: bbb63aa5-2f37-4ccc-9b10-fc9f52d6d0de

		changedProperty = IsHidden

	measure יעדים = ```
			
			// [Ly Target]
			//Choose Target from the Above
			 SUM(factTargets[Target]) //[Ly Target]
			
			
			 /*IF(HASONEVALUE(VAT_MeasureSelctionTable[ID ANALYSIS]),
				SWITCH(MAX(VAT_MeasureSelctionTable[ID ANALYSIS]),
					1,[Total Target no VAT],
					2,[Total Target VAT]),
					
				[Total Target no VAT])*/
			```
		formatString: #,0
		displayFolder: יעדים כללי
		lineageTag: 08b2ab5c-a6d5-4820-9460-ef67cc3e8212

		changedProperty = IsHidden

	measure 'יעד עד היום' =
			
			CALCULATE([יעדים],dimDates[IsHistory]=1)
			
			//DIVIDE([יעדים],[Working Days in Selected Period])*[Working Days Passed in Selected Period]
		formatString: #,0
		displayFolder: יעדים כללי
		lineageTag: 66adb7cb-1703-44dd-b271-f3bc644fca43

		changedProperty = IsHidden

	measure 'כמות מכירה לתקופה וסניפים עם יעד' =
			
			SUMX(CROSSJOIN(dimCustomers,VALUES(dimDates[MonthInCalendarName])),CALCULATE(
			    if([יעדים]
			    >0,
			   [Total Quantity]
			    ,BLANK())))
			/*SUMX(CROSSJOIN(dimBranches,VALUES(dimDates[חודש בשנה])),CALCULATE(
			    if([יעדים]
			    >0,
			   [Total Sales]
			    ,BLANK())))*/
		formatString: #,0
		displayFolder: יעדים כללי
		lineageTag: 35e8c088-9a3b-4b7f-931f-cc931795124f

		changedProperty = IsHidden

	measure 'מרחק מיעד' = ```
			[מכירות מצטברות יעדים] -[יעד עד היום]
			/* If Module Is B2B
			[יעד עד היום] - [מכירות מצטברות] 
			*/
			/*If Module Is B2C
			[מכירות לתקופה וסניפים עם יעד]-
			[יעדים]*/
			```
		formatString: #,0
		displayFolder: יעדים כללי
		lineageTag: 9653c1c4-e9da-4029-943a-37c9d36fd900

		changedProperty = IsHidden

	measure 'מרחק מיעד עד היום' =
			
			[Quantity YTD]-
			[TargetToDate]
		formatString: #,0
		displayFolder: יעדים כללי
		lineageTag: e9fa442d-5b3d-4e76-afd7-fe664708573b

		changedProperty = IsHidden

	measure 'אחוז ביצוע מיעד' =
			DIVIDE([כמות מכירה],
			[יעד עד היום])
			/*B2B
			DIVIDE([מכירות],
			[יעד עד היום])
			*/
			/*B2C
			DIVIDE([מכירות לתקופה וסניפים עם יעד],[יעדים])*/
		formatString: 0%;-0%;0%
		displayFolder: יעדים כללי
		lineageTag: e239dd65-3cac-4dc5-b135-ea6bd28c61ec

		changedProperty = IsHidden

	measure '% Actual From Target' = DIVIDE([Quantity YTD],[TargetToDate])
		formatString: 0.00%;(0.00)%;0.00%
		displayFolder: יעדים כללי
		lineageTag: 4883a3fb-5b3d-4a4e-a3ee-4f46701555ac

		changedProperty = IsHidden

	measure 'Target Param' = 0.97
		displayFolder: יעדים כללי
		lineageTag: 95b73815-3e4d-4ccd-95f5-be8be18f9e61

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Ly Target' = [Sales Comparison LY] *[Target Param]
		formatString: 0
		displayFolder: יעדים כללי
		lineageTag: b02b44cd-7582-4708-bd30-613f7580061a

		changedProperty = IsHidden

	measure 'יעדים ממוצע מכירות ליום' =
			DIVIDE([כמות מכירה לתקופה וסניפים עם יעד],
				[כמות ימים עם מכירה])
		displayFolder: יעדים כללי
		lineageTag: 34ee169d-08d6-4bd2-8395-15ca207064d8

		changedProperty = IsHidden

