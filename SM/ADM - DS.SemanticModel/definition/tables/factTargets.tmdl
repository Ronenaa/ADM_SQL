	measure 'מכירות מצטברות יעדים' = CALCULATE(CALCULATE([כמות מכירה לתקופה וסניפים עם יעד],DATESYTD(dimDates[Date])),dimDates[IsHistory]=1)
		displayFolder: יעדים כללי
		lineageTag: a028a493-1727-4e53-ad70-a7b194f42485

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'יעד עד היום חודשי' =
			
			VAR ThisMonth=CALCULATE(MAX(dimDates[YearMonthSum]),dimDates[IsHistory]=1)
			return
			 CALCULATE([יעד עד היום],FILTER(dimDates,dimDates[YearMonthSum]=ThisMonth))
		displayFolder: יעד חודשי
		lineageTag: efccf089-72a8-4994-b9dd-ede792cfbe2c

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'מרחק מיעד חודשי' =
			[מכירות חודשי לתקופה סניפים עם יעד]
			-[יעד עד היום חודשי]
			
			/*[מכירות חודשי]
			-[יעד עד היום חודשי]*/
		formatString: #,0
		displayFolder: יעד חודשי
		lineageTag: 6c23a055-7450-4032-9cd3-ef6623351f01

		changedProperty = IsHidden

	measure 'ממוצע מכירות ליום חודשי יעדים' =
			
			VAR ThisMonth=CALCULATE(MAX(dimDates[YearMonthSum]),dimDates[IsHistory]=1)
			return
			 CALCULATE([יעדים ממוצע מכירות ליום],FILTER(dimDates,dimDates[YearMonthSum]=ThisMonth))
		formatString: #,0
		displayFolder: יעד חודשי
		lineageTag: a73ac713-7f1e-430d-b09c-dac00b2dafd2

		changedProperty = IsHidden

	measure 'יעד עד היום מצטבר' =
			
			CALCULATE(CALCULATE([יעד עד היום],DATESYTD(dimDates[Date])),dimDates[IsHistory]=1)
		displayFolder: יעד מצטבר
		lineageTag: e3af215b-1e29-4dc7-b716-5443b19c52f0

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'ממוצע כמות מכירה ליום שנתי יעדים' = CALCULATE(CALCULATE([יעדים ממוצע מכירות ליום],DATESYTD(dimDates[Date])),dimDates[IsHistory]=1)
		lineageTag: ba6b10db-ea6b-4965-bac4-bcf286b7c4e3

