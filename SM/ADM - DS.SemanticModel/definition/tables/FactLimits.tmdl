		source =
				let
				    Source = Sql.Database(#"SQL Address", "MT", [Query="#(lf)With InitalTable as(#(lf)Select QOD_QBOTSH as GroupID, #(lf)TAOR_QBOTSH AS 'ProductGroup'#(lf)  FROM ADM_QBOTSOT_PRIT#(lf))#(lf)#(lf)#(lf)Select#(lf)GroupID,#(lf)ProductGroup,#(lf)Case#(lf)#(tab)When GroupID = 1#(lf)#(tab)#(tab)Then 30000#(lf)#(tab)When GroupID = 2#(lf)#(tab)#(tab)Then 65000#(lf)#(tab)When GroupID = 5#(lf)#(tab)#(tab)Then 5000#(lf)#(tab)Else 10000#(lf)End as 'MaxLimit',#(lf)Case#(lf)#(tab)When GroupID = 1#(lf)#(tab)#(tab)Then -30000#(lf)#(tab)When GroupID = 2#(lf)#(tab)#(tab)Then -65000#(lf)#(tab)When GroupID = 5#(lf)#(tab)#(tab)Then -5000#(lf)#(tab)Else -10000#(lf)End as 'MinLimit'#(lf)From InitalTable#(lf)"])
