lf),CASE#(lf)#(tab)WHEN MTBE = '$'#(lf)#(tab)#(tab)THEN (MCHIR_ICH*SM.NEW_SHER)*Hqr.Cmot#(lf)#(tab)ELSE MCHIR_ICH*HqR.Cmot#(lf)END AS 'InvoiceAmount'#(lf),0.00 as 'PayedAmount'#(lf),null as 'Receipt'#(lf),HEROT_1 as 'Details'#(lf),CASE#(lf)#(tab)WHEN MTBE = '$'#(lf)#(tab)#(tab)THEN (MCHIR_ICH*SM.NEW_SHER)*Hqr.Cmot *1.18#(lf)#(tab)ELSE MCHIR_ICH*HqR.Cmot *1.18#(lf)END AS 'Debt'#(lf),CASE#(lf)#(tab)WHEN MTBE = '$'#(lf)#(tab)#(tab)THEN (MCHIR_ICH*SM.NEW_SHER)*Hqr.Cmot#(lf)#(tab)ELSE MCHIR_ICH*HqR.Cmot#(lf)END AS 'Obligo'#(lf)#(lf)--,MCHIR_ICH#(lf)--,HqR.Cmot#(lf)--,MTBE#(lf)--,SM.NEW_SHER#(lf)from HZMNOT HZ#(lf)inner join (#(lf)#(tab)#(tab)#(tab)select HZMNT_MCIRH#(lf)#(tab)#(tab)#(tab),sum(CMOT_MOQTST) as Cmot#(lf)#(tab)#(tab)#(tab)from HQTSAOT_RCSH_HCHLPH#(lf)#(tab)#(tab)#(tab)where 1=1#(lf)#(tab)#(tab)#(tab)and SOG_TM_SH_RCSH_HZMNT_HCHLPH <> ''#(lf)#(tab)#(tab)#(tab)--and HZMNT_MCIRH = 138471--139627#(lf)#(tab)#(tab)#(tab)group by HZMNT_MCIRH#(lf)#(tab)#(tab)#(tab)Having sum(CMOT_MOQTST) <> 0#(lf)#(tab)#(tab)#(tab)) HqR#(lf)#(tab)on  HZ.mspr_Hzmnh = HqR.HZMNT_MCIRH#(lf)Left join (#(lf)#(tab)#(tab)#(tab)Select distinct MS_HZMNH#(lf)#(tab)#(tab)#(tab)from QISHOR_T_MSHLOCH_HZMNOT#(lf)#(tab)#(tab)#(tab)) HzN#(lf)#(tab)on hz.MSPR_HZMNH = HzN.MS_HZMNH#(lf)Left Join (select *, #(lf)Case#(lf)#(tab)when sher = 0#(lf)#(tab)#(tab)then first_value(sher) over (partition by value_partition order by Tarikh) #(lf)#(tab)else sher#(lf)end as new_sher#(lf)from (#(lf)  select *, sum(case when sher=0 then 0 else 1 end) over (order by tarikh ) as value_partition#(lf)  from SHERI_MTBE) m#(lf)#(lf)) SM #(lf)#(tab)on SM.TARIKH= CONVERT(VARCHAR(8), GETDATE(), 112)--HZ.T_HZMNH --- שער המרה לפי תאריך של היום#(lf)Left Join GORMIM G#(lf)#(tab)on HZ.QOD_MQBL = G.QOD_GORM#(lf)where OrderStatus in (1,2)#(lf)--AND HzN.MS_HZMNH is null#(lf)AND Cast(SUBSTRING(T_HZMNH,1,4) as int) >=2018 and Cast(SUBSTRING(T_HZMNH,1,4) as int) <= Year(Getdate())#(lf)AND (Hqr.Cmot <> 0 or MCHIR_ICH <> 0)#(lf)#(lf)--AND MSPR_HZMNH = 139627#(lf)--AND QOD_MQBL = 1041#(lf)#(lf)------ תעודות משלוח פתוחות ללא חשבונית -------------#(lf)#(lf)UNION ALL#(lf)#(lf)Select MS_TEODH as 'TransactionID'#(lf),1 as 'Line'#(lf),2 as 'DocTypeCode' -- PK#(lf),'Delivery Notes' as 'DocType'-- Orders Before Shippment but after the item amount was allocated.#(lf),TM.QOD_MQBL as 'AccountKey'#(lf),TM.AISH_MCIROT as 'AgentKey'#(lf),null as 'Invoice'#(lf),SUBSTRING(TARIKH_MSHLOCH,1,4) + '-' + SUBSTRING(TARIKH_MSHLOCH,5,2) + '-' + SUBSTRING(TARIKH_MSHLOCH,7,2) as 'InvoiceDate'#(lf),SUBSTRING(TARIKH_MSHLOCH,1,4) + '-' + SUBSTRING(TARIKH_MSHLOCH,5,2) + '-' + SUBSTRING(TARIKH_MSHLOCH,7,2) as 'ExpectedPayDate'#(lf),NULL AS 'ActualPayedDate'#(lf),SUBSTRING(TARIKH_MSHLOCH,1,4) + '-' + SUBSTRING(TARIKH_MSHLOCH,5,2) + '-' + SUBSTRING(TARIKH_MSHLOCH,7,2) AS 'DeliveryDate'#(lf),G.TNAI_TSHLOM_IMIM as 'TNAI_TSHLOM'#(lf),CASE#(lf)#(tab)WHEN MTBE_SH = '$'#(lf)#(tab)#(tab)THEN (TM.MCHIR_ICH*SM.new_sher)*TM.MSHQL_NTO#(lf)#(tab)ELSE TM.MCHIR_ICH*TM.MSHQL_NTO#(lf)END AS 'InvoiceAmount'#(lf),0.00 as 'PayedAmount'#(lf),null as 'Receipt'#(lf),HEROT_1 as 'Details'#(lf),CASE#(lf)#(tab)WHEN MTBE_SH = '$'#(lf)#(tab)#(tab)THEN (TM.MCHIR_ICH*SM.new_sher)*TM.MSHQL_NTO * 1.18 -----תוספת מעמ#(lf)#(tab)ELSE TM.MCHIR_ICH*TM.MSHQL_NTO * 1.18#(lf)END AS 'Debt'#(lf),CASE#(lf)#(tab)WHEN MTBE_SH = '$'#(lf)#(tab)#(tab)THEN (TM.MCHIR_ICH*SM.new_sher)*TM.MSHQL_NTO#(lf)#(tab)ELSE TM.MCHIR_ICH*TM.MSHQL_NTO#(lf)END AS 'Obligo'#(lf)#(lf)#(lf)FROM TEODOT_MSHLOCH TM#(lf)Left Join (SELECT distinct MS_T_MSHLOCH#(lf)#(tab)#(tab)#(tab)FROM CHSHBONIOT_SHOROT#(lf)#(tab)#(tab)) CH#(lf)#(tab)on TM.MS_TEODH = CH.MS_T_MSHLOCH#(lf)Left Join (SELECT MS_HZMNH,MS_T_MSHLOCH#(lf)#(tab)#(tab)#(tab)FROM QISHOR_T_MSHLOCH_HZMNOT#(lf)#(tab)#(tab)) HZT#(lf)#(tab)on TM.MS_TEODH = HZT.MS_T_MSHLOCH#(lf)Left Join HZMNOT HZ#(lf)#(tab)on HZ.MSPR_HZMNH = HZT.MS_HZMNH#(lf)Left Join (select *, #(lf)Case#(lf)#(tab)when sher = 0#(lf)#(tab)#(tab)then first_value(sher) over (partition by value_partition order by Tarikh) #(lf)#(tab)else sher#(lf)end as new_sher#(lf)from (#(lf)  select *, sum(case when sher=0 then 0 else 1 end) over (order by tarikh ) as value_partition#(lf)  from SHERI_MTBE) m#(lf)#(lf)) SM  #(lf)#(tab)on SM.TARIKH=CONVERT(VARCHAR(8), GETDATE(), 112)--HZ.T_HZMNH --- שער המרה לפי תאריך של היום#(lf)Left Join GORMIM G#(lf)#(tab)on TM.QOD_MQBL = G.QOD_GORM#(lf)WHERE CH.MS_T_MSHLOCH is null#(lf)AND Cast(SUBSTRING(TARIKH_MSHLOCH,1,4) as int) >=2018 and Cast(SUBSTRING(TARIKH_MSHLOCH,1,4) as int) <= Year(Getdate())#(lf)AND STTOS in (0,1)#(lf)AND TM.ActionType not in (2,6,7,9,10)#(lf)AND TM.MCHIR_ICH <> 0#(lf)AND TM.PurchaseOrderType = 0#(lf)#(lf)#(lf)--AND TM.QOD_MQBL = 1041#(lf)#(lf)#(lf)-------חשבוניות פתוחות ------#(lf)UNION ALL#(lf)#(lf)#(lf)Select CH.MS_CHSHBONIT as 'TransactionID'#(lf),1 as 'Line'#(lf),3 as 'DocTypeCode' -- PK#(lf),'Open Invoices' as 'DocType'-- Orders Before Shippment but after the item amount was allocated.#(lf),CH.QOD_LQOCH as 'AccountKey'#(lf),AM.QOD as 'AgentKey'#(lf),null as 'Invoice'#(lf),SUBSTRING(TARIKH_HPQH,1,4) + '-' + SUBSTRING(TARIKH_HPQH,5,2) + '-' + SUBSTRING(TARIKH_HPQH,7,2) as 'InvoiceDate'#(lf),SUBSTRING(PREON_TSHLOM,1,4) + '-' + SUBSTRING(PREON_TSHLOM,5,2) + '-' + SUBSTRING(PREON_TSHLOM,7,2) as 'ExpectedPayDate'#(lf),NULL AS 'ActualPayedDate'#(lf),FirstDeliveryDate AS 'DeliveryDate'#(lf),G.TNAI_TSHLOM_IMIM as 'TNAI_TSHLOM'#(lf),CH.SH_C_LLA_ME_M + ME_M AS 'InvoiceAmount'#(lf),CASE#(lf)#(tab)WHEN Round(QCH.SCOM,0) = 0#(lf)#(tab)#(tab)Then 0#(lf)#(tab)Else isnull(QCH.SCOM,0)#(lf)END AS 'PayedAmount'#(lf),null as 'Receipt'#(lf),null as 'Details'#(lf),CH.SH_C_LLA_ME_M + ME_M-isnull(QCH.SCOM,0) AS 'Debt'#(lf),CH.SH_C_LLA_ME_M + ME_M-isnull(QCH.SCOM,0) AS 'Obligo'#(lf)#(lf)FROM CHSHBONIOT_COTROT CH#(lf)left join (Select CHSHBONIT, SUM(SCOM_MOTAM) as SCOM#(lf)#(tab)#(tab)#(tab)from QISHOR_QBLOT_CHSHBONIOT#(lf)#(tab)#(tab)#(tab)GROUP BY CHSHBONIT#(lf)#(tab)#(tab)#(tab)) QCH#(lf)#(tab)on CH.MS_CHSHBONIT = QCH.CH