	measure 'Total Invoices' = DISTINCTCOUNT(factCollection[חשבונית])
		formatString: #,0
		lineageTag: 32832cb8-16d2-4aa4-998c-fab153bccc14

		changedProperty = IsHidden

	measure 'Debt To Date 12 Month' = ```
			
			var MaxDate = CALCULATE(MAX(dimDates[Date]),FILTER(dimDates,dimDates[Date]<=TODAY()))
			var MaxSubDate = CALCULATE(MAX(Sub_dimDates[Date]),FILTER(Sub_DimDates,Sub_dimDates[Date]<=MaxDate))
			var MinDate = DATE(YEAR(MaxDate)-1,MONTH(MaxDate),1)
			var _Debt =
			CALCULATE(SUM(factCollection[PayedToDate]), 
			    CALCULATETABLE(
			            FILTER(
			                    factCollection,
			                    factCollection[InvoiceDate]<=MaxSubDate 
			                    && ((factCollection[תאריך קבלה]>=MaxSubDate)|| ISBLANK([תאריך קבלה])) 
			                    && (
			                        factCollection[DocTypeCode] = 3 
			                        || 
			                        factCollection[DocTypeCode] = 4 
			                        || 
			                        factCollection[DocTypeCode] = 5
			                        ) 
			                )
			                ,CALCULATETABLE(ALL(Sub_dimDates),USERELATIONSHIP(factCollection[InvoiceDate],Sub_DimDates[Date]))
			                ,REMOVEFILTERS(dimDates)
			            )
			        )
			
			RETURN
			IF(MaxSubDate<MinDate || MaxSubDate>MaxDate,BLANK(),_Debt)
			```
		formatString: "₪"\ #,0.##;"₪"(#,0.##);"₪"\ #,0.##
		lineageTag: 5e95739a-9c48-4983-a31a-1c58aa3ce34b

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"currencyCulture":"he-IL"}

	measure 'Cash Flow' = ```
			
			var _date = CALCULATE(MAX(dimDates[Date]),dimDates[IsHistory]=1)
			var _Mindate = DATE(YEAR(_date),MONTH(_date)-6,1)
			var _maxdate = DATE(YEAR(_date),MONTH(_date)+7,1)
			var expctedRecipted =
			CALCULATE(SUM(factCollection[Debt]),(factCollection[DocTypeCode]<>4)) 
			
			Return
			
			IF(
			    MAX(Sub_DimDates[Date])< _Mindate || MAX(Sub_DimDates[Date])> _maxdate ,
			    BLANK(),
			    IF(ISBLANK(expctedRecipted),0,expctedRecipted)
			)
			```
		formatString: "₪"\ #,0.##;"₪"(#,0.##);"₪"\ #,0.##
		lineageTag: 78836b1d-567e-46b6-afe7-64b4bfde8278

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"currencyCulture":"he-IL"}

	measure 'Customer Days VS Payment Term' =
			
			IF(MAX(dimCustomers[PaymentTermOrder])<10, //IF Payment Term is Immidate,+1,+5
			        IF(  [Customer Days] > MAX(dimCustomers[PaymentTermOrder]) +10,1,0), //Then Check if Customer Days is greater then 10 only more then 10 days will be considered OVER
			    IF(MAX(dimCustomers[PaymentTermOrder])<20,
			        IF([Customer Days] > MAX(dimCustomers[PaymentTermOrder]) + 5,1,0),
			     IF([Customer Days] > MAX(dimCustomers[PaymentTermOrder]) *1.25,1,0)
			    ))
		formatString: 0
		lineageTag: 0f6b5643-face-4082-a797-cb784f32dc54

		changedProperty = IsHidden

	measure 'Customer Days Vs Payment Term Count Over' = ```
			
			Var _Count = COUNTROWS(
			        FILTER(
			            SUMMARIZE(dimCustomers,dimCustomers[AccountKey],dimCustomers[תנאי תשלום ללקוח],"CustomerDayFlag",[Customer Days VS Payment Term])
			            ,[CustomerDayFlag]=1 
			        )
			)
			
			RETURN
			IF(ISBLANK([Customer Days]),BLANK(),IF(ISBLANK(_Count),0,_Count))
			```
		formatString: 0
		lineageTag: 6f9f4c74-5798-42dd-9429-d46846a5e520

		changedProperty = IsHidden

	measure 'Customer Days Vs Payment Term Count Under' =
			
			Var _Count = COUNTROWS(
			        FILTER(
			            SUMMARIZE(dimCustomers,dimCustomers[AccountKey],dimCustomers[תנאי תשלום ללקוח],dimCustomers[סטטוס לקוח],"CustomerDayFlag",[Customer Days VS Payment Term])
			            ,[CustomerDayFlag]=0 && dimCustomers[סטטוס לקוח] = True()
			        )
			)
			
			RETURN
			IF(ISBLANK([Customer Days]),BLANK(),IF(ISBLANK(_Count),0,_Count))
		formatString: 0
		lineageTag: 8ca50ef8-3037-4792-becc-f0ecaa3ef84e

		changedProperty = IsHidden

