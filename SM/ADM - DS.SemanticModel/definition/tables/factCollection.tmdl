	measure 'Customer Days All Customers Margin' = Round([Customer Days] - [Customer Days All Customers],0)
		formatString: 0
		lineageTag: 3d823cbf-4b04-4eb9-85f1-ec49ebfafe8b

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'Customer Margin Debt' = ```
			
			Var _MarginValue = VALUES('Customer Days Range'[Customer Days Range])
			                       
			Var _Count =
			                    Filter(
			                    SUMMARIZE(
			                            dimCustomers,
			                            dimCustomers[AccountKey],
			                            "CustomerDays",[Customer Days],
			                            "Debt", [Debt To Date],
			                            "CustomerDaysMargin",IF(
			                                                    [Customer Days All Customers Margin]>30,
			                                                    30,
			                                                    IF(
			                                                        [Customer Days All Customers Margin]<-30,
			                                                        -30,
			                                                        [Customer Days All Customers Margin])
			                                                        )
			                                )
			                    ,[CustomerDaysMargin]=_MarginValue && [CustomerDays] >0 )
			                    
			
			RETURN
			IF(HASONEFILTER('Customer Days Range'[Customer Days Range]),
			    (SUMX(_Count,[Debt])),
			    1)
			```
		formatString: "₪"\ #,0.###############;"₪"-#,0.###############;"₪"\ #,0.###############
		lineageTag: 9b6e88f8-10c8-4806-8544-de5ee2105615

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"currencyCulture":"he-IL"}

