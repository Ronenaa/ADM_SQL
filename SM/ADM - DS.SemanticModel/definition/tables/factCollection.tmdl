		lineageTag: 4a64f72f-987e-4db2-8fe8-f207fb34895e

		changedProperty = IsHidden

	measure 'Customer Days' =
			
			VAR _maxdate = CALCULATE(MAX(dimDates[Date]),dimDates[IsHistory]=1)
			VAR _180Days = DATE(YEAR(_maxdate),MONTH(_maxdate),DAY(_maxdate)-180)
			VAR _table = CALCULATETABLE(SUMMARIZE(factCollection,dimCustomers[AccountKey],factCollection[TransactionID],
			                "PaidtoDate",SUM(factCollection[PayedToDate]),
			                "Days", DATEDIFF(MAX(factCollection[InvoiceDate]),
			                    IF(
			                        ISBLANK(MAX(factCollection[תאריך קבלה])),
			                        _maxdate,
			                        IF(
			                            MAX(factCollection[תאריך קבלה])>=_maxdate,
			                            _maxdate,
			                            MAX(factCollection[תאריך קבלה])
			                            )
			                    )
			                    ,DAY)
			                    ),
			                    factCollection[PayedToDate]>0,All(dimDates),factCollection[InvoiceDate]<=_maxdate && factCollection[invoiceDate]>=_180Days,factCollection[DocTypeCode]<>1
			                    )
			RETURN
			SUMX(_table,[PaidtoDate]*[Days])
			/
			SUMX(_table,[PaidtoDate])
		lineageTag: a7ea06b6-96cf-4b0f-a57a-57a33997b913

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Debt To Date' = ```
			
			var MaxDate = CALCULATE(MAX(dimDates[Date]),FILTER(dimDates,dimDates[Date]<=TODAY())) 
			RETURN
			CALCULATE(SUM(factCollection[PayedToDate]), 
			  CALCULATETABLE(FILTER(factCollection,factCollection[InvoiceDate]<=MaxDate && ((factCollection[תאריך קבלה]>MaxDate)|| ISBLANK([תאריך קבלה])) && (factCollection[DocTypeCode] = 3 || factCollection[DocTypeCode] = 4 || factCollection[DocTypeCode] = 5) ),ALL(dimDates)))
			```
		formatString: "₪"\ #,0.00;"₪"-#,0.00;"₪"\ #,0.00
		lineageTag: 5dc8a6b9-b0e9-40b0-90dc-c12da4f0b068

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"currencyCulture":"he-IL"}

