expression CreatePeriodTable = ```
		let
		    Source = (
		PeriodName as text,
		StartDate as date, 
		EndDate as date, 
		SortOrder as number
		) as table =>
		let
		DayCount = Duration.Days(EndDate-StartDate)+1,
		DateList = List.Dates(StartDate,DayCount,#duration(1,0,0,0)),
		AddPeriodName = List.Transform(DateList, 
		each {PeriodName,_,SortOrder}),
		CreateTable = #table(
		type table[Period=text, Date=date, Sort=number], 
		AddPeriodName)
		in
		CreateTable
		in
		    Source
		```
	lineageTag: 46b4b0c7-4acb-4989-9fa3-c043bf122b03
	queryGroup: 'Dates Dim'

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Function

expression CreatedimPeriodTable = ```
		let
		    Source = (
		PeriodName as text,
		StartDate as date, 
		EndDate as date, 
		FullDate as date,
		SortOrder as number
		) as table =>
		let
		//FullDayCount = Duration.Days(FullDate-StartDate)+1, //Old Calc
		FullDayCount = CalcWorkingDays(StartDate ,FullDate),
		DayCount = Duration.Days(EndDate-StartDate)+1,
		DateList = List.Dates(StartDate,DayCount,#duration(1,0,0,0)),
		AddPeriodName = List.Transform(DateList, 
		each {PeriodName,_,SortOrder,FullDayCount}),
		CreateTable = #table(
		type table[Period=text, Date=date, Sort=number,FullDays=number], 
		AddPeriodName)
		in
		CreateTable
		in
		    Source
		```
	lineageTag: a12bcc77-02c9-458d-8bea-dea0f51c6ed3
	queryGroup: 'Dates Dim'

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Function

expression CalcWorkingDays =
		(StartDate,EndDate)=>
		
		let
		    Source = dimDates,
		    #"Filtered Rows" = Table.SelectRows(Source, each [Date] >= StartDate and [Date] <= EndDate),
		    #"Calculated Sum" = List.Sum(#"Filtered Rows"[Is Working Day])
		in
		    #"Calculated Sum"
	lineageTag: 852e5f89-bae7-4293-8dff-3adde1aafce0
	queryGroup: 'Dates Dim'

