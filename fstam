CIF Purchase

CIF Price = 
CALCULATE([Avg Price USD (Expenses)]
            ,dimItems[PNL Description] = "Purchase Inventory"
)

Avg Price USD (Expenses) = DIVIDE([Total Expenses USD],[Total Order Quantity (Hzmnot)])

Total Expenses USD = SUM(factPurchaseExpenses[LineTotalNetUSD])

Total Order Quantity (Hzmnot) = SUM(factPurchaseExpenses[OrderQuantity])


in sql:
sum( 
    case when then SUM([LineTotalNetUSD])
)
