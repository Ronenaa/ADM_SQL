Avg Unit Price (Sales) = 
 DIVIDE([Total Sales (Sales)],[Total Quantity (Sales)])


--------------------------------------------------------------
AVG Unit Price (Sales) - FOT = 
CALCULATE(
    [Avg Unit Price (Sales) Item],
    FILTER(factSales,[ActionTypeDesc] = "מכירה")
    )

Avg Unit Price (Sales) Item = 
 DIVIDE([Total Sales USD (Sales) Only Item],[Total Quantity (Sales)])    

 Total Sales USD (Sales) Only Item = 
CALCULATE(SUM(factSales[LineTotalNet_USD]), factSales[AdjustmentFlag] <> 1 && factSales[LineType] = "Item")

Total Quantity (Sales) = 
CALCULATE(SUM(factSales[Quantity]), factSales[AdjustmentFlag] <> 1)


